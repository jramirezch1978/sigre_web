# SIGRE ERP — Variables de entorno (copiar a .env en cronos)
# cp .env.example .env && nano .env

# PostgreSQL (contenedor postgres en stack_default)
POSTGRES_USER=${postgres_superuser}
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES
ERP_APP_PASSWORD=CHANGE_ME_ERP_APP

# Imágenes
IMAGE_REGISTRY=${image_registry}
IMAGE_TAG=${image_tag}

# URLs públicas
PUBLIC_HOST=${public_host}
API_GATEWAY_URL=http://${public_host}:${api_gateway_port}
FRONTEND_URL=http://${public_host}:${frontend_port}

# Zona horaria
TZ=${timezone}

# JDBC interno (solo red Docker — NO usar IP pública)
# jdbc:postgresql://${postgres_service}:5432/sigre_security
# jdbc:postgresql://${postgres_service}:5432/template_sigre
# jdbc:postgresql://${postgres_service}:5432/sigre_emp_cantabria
