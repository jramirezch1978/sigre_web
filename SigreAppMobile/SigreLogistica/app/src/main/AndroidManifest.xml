<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:name=".SigreApplication"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher"
        android:supportsRtl="true"
        android:usesCleartextTraffic="true"
        android:theme="@style/Theme.SigreLogistica">

        <activity
            android:name=".ui.login.LoginActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity android:name=".ui.empresa.SeleccionEmpresaActivity" android:exported="false" />
        <activity android:name=".ui.menu.MenuActivity" android:exported="false" />

        <activity android:name=".ui.almacen.AlmacenOpcionesActivity" android:exported="false" />
        <activity android:name=".ui.almacen.movimientos.MovimientosListActivity" android:exported="false" />

        <activity android:name=".ui.compras.ComprasOpcionesActivity" android:exported="false" />
        <activity android:name=".ui.compras.solicitudes.SolicitudesListActivity" android:exported="false" />

    </application>

</manifest>
