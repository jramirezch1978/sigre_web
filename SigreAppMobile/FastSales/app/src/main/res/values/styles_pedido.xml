<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="PedidoButton">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">40dp</item>
        <item name="android:minWidth">88dp</item>
        <item name="android:minHeight">40dp</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:paddingLeft">14dp</item>
        <item name="android:paddingRight">14dp</item>
        <item name="android:layout_marginEnd">6dp</item>
        <item name="android:elevation">2dp</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <style name="PedidoButton.Primary">
        <item name="android:background">@drawable/btn_pedido_primary</item>
        <item name="android:textColor">@android:color/white</item>
    </style>

    <style name="PedidoButton.Success">
        <item name="android:background">@drawable/btn_pedido_success</item>
        <item name="android:textColor">@android:color/white</item>
    </style>

    <style name="PedidoButton.Secondary">
        <item name="android:background">@drawable/btn_pedido_secondary</item>
        <item name="android:textColor">#1565C0</item>
    </style>

    <style name="PedidoButton.Muted">
        <item name="android:background">@drawable/btn_pedido_muted</item>
        <item name="android:textColor">@android:color/white</item>
    </style>

    <style name="PedidoButton.Danger">
        <item name="android:background">@drawable/btn_pedido_danger</item>
        <item name="android:textColor">@android:color/white</item>
    </style>

    <style name="PedidoButton.IconTab">
        <item name="android:layout_width">40dp</item>
        <item name="android:layout_height">36dp</item>
        <item name="android:minWidth">40dp</item>
        <item name="android:minHeight">36dp</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="android:padding">0dp</item>
        <item name="android:elevation">2dp</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <!-- Branding ERP para modales -->
    <style name="ErpDialogRoot">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">vertical</item>
        <item name="android:background">#F5F5F5</item>
    </style>

    <style name="ErpDialogHeader">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">vertical</item>
        <item name="android:background">@drawable/bg_dialog_header</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
    </style>

    <style name="ErpDialogTitle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="ErpDialogSubtitle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">4dp</item>
        <item name="android:textColor">#E3F2FD</item>
        <item name="android:textSize">12sp</item>
    </style>

    <style name="ErpDialogLabel">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">#1565C0</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:layout_marginBottom">6dp</item>
    </style>

    <style name="ErpDialogFooter">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:gravity">end</item>
        <item name="android:padding">12dp</item>
        <item name="android:background">@android:color/white</item>
    </style>
</resources>
