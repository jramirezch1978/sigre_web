<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <include layout="@layout/include_rrhh_empresa_banner" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    style="@style/RrhhCardHeaderBar"
                    android:text="📋 DATOS DEL PARTE" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        style="@style/RrhhFieldLabel"
                        android:layout_marginTop="0dp"
                        android:text="FECHA PARTE" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <EditText
                            android:id="@+id/etFechaParte"
                            style="@style/RrhhFieldInput"
                            android:layout_width="0dp"
                            android:layout_marginEnd="6dp"
                            android:layout_weight="1"
                            android:clickable="true"
                            android:focusable="false"
                            android:hint="DD/MM/YYYY" />

                        <ImageButton
                            android:id="@+id/btnFechaParte"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_rrhh_input"
                            android:contentDescription="Seleccionar fecha"
                            android:padding="10dp"
                            android:scaleType="centerInside"
                            android:src="@android:drawable/ic_menu_my_calendar" />
                    </LinearLayout>

                    <TextView
                        style="@style/RrhhFieldLabel"
                        android:text="CLIENTE" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_rrhh_search_row"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="6dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:paddingStart="8dp"
                            android:paddingEnd="8dp">

                            <EditText
                                android:id="@+id/etCliente"
                                android:layout_width="0dp"
                                android:layout_height="0dp"
                                android:visibility="gone" />

                            <TextView
                                android:id="@+id/tvClienteCodigo"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Código: —"
                                android:textColor="#757575"
                                android:textSize="12sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvNombreCliente"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:ellipsize="end"
                                android:maxLines="2"
                                android:minHeight="40dp"
                                android:text="Nombre de empresa"
                                android:textColor="#212121"
                                android:textSize="16sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <Button
                            android:id="@+id/btnBuscarCliente"
                            style="@style/RrhhButtonSearch"
                            android:text="BUSCAR" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    style="@style/RrhhCardHeaderBar"
                    android:text="👥 CUADRILLA Y FILTROS" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        style="@style/RrhhFieldLabel"
                        android:layout_marginTop="0dp"
                        android:text="BUSCAR CUADRILLA" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_rrhh_search_row"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="6dp">

                        <EditText
                            android:id="@+id/etFiltroCuadrilla"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:background="@null"
                            android:hint="Código o descripción"
                            android:minHeight="44dp"
                            android:paddingStart="8dp"
                            android:paddingEnd="8dp"
                            android:textColor="#212121"
                            android:textColorHint="#9E9E9E"
                            android:textSize="16sp" />

                        <Button
                            android:id="@+id/btnBuscarCuadrilla"
                            style="@style/RrhhButtonSearch"
                            android:text="BUSCAR" />
                    </LinearLayout>

                    <TextView
                        style="@style/RrhhFieldLabel"
                        android:text="FILTROS TARIFARIO (OPCIONAL)" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <EditText
                            android:id="@+id/etFiltroEspecie"
                            style="@style/RrhhFieldInput"
                            android:layout_width="0dp"
                            android:layout_marginEnd="6dp"
                            android:layout_weight="1"
                            android:hint="Especie" />

                        <EditText
                            android:id="@+id/etFiltroPresentacion"
                            style="@style/RrhhFieldInput"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:hint="Pres." />
                    </LinearLayout>

                    <EditText
                        android:id="@+id/etFiltroTarea"
                        style="@style/RrhhFieldInput"
                        android:hint="Tarea" />

                    <TextView
                        style="@style/RrhhFieldLabel"
                        android:text="CUADRILLA SELECCIONADA" />

                    <EditText
                        android:id="@+id/etCuadrilla"
                        style="@style/RrhhFieldReadOnly"
                        android:enabled="false"
                        android:hint="Sin seleccionar" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_rrhh_info_panel"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Información de cuadrilla"
                            android:textColor="#757575"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tvInfoCuadrilla"
                            style="@style/RrhhInfoPanelText"
                            android:layout_marginTop="4dp"
                            android:text="Turno y OT aparecerán aquí" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="8dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    style="@style/RrhhCardHeaderBar"
                    android:text="⚙ LABOR / TARIFARIO / OPERACIÓN" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        style="@style/RrhhFieldLabel"
                        android:layout_marginTop="0dp"
                        android:text="ESPECIE / PRESENTACIÓN / TAREA" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <EditText
                            android:id="@+id/etEspecie"
                            style="@style/RrhhFieldReadOnly"
                            android:layout_width="0dp"
                            android:layout_marginEnd="6dp"
                            android:layout_weight="1"
                            android:enabled="false"
                            android:hint="Especie" />

                        <Button
                            android:id="@+id/btnBuscarLabor"
                            style="@style/RrhhButtonSearch"
                            android:text="LABOR" />
                    </LinearLayout>

                    <EditText
                        android:id="@+id/etPresentacion"
                        style="@style/RrhhFieldReadOnly"
                        android:enabled="false"
                        android:hint="Presentación" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <EditText
                            android:id="@+id/etTarea"
                            style="@style/RrhhFieldReadOnly"
                            android:layout_width="0dp"
                            android:layout_marginEnd="6dp"
                            android:layout_weight="1"
                            android:enabled="false"
                            android:hint="Tarea" />

                        <Button
                            android:id="@+id/btnBuscarTarifario"
                            style="@style/RrhhButtonSearch"
                            android:text="TARIF." />
                    </LinearLayout>

                    <TextView
                        style="@style/RrhhFieldLabel"
                        android:text="OT ADMINISTRATIVA (DATOS O.T.)" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <EditText
                            android:id="@+id/etOtAdm"
                            style="@style/RrhhFieldReadOnly"
                            android:layout_width="0dp"
                            android:layout_marginEnd="6dp"
                            android:layout_weight="1"
                            android:enabled="false"
                            android:hint="ot_adm" />

                        <Button
                            android:id="@+id/btnBuscarOtAdm"
                            style="@style/RrhhButtonSearch"
                            android:text="OT ADM" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvOtAdmDesc"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textColor="#616161"
                        android:textSize="13sp"
                        android:visibility="gone" />

                    <TextView
                        style="@style/RrhhFieldLabel"
                        android:text="NRO. ORDEN DE TRABAJO" />

                    <EditText
                        android:id="@+id/etNroOrden"
                        style="@style/RrhhFieldReadOnly"
                        android:enabled="false"
                        android:hint="nro_orden" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_rrhh_info_panel"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tarifa unitaria"
                            android:textColor="#757575"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tvTarifa"
                            style="@style/RrhhHighlightValue"
                            android:layout_marginTop="4dp"
                            android:text="Tarifa: -" />
                    </LinearLayout>

                    <TextView
                        style="@style/RrhhFieldLabel"
                        android:text="OPERACIÓN" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <EditText
                            android:id="@+id/etOperSec"
                            style="@style/RrhhFieldReadOnly"
                            android:layout_width="0dp"
                            android:layout_marginEnd="6dp"
                            android:layout_weight="1"
                            android:enabled="false"
                            android:hint="oper_sec" />

                        <Button
                            android:id="@+id/btnBuscarOper"
                            style="@style/RrhhButtonSearch"
                            android:text="OPER." />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_rrhh_info_panel"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Producción total del parte"
                            android:textColor="#757575"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tvProdTotal"
                            style="@style/RrhhHighlightValue"
                            android:layout_marginTop="4dp"
                            android:text="0.00" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>
</merge>
