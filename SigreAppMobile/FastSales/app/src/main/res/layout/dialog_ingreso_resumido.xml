<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#1976D2"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ingreso Simplificado de Artículos"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Registro rápido de artículos con precios y tallas"
            android:textColor="#E3F2FD"
            android:textSize="12sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:layout_weight="1"
            android:background="#b9e19b">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingBottom="2sp"
                android:paddingTop="2sp"
                android:orientation="vertical">

                <!-- Categoria y Sub Categoria -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:layout_weight="1">

                        <TextView
                            android:layout_width="150sp"
                            android:layout_height="match_parent"
                            android:text="Categoria :"
                            android:textStyle="bold"
                            android:textColor="#1565C0"
                            android:textSize="13sp"
                            android:gravity="right|center_vertical"/>

                        <EditText
                            android:id="@+id/etCategoria"
                            android:layout_width="60dip"
                            android:layout_height="match_parent"
                            android:singleLine="true"
                            android:gravity="center_horizontal|center_vertical"
                            android:text="01A "
                            android:textSize="18dp"
                            android:background="@drawable/rounded_edit_text"/>

                        <Button
                            android:id="@+id/btnCategoria"
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:gravity="center_horizontal|center_vertical"
                            android:padding="0dp"
                            android:text="..."
                            android:textSize="18dp" />

                        <TextView
                            android:id="@+id/tvDescCategoria"
                            android:layout_width="160dp"
                            android:layout_height="match_parent"
                            android:gravity="center_vertical|left"
                            android:text="CALZADO CABALLERO"
                            android:textColor="@android:color/holo_red_dark"
                            android:textSize="14dip" />


                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:layout_weight="1">

                        <TextView
                            android:layout_width="130sp"
                            android:layout_height="wrap_content"
                            android:text="Sub Categoria :"
                            android:textStyle="bold"
                            android:textColor="#1565C0"
                            android:textSize="13sp"
                            android:gravity="right|center_vertical"/>

                        <EditText
                            android:id="@+id/etSubCategoria"
                            android:layout_width="80dip"
                            android:layout_height="match_parent"
                            android:singleLine="true"
                            android:gravity="center_horizontal|center_vertical"
                            android:text="01A001"
                            android:textSize="18dp"
                            android:background="@drawable/rounded_edit_text"/>

                        <Button
                            android:id="@+id/btnSubCategoria"
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:gravity="center_horizontal|center_vertical"
                            android:padding="0dp"
                            android:text="..."
                            android:textSize="18dp" />

                        <TextView
                            android:id="@+id/tvDescSubCategoria"
                            android:layout_width="150dp"
                            android:layout_height="match_parent"
                            android:text="ALPARGATA - CALZADO CABALLERO"
                            android:gravity="center_vertical|left"
                            android:textSize="13dp"
                            android:textColor="@android:color/holo_red_dark"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Marca -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="150sp"
                        android:layout_height="match_parent"
                        android:text="Marca :"
                        android:id="@+id/textView03"
                        android:textStyle="bold"
                        android:textColor="#1565C0"
                        android:textSize="13sp"
                        android:gravity="right"/>

                    <EditText
                        android:id="@+id/etMarca"
                        android:layout_width="120dp"
                        android:layout_height="wrap_content"
                        android:singleLine="true"
                        android:paddingRight="10dip"
                        android:paddingLeft="10dip"
                        android:gravity="left|center_vertical"
                        android:text="00000002"
                        android:textSize="18dip"
                        android:background="@drawable/rounded_edit_text"/>

                    <Button
                        android:id="@+id/btnMarca"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:layout_marginLeft="10dip"
                        android:gravity="center_horizontal|center_vertical"
                        android:padding="0dp"
                        android:text="..."
                        android:textSize="18dp" />

                    <TextView
                        android:id="@+id/tvDescMarca"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:text="LENOX"
                        android:layout_marginRight="10dip"
                        android:layout_marginLeft="10dip"
                        android:gravity="center_vertical|left"
                        android:textSize="18dp"
                        android:textColor="@android:color/holo_red_dark"/>

                </LinearLayout>

                <!-- Estilo -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="150sp"
                        android:layout_height="match_parent"
                        android:text="Estilo :"
                        android:textStyle="bold"
                        android:textColor="#1565C0"
                        android:textSize="13sp"
                        android:gravity="right"/>

                    <EditText
                        android:id="@+id/etEstilo"
                        android:layout_width="400dp"
                        android:layout_height="wrap_content"
                        android:singleLine="true"
                        android:paddingRight="10dip"
                        android:paddingLeft="10dip"
                        android:gravity="left|center_vertical"
                        android:text="HOLSONST"
                        android:textSize="18dp"
                        android:background="@drawable/rounded_edit_text"/>

                    <TextView
                        android:id="@+id/tvLink"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:text="No hay sugerencias"
                        android:textSize="18dp"
                        android:layout_marginLeft="15dp"
                        android:textStyle="bold"
                        android:textColor="@android:color/holo_blue_dark"
                        android:autoLink="all" />

                </LinearLayout>

                <!-- Linea y Sub Linea -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:layout_weight="1">

                        <TextView
                            android:layout_width="150dp"
                            android:layout_height="match_parent"
                            android:text="Linea :"
                            android:textStyle="bold"
                            android:textColor="#1565C0"
                            android:textSize="13sp"
                            android:gravity="right|center_vertical"/>

                        <EditText
                            android:id="@+id/etLinea"
                            android:layout_width="70dp"
                            android:layout_height="wrap_content"
                            android:singleLine="true"
                            android:gravity="center_horizontal|center_vertical"
                            android:text="001"
                            android:textSize="18dp"
                            android:background="@drawable/rounded_edit_text"/>

                        <Button
                            android:id="@+id/btnLinea"
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:gravity="center_horizontal|center_vertical"
                            android:padding="0dp"
                            android:text="..."
                            android:textSize="18dp" />

                        <TextView
                            android:id="@+id/tvDescLinea"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:text="VESTIR"
                            android:gravity="left|center_vertical"
                            android:textSize="18dp"
                            android:textColor="@android:color/holo_red_dark"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:layout_weight="1">

                        <TextView
                            android:layout_width="130sp"
                            android:layout_height="match_parent"
                            android:text="Sub Linea :"
                            android:textStyle="bold"
                            android:textColor="#1565C0"
                            android:textSize="13sp"
                            android:gravity="right|center_vertical"/>

                        <EditText
                            android:id="@+id/etSubLinea"
                            android:layout_width="70dp"
                            android:layout_height="wrap_content"
                            android:singleLine="true"
                            android:gravity="center_horizontal|center_vertical"
                            android:text="000001"
                            android:textSize="18dp"
                            android:background="@drawable/rounded_edit_text"/>

                        <Button
                            android:id="@+id/btnSubLinea"
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:gravity="center_horizontal|center_vertical"
                            android:padding="0dp"
                            android:text="..."
                            android:textSize="18dp" />

                        <TextView
                            android:id="@+id/tvDescSubLinea"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:text="ALPARGATA"
                            android:gravity="left|center_vertical"
                            android:textSize="18dp"
                            android:textColor="@android:color/holo_red_dark"/>

                        <ImageButton
                            android:id="@+id/ibtAddSubLinea"
                            android:layout_width="40dip"
                            android:layout_height="35dip"
                            android:padding="0dp"
                            android:background="@android:color/white"
                            android:scaleType="fitCenter"
                            android:src="@drawable/note_add"
                            android:gravity="center_horizontal|center_vertical"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Suela -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="150sp"
                        android:layout_height="match_parent"
                        android:text="Suela :"
                        android:textStyle="bold"
                        android:textColor="#1565C0"
                        android:textSize="13sp"
                        android:gravity="right"/>

                    <EditText
                        android:id="@+id/etSuela"
                        android:layout_width="70dp"
                        android:layout_height="wrap_content"
                        android:singleLine="true"
                        android:paddingRight="10dip"
                        android:paddingLeft="10dip"
                        android:gravity="center_horizontal|center_vertical"
                        android:text="002"
                        android:textSize="18dp"
                        android:background="@drawable/rounded_edit_text"/>

                    <Button
                        android:id="@+id/btnSuela"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:gravity="center_horizontal|center_vertical"
                        android:padding="0dp"
                        android:text="..."
                        android:textSize="18dp" />

                    <TextView
                        android:id="@+id/tvDescSuela"
                        android:layout_width="400dp"
                        android:layout_height="match_parent"
                        android:text="SARDEGNA"
                        android:layout_marginRight="10dip"
                        android:gravity="center_vertical|left"
                        android:textSize="18dp"
                        android:textColor="@android:color/holo_red_dark"/>

                    <ImageButton
                        android:id="@+id/ibtAddSuela"
                        android:layout_width="40dip"
                        android:layout_height="match_parent"
                        android:layout_marginLeft="10dp"
                        android:padding="0dp"
                        android:background="@android:color/white"
                        android:scaleType="fitCenter"
                        android:src="@drawable/note_add" />

                </LinearLayout>

                <!-- Acabado -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="150sp"
                        android:layout_height="match_parent"
                        android:text="Acabado :"
                        android:textStyle="bold"
                        android:textColor="#1565C0"
                        android:textSize="13sp"
                        android:gravity="right"/>

                    <EditText
                        android:id="@+id/etAcabado"
                        android:layout_width="70dp"
                        android:layout_height="wrap_content"
                        android:singleLine="true"
                        android:paddingRight="10dip"
                        android:paddingLeft="10dip"
                        android:gravity="center_horizontal|center_vertical"
                        android:text="NOB"
                        android:textSize="18dp"
                        android:background="@drawable/rounded_edit_text"/>

                    <Button
                        android:id="@+id/btnAcabado"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:gravity="center_horizontal|center_vertical"
                        android:padding="0dp"
                        android:text="..."
                        android:textSize="18dp" />

                    <TextView
                        android:id="@+id/tvDescAcabado"
                        android:layout_width="400dp"
                        android:layout_height="match_parent"
                        android:text="NOB"
                        android:layout_marginRight="10dip"
                        android:gravity="center_vertical|left"
                        android:textSize="18dp"
                        android:textColor="@android:color/holo_red_dark"/>

                    <ImageButton
                        android:id="@+id/ibtAddAcabado"
                        android:layout_width="40dip"
                        android:layout_height="match_parent"
                        android:layout_marginLeft="10dp"
                        android:padding="0dp"
                        android:background="@android:color/white"
                        android:scaleType="fitCenter"
                        android:src="@drawable/note_add" />

                </LinearLayout>

                <!-- Color Primario y Color Secundario -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:layout_weight="1">

                        <TextView
                            android:layout_width="150sp"
                            android:layout_height="match_parent"
                            android:text="Color Primario :"
                            android:textStyle="bold"
                            android:textColor="#1565C0"
                            android:textSize="13sp"
                            android:gravity="right"/>

                        <EditText
                            android:id="@+id/etColor1"
                            android:layout_width="70dip"
                            android:layout_height="wrap_content"
                            android:singleLine="true"
                            android:gravity="center_horizontal|center_vertical"
                            android:text="001"
                            android:textSize="18dp"
                            android:background="@drawable/rounded_edit_text"/>

                        <Button
                            android:id="@+id/btnColor1"
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:gravity="center_horizontal|center_vertical"
                            android:padding="0dp"
                            android:text="..."
                            android:textSize="18dp" />

                        <TextView
                            android:id="@+id/tvDescColor1"
                            android:layout_width="140dp"
                            android:layout_height="match_parent"
                            android:text="NEGRO"
                            android:gravity="center_vertical|left"
                            android:textSize="18dp"
                            android:textColor="@android:color/holo_red_dark"/>

                        <ImageButton
                            android:id="@+id/ibtAddColor1"
                            android:layout_width="40dip"
                            android:layout_height="match_parent"
                            android:layout_gravity="right|center_vertical"
                            android:padding="0dp"
                            android:background="@android:color/white"
                            android:scaleType="fitCenter"
                            android:src="@drawable/note_add" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:layout_weight="1">

                        <TextView
                            android:layout_width="150sp"
                            android:layout_height="match_parent"
                            android:text="Color Secund. :"
                            android:textStyle="bold"
                            android:textColor="#1565C0"
                            android:textSize="13sp"
                            android:gravity="right"/>

                        <EditText
                            android:id="@+id/etColor2"
                            android:layout_width="60dp"
                            android:layout_height="wrap_content"
                            android:singleLine="true"
                            android:gravity="center_horizontal|center_vertical"
                            android:text="001"
                            android:textSize="18dp"
                            android:background="@drawable/rounded_edit_text"/>

                        <Button
                            android:id="@+id/btnColor2"
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:gravity="center_horizontal|center_vertical"
                            android:padding="0dp"
                            android:text="..."
                            android:textSize="18dp" />

                        <TextView
                            android:id="@+id/tvDescColor2"
                            android:layout_width="130dp"
                            android:layout_height="match_parent"
                            android:text="NEGRO"
                            android:gravity="center_vertical|left"
                            android:textSize="18dp"
                            android:textColor="@android:color/holo_red_dark"/>

                        <ImageButton
                            android:id="@+id/ibtAddColor2"
                            android:layout_width="40dip"
                            android:layout_height="match_parent"
                            android:layout_gravity="right|center_vertical"
                            android:padding="0dp"
                            android:background="@android:color/white"
                            android:scaleType="fitCenter"
                            android:src="@drawable/note_add" />

                    </LinearLayout>

                </LinearLayout>

                <!-- Taco y Unidad -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:layout_weight="1">

                        <TextView
                            android:layout_width="150sp"
                            android:layout_height="match_parent"
                            android:text="Taco :"
                            android:textStyle="bold"
                            android:textColor="#1565C0"
                            android:textSize="13sp"
                            android:gravity="right"/>

                        <EditText
                            android:id="@+id/etTaco"
                            android:layout_width="70dip"
                            android:layout_height="wrap_content"
                            android:singleLine="true"
                            android:gravity="center_horizontal|center_vertical"
                            android:text="T9"
                            android:textSize="18dp"
                            android:background="@drawable/rounded_edit_text"/>

                        <Button
                            android:id="@+id/btnTaco"
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:gravity="center_horizontal|center_vertical"
                            android:padding="0dp"
                            android:text="..."
                            android:textSize="18dp" />

                        <TextView
                            android:id="@+id/tvDescTaco"
                            android:layout_width="150dp"
                            android:layout_height="match_parent"
                            android:text="TACO 9"
                            android:gravity="center_vertical|left"
                            android:textSize="18dp"
                            android:textColor="@android:color/holo_red_dark"/>

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:layout_weight="1">

                        <TextView
                            android:layout_width="150sp"
                            android:layout_height="match_parent"
                            android:text="Unidad :"
                            android:textStyle="bold"
                            android:textColor="#1565C0"
                            android:textSize="13sp"
                            android:gravity="right"/>

                        <EditText
                            android:id="@+id/etUnidad"
                            android:layout_width="60dp"
                            android:layout_height="wrap_content"
                            android:singleLine="true"
                            android:gravity="center_horizontal|center_vertical"
                            android:text="PAR"
                            android:textSize="18dp"
                            android:background="@drawable/rounded_edit_text"/>

                        <Button
                            android:id="@+id/btnUnidad"
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:gravity="center_horizontal|center_vertical"
                            android:padding="0dp"
                            android:text="..."
                            android:textSize="18dp" />

                        <TextView
                            android:id="@+id/tvDescUnidad"
                            android:layout_width="130dp"
                            android:layout_height="match_parent"
                            android:text="PARES"
                            android:gravity="center_vertical|left"
                            android:textSize="18dp"
                            android:textColor="@android:color/holo_red_dark"/>

                    </LinearLayout>

                </LinearLayout>

                <!-- Clase Articulo -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="150sp"
                        android:layout_height="match_parent"
                        android:text="Clase Articulo :"
                        android:textStyle="bold"
                        android:textColor="#1565C0"
                        android:textSize="13sp"
                        android:gravity="right"/>

                    <EditText
                        android:id="@+id/etClase"
                        android:layout_width="70dip"
                        android:layout_height="wrap_content"
                        android:singleLine="true"
                        android:paddingRight="10dip"
                        android:paddingLeft="10dip"
                        android:gravity="center_horizontal|center_vertical"
                        android:text="01"
                        android:textSize="18dp"
                        android:background="@drawable/rounded_edit_text"/>

                    <Button
                        android:id="@+id/btnClase"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:gravity="center_horizontal|center_vertical"
                        android:padding="0dp"
                        android:text="..."
                        android:textSize="18dp" />

                    <TextView
                        android:id="@+id/tvDescClase"
                        android:layout_width="400dp"
                        android:layout_height="match_parent"
                        android:text="MERCADERÍAS"
                        android:layout_marginRight="10dip"
                        android:layout_marginLeft="10dip"
                        android:gravity="center_vertical|left"
                        android:textSize="18dp"
                        android:textColor="@android:color/holo_red_dark"/>

                </LinearLayout>

            </LinearLayout>

            <!-- Intervalo e Incremento / Procesar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="45dp"
                android:orientation="horizontal"
                android:gravity="left|center_vertical">

                <TextView
                    android:layout_width="150dp"
                    android:layout_height="match_parent"
                    android:text="Intervalo :"
                    android:gravity="right|center_vertical"
                    android:id="@+id/textView01"
                    android:textSize="18dp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etTallaMin"
                    android:layout_width="70dp"
                    android:layout_height="wrap_content"
                    android:singleLine="true"
                    android:paddingRight="10dip"
                    android:paddingLeft="10dip"
                    android:layout_marginRight="10dp"
                    android:gravity="right|center_vertical"
                    android:inputType="number"
                    android:text="1"
                    android:textSize="18dip"
                    android:background="@drawable/rounded_edit_text"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:text="AL"
                    android:gravity="center_horizontal|center_vertical"
                    android:paddingLeft="3dp"
                    android:paddingRight="3dp"
                    android:textSize="18dp"
                    android:id="@+id/tvTotalRegistros" />

                <EditText
                    android:id="@+id/etTallaMax"
                    android:layout_width="86dp"
                    android:layout_height="wrap_content"
                    android:singleLine="true"
                    android:paddingRight="10dip"
                    android:paddingLeft="10dip"
                    android:layout_marginLeft="5dp"
                    android:layout_marginRight="5dp"
                    android:gravity="right|center_vertical"
                    android:text="100"
                    android:inputType="number"
                    android:textSize="18dip"
                    android:background="@drawable/rounded_edit_text"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:text="Incremento :"
                    android:textSize="18dp"
                    android:gravity="center_horizontal|center_vertical"
                    android:layout_marginLeft="5dp"
                    android:layout_marginRight="5dp"/>

                <EditText
                    android:id="@+id/etIncremento"
                    android:layout_width="50dp"
                    android:layout_height="wrap_content"
                    android:singleLine="true"
                    android:paddingRight="10dip"
                    android:paddingLeft="10dip"
                    android:layout_marginLeft="5dp"
                    android:layout_marginRight="10dp"
                    android:gravity="right|center_vertical"
                    android:text="1"
                    android:inputType="number"
                    android:textSize="18dip"
                    android:background="@drawable/rounded_edit_text"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:text="Precio\nCompra:"
                    android:textSize="18dp"
                    android:gravity="center_horizontal|center_vertical"
                    android:paddingLeft="3dp"
                    android:paddingRight="3dp"/>

                <EditText
                    android:id="@+id/etPrecioCompra"
                    android:layout_width="100dp"
                    android:layout_height="wrap_content"
                    android:singleLine="true"
                    android:paddingRight="10dip"
                    android:paddingLeft="10dip"
                    android:layout_marginLeft="10dp"
                    android:layout_marginRight="10dp"
                    android:gravity="right|center_vertical"
                    android:text="100.00"
                    android:inputType="numberDecimal"
                    android:textSize="18dip"
                    android:background="@drawable/rounded_edit_text"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:text="Precio\nVenta:"
                    android:textSize="18dp"
                    android:gravity="center_horizontal|center_vertical"
                    android:paddingLeft="3dp"
                    android:paddingRight="3dp"/>

                <EditText
                    android:id="@+id/etPrecioVenta"
                    android:layout_width="100dp"
                    android:layout_height="wrap_content"
                    android:singleLine="true"
                    android:paddingRight="10dip"
                    android:paddingLeft="10dip"
                    android:layout_marginLeft="10dp"
                    android:layout_marginRight="10dp"
                    android:gravity="right|center_vertical"
                    android:text="100.00"
                    android:inputType="numberDecimal"
                    android:textSize="18dip"
                    android:background="@drawable/rounded_edit_text"/>

            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/llBotones"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical|center_horizontal"
            android:orientation="vertical"
            android:padding="12dp">

            <Button
                android:id="@+id/btnAceptar"
                style="@style/PedidoButton.Success"
                android:layout_width="120dp"
                android:layout_marginBottom="6dp"
                android:text="Aceptar" />

            <Button
                android:id="@+id/btnCerrar"
                style="@style/PedidoButton.Muted"
                android:layout_width="120dp"
                android:layout_marginBottom="6dp"
                android:text="Cancelar" />

            <Button
                android:id="@+id/btnTransferir"
                style="@style/PedidoButton.Secondary"
                android:layout_width="120dp"
                android:layout_marginBottom="6dp"
                android:enabled="false"
                android:text="Transferir" />

            <Button
                android:id="@+id/btnFinalizar"
                style="@style/PedidoButton.Primary"
                android:layout_width="120dp"
                android:layout_marginBottom="6dp"
                android:enabled="false"
                android:text="Finalizar" />

            <Button
                android:id="@+id/btnProcesar"
                style="@style/PedidoButton.Primary"
                android:layout_width="120dp"
                android:layout_marginBottom="6dp"
                android:layout_marginEnd="0dp"
                android:text="Procesar" />

            <ImageView
                android:id="@+id/ivImagen"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="fitCenter"
                android:padding="0dp"
                android:src="@drawable/noimagen" />
        </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#eccd6a"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#1976D2"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tabla de Ingreso Resumido"
                android:textColor="@android:color/white"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@android:color/darker_gray"
            android:scrollbars="vertical|horizontal">

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <TableLayout
                    android:id="@+id/tblIngresoResumido"
                    android:stretchColumns="1"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_weight="1">

                </TableLayout>

            </HorizontalScrollView>
        </ScrollView>

    </LinearLayout>




</LinearLayout>