<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#1976D2"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Servidor remoto"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Añada un servidor remoto de webservices"
            android:textColor="#E3F2FD"
            android:textSize="12sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/lblNameServer"
            android:textColor="#1565C0"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilNameServer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:hintEnabled="false">

            <EditText
                android:id="@+id/etNameServer"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:inputType="textCapCharacters"
                android:background="@drawable/rounded_edit_text"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:gravity="center_vertical|start"
                android:textSize="16sp"
                android:textColor="#37474F"
                android:hint="@string/lblNameServer"
                android:textColorHint="#90A4AE" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/lblHostIp"
            android:textColor="#1565C0"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilHostIP"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:hintEnabled="false">

            <EditText
                android:id="@+id/etHostIp"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:inputType="text"
                android:background="@drawable/rounded_edit_text"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:gravity="center_vertical|start"
                android:textSize="16sp"
                android:textColor="#37474F"
                android:hint="@string/lblHostIp"
                android:textColorHint="#90A4AE" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/lblPort"
            android:textColor="#1565C0"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilPort"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:hintEnabled="false">

            <EditText
                android:id="@+id/etPort"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:inputType="number"
                android:digits="0123456789"
                android:background="@drawable/rounded_edit_text"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:gravity="center_vertical|start"
                android:textSize="16sp"
                android:textColor="#37474F"
                android:hint="@string/lblPort"
                android:textColorHint="#90A4AE" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/lblProtocolo"
            android:textColor="#1565C0"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:background="@drawable/background_border_spinner"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <Spinner
                android:id="@+id/spProtocolo"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_centerVertical="true"
                android:background="@android:color/transparent"
                android:paddingStart="8dp"
                android:spinnerMode="dropdown"
                android:prompt="@string/lblProtocolo" />

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:layout_marginEnd="6dp"
                android:src="@drawable/g0c8m"
                android:contentDescription="@null" />
        </RelativeLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@android:color/white"
            android:padding="10dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/lblServerDefault"
                android:textColor="#37474F"
                android:textSize="13sp" />

            <CheckBox
                android:id="@+id/chkFlagDefault"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/llBottomBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end"
        android:padding="12dp"
        android:background="@android:color/white">

        <Button
            android:id="@+id/btnCancelar"
            style="@style/PedidoButton.Muted"
            android:text="@string/btn_Cancelar" />

        <Button
            android:id="@+id/btnAceptar"
            style="@style/PedidoButton.Success"
            android:layout_marginEnd="0dp"
            android:text="@string/btn_Aceptar" />
    </LinearLayout>
</LinearLayout>
