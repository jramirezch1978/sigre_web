<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical">

    <TextView
        android:id="@+id/tvText4"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="Datos para el despacho"
        android:layout_marginBottom="10dp"
        app:layout_constraintTop_toTopOf="parent"
        android:textSize="25dp"
        android:background="@android:color/holo_blue_dark"
        android:textColor="@android:color/white"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0px"
        app:layout_constraintTop_toBottomOf="@id/tvText4"
        app:layout_constraintBottom_toBottomOf="parent"
        android:scrollbars="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvOrdenVenta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Orden de Venta"
                android:gravity="center"
                android:textSize="25dp"/>

            <Spinner
                android:id="@+id/spOrdenVenta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:spinnerMode="dialog"
                android:textSize="20sp"
                android:layout_marginBottom="10dp"/>

            <TextView
                android:id="@+id/tvAlmacen"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Almacen Despacho"
                android:gravity="center"
                android:textSize="25dp"/>

            <Spinner
                android:id="@+id/spAlmacen"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:spinnerMode="dropdown"
                android:textSize="20sp"
                android:layout_marginBottom="10dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Articulo Despacho"
                android:gravity="center"
                android:textSize="25dp"/>

            <Spinner
                android:id="@+id/spAMP"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:spinnerMode="dropdown"
                android:textSize="20sp"
                android:layout_marginBottom="10dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginRight="10sp"
                    android:textColor="#343434"
                    android:textSize="20dp"
                    android:text="Total Und1 :" />

                <TextView
                    android:id="@+id/tvSaldoUnd"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#343434"
                    android:textSize="20sp"
                    android:text="0"
                    android:layout_marginRight="5dp"/>

                <TextView
                    android:id="@+id/tvUnd"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#343434"
                    android:textSize="20sp"
                    android:text="KGR"
                    android:layout_marginRight="5dp"/>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginRight="10sp"
                    android:textColor="#343434"
                    android:textSize="20dp"
                    android:text="Total Und2 :" />

                <TextView
                    android:id="@+id/tvSaldoUnd2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#343434"
                    android:textSize="20sp"
                    android:text="0"
                    android:layout_marginRight="5dp"/>

                <TextView
                    android:id="@+id/tvUnd2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#343434"
                    android:textSize="20sp"
                    android:text="KGR"
                    android:layout_marginRight="5dp"/>

            </LinearLayout>

        </LinearLayout>





    </ScrollView>


</androidx.constraintlayout.widget.ConstraintLayout>