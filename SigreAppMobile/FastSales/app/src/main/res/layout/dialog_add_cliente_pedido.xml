<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#1976D2"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Indique el cliente"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Ubigeo, cliente y dirección de entrega"
            android:textColor="#E3F2FD"
            android:textSize="12sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/llBody"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Ubigeo"
                    android:textColor="#1565C0"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:id="@+id/tvUbigeo"
                        android:layout_width="96dp"
                        android:layout_height="36dp"
                        android:singleLine="true"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:gravity="center_vertical|start"
                        android:text="201010"
                        android:textSize="14sp"
                        android:textColor="#37474F"
                        android:background="@drawable/rounded_edit_text" />

                    <Button
                        android:id="@+id/btnUbigeo"
                        style="@style/PedidoButton.Secondary"
                        android:layout_width="40dp"
                        android:layout_height="36dp"
                        android:layout_marginStart="8dp"
                        android:minWidth="40dp"
                        android:padding="0dp"
                        android:text="…"
                        android:textSize="16sp" />

                    <TextView
                        android:id="@+id/tvDescUbigeo"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:text="PIURA - PIURA - PIURA"
                        android:gravity="center_vertical|start"
                        android:textSize="13sp"
                        android:textColor="#546E7A"
                        android:maxLines="2"
                        android:ellipsize="end" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Cliente"
                    android:textColor="#1565C0"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:id="@+id/tvCliente"
                        android:layout_width="96dp"
                        android:layout_height="36dp"
                        android:singleLine="true"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:gravity="center_vertical|start"
                        android:text="E0000001"
                        android:textSize="14sp"
                        android:textColor="#37474F"
                        android:background="@drawable/rounded_edit_text" />

                    <Button
                        android:id="@+id/btnCliente"
                        style="@style/PedidoButton.Secondary"
                        android:layout_width="40dp"
                        android:layout_height="36dp"
                        android:layout_marginStart="8dp"
                        android:minWidth="40dp"
                        android:padding="0dp"
                        android:text="…"
                        android:textSize="16sp" />

                    <TextView
                        android:id="@+id/tvRazonSocial"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:text="LENOX"
                        android:gravity="center_vertical|start"
                        android:textSize="13sp"
                        android:textColor="#546E7A"
                        android:maxLines="2"
                        android:ellipsize="end" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Dirección"
                    android:textColor="#1565C0"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:id="@+id/tvItemDireccion"
                        android:layout_width="96dp"
                        android:layout_height="36dp"
                        android:singleLine="true"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:gravity="center_vertical|start"
                        android:text="1"
                        android:textSize="14sp"
                        android:textColor="#37474F"
                        android:background="@drawable/rounded_edit_text" />

                    <Button
                        android:id="@+id/btnDireccion"
                        style="@style/PedidoButton.Secondary"
                        android:layout_width="40dp"
                        android:layout_height="36dp"
                        android:layout_marginStart="8dp"
                        android:minWidth="40dp"
                        android:padding="0dp"
                        android:text="…"
                        android:textSize="16sp" />

                    <TextView
                        android:id="@+id/tvDireccion"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:text="Urb San Felipe Mz D Lote 20 Piura - Piura - Piura"
                        android:gravity="center_vertical|start"
                        android:textSize="13sp"
                        android:textColor="#546E7A"
                        android:maxLines="3"
                        android:ellipsize="end" />
                </LinearLayout>

                <Button
                    android:id="@+id/btnAddDireccion"
                    style="@style/PedidoButton.Primary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="0dp"
                    android:layout_marginEnd="0dp"
                    android:text="Añadir dirección"
                    android:visibility="invisible" />
            </LinearLayout>
        </ScrollView>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/llBotones"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end"
        android:padding="12dp"
        android:background="@android:color/white">

        <Button
            android:id="@+id/btnCerrar"
            style="@style/PedidoButton.Muted"
            android:text="Cerrar" />

        <Button
            android:id="@+id/btnAceptar"
            style="@style/PedidoButton.Success"
            android:layout_marginEnd="0dp"
            android:text="Aceptar" />
    </LinearLayout>
</LinearLayout>
