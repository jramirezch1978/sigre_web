<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#F5F5F5"
    android:padding="0dp">

    <!-- Header del Dialog -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#1976D2"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⏱️ SELECCIONAR TIPO DE MOVIMIENTO"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:gravity="center"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Seleccione el tipo de marcación que desea registrar"
            android:textSize="13sp"
            android:textColor="#E3F2FD"
            android:gravity="center"
            android:fontFamily="sans-serif-light"/>
    </LinearLayout>

    <!-- ScrollView para los tipos de movimiento -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxHeight="500dp"
        android:scrollbars="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- TIPO 01: INGRESO A PLANTA -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cvTipo01"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="3dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="14dp"
                    android:gravity="center_vertical"
                    android:background="#E8F5E9">

                    <TextView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:text="🏭"
                        android:textSize="28sp"
                        android:gravity="center"
                        android:layout_marginEnd="12dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="01 - INGRESO A PLANTA"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#2E7D32"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Registrar entrada a la planta"
                            android:textSize="12sp"
                            android:textColor="#66BB6A"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_menu_send"
                        android:tint="#4CAF50"
                        android:contentDescription="Seleccionar"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- TIPO 02: SALIDA DE PLANTA -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cvTipo02"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="3dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="14dp"
                    android:gravity="center_vertical"
                    android:background="#FFEBEE">

                    <TextView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:text="🚪"
                        android:textSize="28sp"
                        android:gravity="center"
                        android:layout_marginEnd="12dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="02 - SALIDA DE PLANTA"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#C62828"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Registrar salida de la planta"
                            android:textSize="12sp"
                            android:textColor="#EF5350"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_menu_send"
                        android:tint="#F44336"
                        android:contentDescription="Seleccionar"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- TIPO 03: SALIDA A ALMORZAR -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cvTipo03"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="3dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="14dp"
                    android:gravity="center_vertical"
                    android:background="#FFF3E0">

                    <TextView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:text="🍽️"
                        android:textSize="28sp"
                        android:gravity="center"
                        android:layout_marginEnd="12dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="03 - SALIDA A ALMORZAR"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#EF6C00"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Salir a almorzar"
                            android:textSize="12sp"
                            android:textColor="#FF9800"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_menu_send"
                        android:tint="#FF9800"
                        android:contentDescription="Seleccionar"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- TIPO 04: REGRESO DE ALMORZAR -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cvTipo04"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="3dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="14dp"
                    android:gravity="center_vertical"
                    android:background="#FFF8E1">

                    <TextView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:text="↩️"
                        android:textSize="28sp"
                        android:gravity="center"
                        android:layout_marginEnd="12dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="04 - REGRESO DE ALMORZAR"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#F57F17"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Regresar de almorzar"
                            android:textSize="12sp"
                            android:textColor="#FBC02D"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_menu_send"
                        android:tint="#FBC02D"
                        android:contentDescription="Seleccionar"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- TIPO 05: SALIDA DE COMISIÓN -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cvTipo05"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="3dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="14dp"
                    android:gravity="center_vertical"
                    android:background="#E1F5FE">

                    <TextView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:text="🚗"
                        android:textSize="28sp"
                        android:gravity="center"
                        android:layout_marginEnd="12dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="05 - SALIDA DE COMISIÓN"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#0277BD"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Salir en comisión de servicio"
                            android:textSize="12sp"
                            android:textColor="#03A9F4"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_menu_send"
                        android:tint="#03A9F4"
                        android:contentDescription="Seleccionar"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- TIPO 06: RETORNO DE COMISIÓN -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cvTipo06"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="3dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="14dp"
                    android:gravity="center_vertical"
                    android:background="#E0F2F1">

                    <TextView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:text="🔙"
                        android:textSize="28sp"
                        android:gravity="center"
                        android:layout_marginEnd="12dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="06 - RETORNO DE COMISIÓN"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#00695C"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Regresar de comisión"
                            android:textSize="12sp"
                            android:textColor="#009688"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_menu_send"
                        android:tint="#009688"
                        android:contentDescription="Seleccionar"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- TIPO 07: INGRESO A PRODUCCIÓN -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cvTipo07"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="3dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="14dp"
                    android:gravity="center_vertical"
                    android:background="#F3E5F5">

                    <TextView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:text="⚙️"
                        android:textSize="28sp"
                        android:gravity="center"
                        android:layout_marginEnd="12dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="07 - INGRESO A PRODUCCIÓN"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#6A1B9A"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Ingresar al área de producción"
                            android:textSize="12sp"
                            android:textColor="#9C27B0"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_menu_send"
                        android:tint="#9C27B0"
                        android:contentDescription="Seleccionar"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- TIPO 08: SALIDA DE PRODUCCIÓN -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cvTipo08"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="3dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="14dp"
                    android:gravity="center_vertical"
                    android:background="#FCE4EC">

                    <TextView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:text="🔧"
                        android:textSize="28sp"
                        android:gravity="center"
                        android:layout_marginEnd="12dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="08 - SALIDA DE PRODUCCIÓN"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#AD1457"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Salir del área de producción"
                            android:textSize="12sp"
                            android:textColor="#E91E63"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_menu_send"
                        android:tint="#E91E63"
                        android:contentDescription="Seleccionar"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- TIPO 09: SALIDA A CENAR -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cvTipo09"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="3dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="14dp"
                    android:gravity="center_vertical"
                    android:background="#EDE7F6">

                    <TextView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:text="🌙"
                        android:textSize="28sp"
                        android:gravity="center"
                        android:layout_marginEnd="12dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="09 - SALIDA A CENAR"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#4527A0"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Salir a cenar"
                            android:textSize="12sp"
                            android:textColor="#673AB7"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_menu_send"
                        android:tint="#673AB7"
                        android:contentDescription="Seleccionar"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- TIPO 10: REGRESO DE CENAR -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cvTipo10"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="3dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="14dp"
                    android:gravity="center_vertical"
                    android:background="#E8EAF6">

                    <TextView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:text="⭐"
                        android:textSize="28sp"
                        android:gravity="center"
                        android:layout_marginEnd="12dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="10 - REGRESO DE CENAR"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#283593"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Regresar de cenar"
                            android:textSize="12sp"
                            android:textColor="#3F51B5"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_menu_send"
                        android:tint="#3F51B5"
                        android:contentDescription="Seleccionar"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <!-- Botón Cancelar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/white"
        android:gravity="end"
        android:orientation="horizontal"
        android:padding="12dp">

        <Button
            android:id="@+id/btnCancelar"
            style="@style/PedidoButton.Muted"
            android:layout_marginEnd="0dp"
            android:text="Cancelar" />
    </LinearLayout>

</LinearLayout>
