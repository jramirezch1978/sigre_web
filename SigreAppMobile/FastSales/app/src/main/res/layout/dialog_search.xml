<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#1976D2"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ventana de búsqueda"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Ingrese criterios y seleccione un registro"
            android:textColor="#E3F2FD"
            android:textSize="12sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Búsqueda"
            android:textColor="#1565C0"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginEnd="10dp" />

        <EditText
            android:id="@+id/etBusqueda"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:singleLine="true"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:gravity="center_vertical|start"
            android:hint="Ingrese la cadena de búsqueda"
            android:text=""
            android:textSize="16sp"
            android:textColorHint="#90A4AE"
            android:background="@drawable/rounded_edit_text"
            android:inputType="text" />

        <ImageButton
            android:id="@+id/ibtBuscar"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginStart="8dp"
            android:src="@drawable/icono_lupa"
            android:background="@drawable/btn_pedido_primary"
            android:padding="8dp"
            android:scaleType="fitCenter"
            android:contentDescription="Buscar" />
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@android:color/white"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="8dp">

        <ListView
            android:id="@+id/lvListadoItems"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scrollbars="vertical"
            android:divider="#E0E0E0"
            android:dividerHeight="1dp"
            android:padding="4dp" />

        <TextView
            android:id="@+id/tvListadoVacio"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:padding="16dp"
            android:text="Sin resultados"
            android:textColor="#78909C"
            android:textSize="14sp"
            android:visibility="gone" />
    </FrameLayout>

    <LinearLayout
        android:id="@+id/llBotones"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end"
        android:padding="12dp"
        android:background="@android:color/white">

        <Button
            android:id="@+id/btnCerrar"
            style="@style/PedidoButton.Muted"
            android:layout_marginEnd="0dp"
            android:text="Cerrar" />
    </LinearLayout>
</LinearLayout>
