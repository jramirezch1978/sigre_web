<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <include layout="@layout/include_rrhh_empresa_banner" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    style="@style/RrhhCardHeaderBar"
                    android:text="📅 DATOS DEL JORNAL" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        style="@style/RrhhFieldLabel"
                        android:layout_marginTop="0dp"
                        android:text="FECHA" />

                    <EditText
                        android:id="@+id/etFecha"
                        style="@style/RrhhFieldInput"
                        android:hint="DD/MM/YYYY" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="6dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                style="@style/RrhhFieldLabel"
                                android:text="HORA INICIO" />

                            <EditText
                                android:id="@+id/etHoraInicio"
                                style="@style/RrhhFieldInput"
                                android:hint="DD/MM/YYYY HH:MI" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                style="@style/RrhhFieldLabel"
                                android:text="HORA FIN" />

                            <EditText
                                android:id="@+id/etHoraFin"
                                style="@style/RrhhFieldInput"
                                android:hint="DD/MM/YYYY HH:MI" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    style="@style/RrhhCardHeaderBar"
                    android:text="👥 CUADRILLA Y CATÁLOGOS" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        style="@style/RrhhFieldLabel"
                        android:layout_marginTop="0dp"
                        android:text="BUSCAR CUADRILLA" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_rrhh_search_row"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="6dp">

                        <EditText
                            android:id="@+id/etFiltroCuadrilla"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:background="@null"
                            android:hint="Código o descripción"
                            android:minHeight="44dp"
                            android:paddingStart="8dp"
                            android:paddingEnd="8dp"
                            android:textSize="16sp" />

                        <Button
                            android:id="@+id/btnBuscarCuadrilla"
                            style="@style/RrhhButtonSearch"
                            android:text="BUSCAR" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <EditText
                            android:id="@+id/etFiltroEspecie"
                            style="@style/RrhhFieldInput"
                            android:layout_width="0dp"
                            android:layout_marginEnd="6dp"
                            android:layout_weight="1"
                            android:hint="Especie" />

                        <EditText
                            android:id="@+id/etFiltroPresentacion"
                            style="@style/RrhhFieldInput"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:hint="Pres." />
                    </LinearLayout>

                    <EditText
                        android:id="@+id/etFiltroTarea"
                        style="@style/RrhhFieldInput"
                        android:hint="Tarea filtro" />

                    <TextView
                        style="@style/RrhhFieldLabel"
                        android:text="CUADRILLA / OT ADM." />

                    <EditText
                        android:id="@+id/etCuadrilla"
                        style="@style/RrhhFieldReadOnly"
                        android:enabled="false"
                        android:hint="Cuadrilla" />

                    <TextView
                        android:id="@+id/tvInfoCuadrilla"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"
                        android:textColor="#546E7A"
                        android:textSize="13sp"
                        android:text="" />

                    <EditText
                        android:id="@+id/etOtAdm"
                        style="@style/RrhhFieldReadOnly"
                        android:enabled="false"
                        android:hint="OT Administrativa" />

                    <TextView
                        style="@style/RrhhFieldLabel"
                        android:text="LABOR" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <EditText
                            android:id="@+id/etLabor"
                            style="@style/RrhhFieldReadOnly"
                            android:layout_width="0dp"
                            android:layout_marginEnd="6dp"
                            android:layout_weight="1"
                            android:enabled="false"
                            android:hint="Código labor" />

                        <Button
                            android:id="@+id/btnBuscarLabor"
                            style="@style/RrhhButtonSearch"
                            android:text="LABOR" />
                    </LinearLayout>

                    <TextView
                        style="@style/RrhhFieldLabel"
                        android:text="OPERACIÓN" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <EditText
                            android:id="@+id/etOperSec"
                            style="@style/RrhhFieldReadOnly"
                            android:layout_width="0dp"
                            android:layout_marginEnd="6dp"
                            android:layout_weight="1"
                            android:enabled="false"
                            android:hint="oper_sec" />

                        <Button
                            android:id="@+id/btnBuscarOper"
                            style="@style/RrhhButtonSearch"
                            android:text="OPER." />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="8dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    style="@style/RrhhCardHeaderBar"
                    android:text="⏱ HORAS DIURNAS / NOCTURNAS" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <EditText
                        android:id="@+id/etHrsNormales"
                        style="@style/RrhhFieldInput"
                        android:hint="Horas normales"
                        android:inputType="numberDecimal" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <EditText
                            android:id="@+id/etHrsExtra25"
                            style="@style/RrhhFieldInput"
                            android:layout_width="0dp"
                            android:layout_marginEnd="6dp"
                            android:layout_weight="1"
                            android:hint="Extra 25%"
                            android:inputType="numberDecimal" />

                        <EditText
                            android:id="@+id/etHrsExtra35"
                            style="@style/RrhhFieldInput"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:hint="Extra 35%"
                            android:inputType="numberDecimal" />
                    </LinearLayout>

                    <EditText
                        android:id="@+id/etHrsExtra100"
                        style="@style/RrhhFieldInput"
                        android:hint="Extra 100%"
                        android:inputType="numberDecimal" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <EditText
                            android:id="@+id/etHrsNocNormal"
                            style="@style/RrhhFieldInput"
                            android:layout_width="0dp"
                            android:layout_marginEnd="6dp"
                            android:layout_weight="1"
                            android:hint="Noc. normal"
                            android:inputType="numberDecimal" />

                        <EditText
                            android:id="@+id/etHrsNocExtra25"
                            style="@style/RrhhFieldInput"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:hint="Noc. extra 25%"
                            android:inputType="numberDecimal" />
                    </LinearLayout>

                    <EditText
                        android:id="@+id/etHrsNocExtra35"
                        style="@style/RrhhFieldInput"
                        android:hint="Noc. extra 35%"
                        android:inputType="numberDecimal" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>
</merge>
