<?xml version="1.0" encoding="utf-8"?>
<!-- Componente reutilizable: lectura wedge PDA + opción cámara (Tomapedidos, Inventario, etc.) -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#1976D2"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp">

        <TextView
            android:id="@+id/tvScanTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Lectura de código"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvScanSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Escanee con el PDA o use la cámara"
            android:textColor="#E3F2FD"
            android:textSize="12sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvScanLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Código / SKU / QR"
            android:textColor="#1565C0"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/etCodigo"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:inputType="text"
            android:imeOptions="actionDone"
            android:gravity="center_vertical|start"
            android:background="@drawable/rounded_edit_text"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:textSize="18sp"
            android:hint="Apunte el lector aquí…"
            android:textColorHint="#90A4AE"
            android:importantForAutofill="no" />

        <TextView
            android:id="@+id/tvScanHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="En PDA el código se escribe solo al escanear. Pulse Enter o Aceptar."
            android:textColor="#78909C"
            android:textSize="11sp" />

        <Button
            android:id="@+id/btnCamara"
            style="@style/PedidoButton.Primary"
            android:layout_width="match_parent"
            android:layout_marginTop="14dp"
            android:layout_marginEnd="0dp"
            android:text="Escanear con cámara" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end"
        android:padding="12dp"
        android:background="@android:color/white">

        <Button
            android:id="@+id/btnCancelar"
            style="@style/PedidoButton.Muted"
            android:text="Cancelar" />

        <Button
            android:id="@+id/btnAceptar"
            style="@style/PedidoButton.Success"
            android:layout_marginEnd="0dp"
            android:text="Aceptar" />
    </LinearLayout>
</LinearLayout>
