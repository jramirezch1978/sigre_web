<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5"
    android:fitsSystemWindows="true">

    <!-- Un solo encabezado: logo + EMPRESA / usuario (estilo banner) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:background="#E3F2FD"
        android:elevation="2dp">

        <ImageView
            android:id="@+id/ivLogoEmpresaRrhh"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginEnd="10dp"
            android:scaleType="fitCenter"
            android:background="@android:color/white"
            android:padding="3dp"
            android:src="@drawable/icono_empresa"
            android:contentDescription="Logo empresa" />

        <TextView
            android:id="@+id/tvNombreEmpresaRrhh"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="EMPRESA"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#1976D2"
            android:maxLines="2"
            android:ellipsize="end"
            android:lineSpacingExtra="2dp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="2dp"
        android:paddingEnd="4dp"
        android:background="#FFFFFF">

        <ImageButton
            android:id="@+id/btnTabScrollLeft"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginStart="2dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Tabs anteriores"
            android:padding="6dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_tab_chevron_left" />

        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tabs"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            app:tabMode="scrollable"
            app:tabGravity="start"
            app:tabIndicatorColor="#1976D2"
            app:tabSelectedTextColor="#1976D2"
            app:tabTextColor="#757575" />

        <ImageButton
            android:id="@+id/btnTabScrollRight"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Tabs siguientes"
            android:padding="6dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_tab_chevron_right" />

        <Button
            android:id="@+id/btnAddTab"
            style="@style/PedidoButton.IconTab"
            android:layout_marginStart="2dp"
            android:background="@drawable/btn_pedido_success"
            android:text="+" />

        <Button
            android:id="@+id/btnCloseTab"
            style="@style/PedidoButton.IconTab"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="2dp"
            android:background="@drawable/btn_pedido_danger"
            android:text="×"
            android:textSize="16sp" />
    </LinearLayout>

    <androidx.viewpager.widget.ViewPager
        android:id="@+id/viewpager"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

</LinearLayout>
