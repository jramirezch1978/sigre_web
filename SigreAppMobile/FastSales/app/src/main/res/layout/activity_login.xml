<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/login_background"
    android:fitsSystemWindows="true">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="16dp">

            <!-- Card contenedor principal con sombra y bordes redondeados -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="8dp"
                app:cardMaxElevation="12dp"
                app:cardUseCompatPadding="true"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp">

                <!-- FrameLayout para permitir elementos flotantes -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@color/login_card_background"
                        android:padding="24dp">

                        <!-- Logo -->
                        <ImageView
                            android:id="@+id/ivLogo"
                            android:src="@drawable/sigre"
                            android:layout_width="match_parent"
                            android:layout_height="140dp"
                            android:layout_marginTop="16dp"
                            android:layout_marginBottom="8dp"
                            android:scaleType="fitCenter"
                            android:contentDescription="Logo SIGRE" />

                        <!-- Versión -->
                        <TextView
                            android:id="@+id/tvVersionName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="1.80.0"
                            android:gravity="end"
                            android:textSize="12sp"
                            android:textColor="@color/login_text_secondary"
                            android:layout_marginBottom="24dp"
                            android:fontFamily="sans-serif-medium" />

                        <!-- Título -->
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Iniciar Sesión"
                            android:textSize="24sp"
                            android:textColor="@color/login_text_primary"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:layout_marginBottom="24dp"
                            android:fontFamily="sans-serif" />

                        <!-- Campo Usuario -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilUsuario"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            app:boxBackgroundMode="outline"
                            app:boxCornerRadiusTopStart="8dp"
                            app:boxCornerRadiusTopEnd="8dp"
                            app:boxCornerRadiusBottomStart="8dp"
                            app:boxCornerRadiusBottomEnd="8dp"
                            app:boxStrokeColor="@color/login_primary"
                            app:hintTextColor="@color/login_primary"
                            app:startIconDrawable="@android:drawable/ic_menu_myplaces"
                            app:startIconTint="@color/login_primary">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etUsuario"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="text"
                                android:hint="Usuario"
                                android:textSize="16sp"
                                android:textColor="@color/login_text_primary"
                                android:textColorHint="@color/login_text_hint"
                                android:singleLine="true" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Campo Password -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilClave"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="24dp"
                            app:boxBackgroundMode="outline"
                            app:boxCornerRadiusTopStart="8dp"
                            app:boxCornerRadiusTopEnd="8dp"
                            app:boxCornerRadiusBottomStart="8dp"
                            app:boxCornerRadiusBottomEnd="8dp"
                            app:boxStrokeColor="@color/login_primary"
                            app:hintTextColor="@color/login_primary"
                            app:startIconDrawable="@android:drawable/ic_lock_lock"
                            app:startIconTint="@color/login_primary"
                            app:endIconMode="password_toggle"
                            app:endIconTint="@color/login_text_secondary">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etClave"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="textPassword"
                                android:hint="Contraseña"
                                android:textSize="16sp"
                                android:textColor="@color/login_text_primary"
                                android:textColorHint="@color/login_text_hint"
                                android:singleLine="true" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Sección Servidor -->
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Configuración de Conexión"
                            android:textSize="14sp"
                            android:textColor="@color/login_text_secondary"
                            android:textStyle="bold"
                            android:layout_marginBottom="12dp"
                            android:layout_marginTop="8dp" />

                        <!-- Servidor por defecto -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="12dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Servidor:"
                                android:textSize="13sp"
                                android:textColor="@color/login_text_primary"
                                android:gravity="start"
                                android:layout_marginEnd="8dp" />

                            <Button
                                android:id="@+id/btnServerDefault"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="2"
                                android:textSize="12sp"
                                android:textColor="@color/login_text_primary"
                                android:background="@drawable/login_button_config"
                                android:paddingStart="12dp"
                                android:paddingEnd="12dp"
                                android:paddingTop="10dp"
                                android:paddingBottom="10dp"
                                android:textAllCaps="false"
                                android:ellipsize="end"
                                android:maxLines="1" />

                            <ImageButton
                                android:id="@+id/btnRefrescar"
                                android:layout_width="44dp"
                                android:layout_height="44dp"
                                android:layout_marginStart="8dp"
                                android:background="@drawable/login_button_config"
                                android:src="@drawable/icon_reload"
                                android:scaleType="centerInside"
                                android:padding="8dp"
                                android:contentDescription="Refrescar" />

                        </LinearLayout>

                        <!-- Empresa seleccionada -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="20dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Empresa:"
                                android:textSize="13sp"
                                android:textColor="@color/login_text_primary"
                                android:gravity="start"
                                android:layout_marginEnd="8dp" />

                            <Button
                                android:id="@+id/btnEmpresaDefault"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="2"
                                android:textSize="12sp"
                                android:textColor="@color/login_text_primary"
                                android:background="@drawable/login_button_config"
                                android:paddingStart="12dp"
                                android:paddingEnd="12dp"
                                android:paddingTop="10dp"
                                android:paddingBottom="10dp"
                                android:textAllCaps="false"
                                android:ellipsize="end"
                                android:maxLines="1" />

                        </LinearLayout>

                        <!-- Mensaje de Error (oculto por defecto, se usa para errores generales) -->
                        <TextView
                            android:id="@+id/tvMensajeError"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textColor="@color/login_error"
                            android:textSize="13sp"
                            android:gravity="start"
                            android:visibility="gone"
                            android:layout_marginBottom="16dp"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:paddingTop="8dp"
                            android:paddingBottom="8dp"
                            android:background="#FFEBEE"
                            android:drawableStart="@android:drawable/ic_dialog_alert"
                            android:drawablePadding="8dp"
                            android:drawableTint="@color/login_error" />

                        <!-- Botones -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="8dp"
                            android:gravity="center">

                            <Button
                                android:id="@+id/btnLogin"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Ingresar"
                                android:textSize="16sp"
                                android:textColor="@color/login_button_text"
                                android:textStyle="bold"
                                android:background="@drawable/login_button_primary"
                                android:paddingTop="14dp"
                                android:paddingBottom="14dp"
                                android:layout_marginEnd="8dp"
                                android:textAllCaps="false"
                                android:onClick="Ingresar"
                                android:elevation="2dp" />

                            <Button
                                android:id="@+id/btnCancelar"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Salir"
                                android:textSize="16sp"
                                android:textColor="@color/login_primary"
                                android:textStyle="bold"
                                android:background="@drawable/login_button_secondary"
                                android:paddingTop="14dp"
                                android:paddingBottom="14dp"
                                android:layout_marginStart="8dp"
                                android:textAllCaps="false"
                                android:onClick="Salir" />

                        </LinearLayout>

                    </LinearLayout>

                    <!-- Badge de Conexión FLOTANTE (arriba a la derecha) -->
                    <LinearLayout
                        android:id="@+id/llBadgeConexion"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="top|end"
                        android:layout_marginTop="8dp"
                        android:layout_marginEnd="12dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/badge_connected_bg"
                        android:paddingStart="6dp"
                        android:paddingEnd="6dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"
                        android:elevation="6dp"
                        android:visibility="gone">

                        <ImageView
                            android:id="@+id/ivEstadoConexion"
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:src="@drawable/ic_wifi_connected"
                            android:layout_marginEnd="3dp"
                            android:contentDescription="Estado Conexión" />

                        <TextView
                            android:id="@+id/tvEstadoConexion"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Conectado"
                            android:textSize="9sp"
                            android:textStyle="bold"
                            android:textColor="#4CAF50" />

                    </LinearLayout>

                </FrameLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </ScrollView>

</LinearLayout>
