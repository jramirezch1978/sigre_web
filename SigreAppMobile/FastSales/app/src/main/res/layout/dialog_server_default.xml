<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#1976D2"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Servidor por defecto"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Configuración del servidor por defecto"
            android:textColor="#E3F2FD"
            android:textSize="12sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/lblNameServer"
            android:textColor="#1565C0"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <TextView
            android:id="@+id/tvNameServer"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:gravity="center_vertical|start"
            android:text="..."
            android:textSize="15sp"
            android:textColor="#37474F"
            android:background="@drawable/rounded_edit_text"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/lblHostIp"
            android:textColor="#1565C0"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <TextView
            android:id="@+id/tvHostIP"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:gravity="center_vertical|start"
            android:text="..."
            android:textSize="15sp"
            android:textColor="#37474F"
            android:background="@drawable/rounded_edit_text"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/lblPort"
            android:textColor="#1565C0"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <TextView
            android:id="@+id/tvPort"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:gravity="center_vertical|start"
            android:text="..."
            android:textSize="15sp"
            android:textColor="#37474F"
            android:background="@drawable/rounded_edit_text"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/lblProtocolo"
            android:textColor="#1565C0"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <TextView
            android:id="@+id/tvProtocolo"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:gravity="center_vertical|start"
            android:text="..."
            android:textSize="15sp"
            android:textColor="#37474F"
            android:background="@drawable/rounded_edit_text"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/lblServerDefault"
            android:textColor="#1565C0"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <TextView
            android:id="@+id/tvServerDefault"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:gravity="center_vertical|start"
            android:text="..."
            android:textSize="15sp"
            android:textColor="#37474F"
            android:background="@drawable/rounded_edit_text" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/llBottomBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end"
        android:padding="12dp"
        android:background="@android:color/white">

        <Button
            android:id="@+id/btnListado"
            style="@style/PedidoButton.Primary"
            android:text="@string/btn_Listado" />

        <Button
            android:id="@+id/btnCerrar"
            style="@style/PedidoButton.Muted"
            android:layout_marginEnd="0dp"
            android:text="@string/btn_Cerrar" />
    </LinearLayout>
</LinearLayout>
