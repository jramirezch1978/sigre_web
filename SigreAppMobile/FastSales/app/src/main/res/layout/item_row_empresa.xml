<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="5dip"
    android:orientation="horizontal"
    android:background="@android:color/white"
    android:descendantFocusability="blocksDescendants">

    <!--  ListRow Left sied Thumbnail image -->
    <LinearLayout
        android:id="@+id/thumbnail"
        android:layout_width="wrap_content"
        android:layout_height="60dip"
        android:gravity="center_horizontal|center_vertical">

        <ImageView
            android:layout_width="50dip"
            android:layout_height="50dip"
            android:id="@+id/ivImagen"
            android:layout_marginRight="5dip"
            android:layout_marginLeft="5dip"
            android:layout_centerVertical="true"
            android:src="@drawable/icono_empresa" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvRazonSocial"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ZAPATERIA CENTRAL"
            android:textColor="#040404"
            android:typeface="sans"
            android:textSize="16sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_weight="1"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvCodigo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#343434"
                android:textSize="12sp"
                android:layout_marginRight="10sp"
                android:text="SUCESION" />

            <TextView
                android:id="@+id/tvNroDocIdentidad"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#343434"
                android:textSize="12sp"
                android:text="6 - 10056450608" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_weight="1"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvAmbienteProd"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginRight="10sp"
                android:textColor="#343434"
                android:textSize="12sp"
                android:text="PRODUCTION (si)" />

            <TextView
                android:id="@+id/tvAmbienteTest"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#343434"
                android:textSize="12sp"
                android:text="TEST (No)" />

        </LinearLayout>


    </LinearLayout>

    <!--  ListRow Left sied Thumbnail image -->
    <LinearLayout
        android:id="@+id/llBotones"
        android:layout_width="wrap_content"
        android:layout_height="60dip"
        android:gravity="center_horizontal|center_vertical">


        <ImageView
            android:id="@+id/ivDefault"
            android:layout_width="50sp"
            android:layout_height="50sp"
            android:layout_marginRight="5dip"
            android:layout_marginLeft="5dip"
            android:src="@drawable/exito" />

        <Button
            android:id="@+id/btnDelete"
            android:layout_width="50sp"
            android:layout_height="50sp"
            android:layout_centerVertical="true"
            android:background="@drawable/delete"
            android:clickable="false"
            android:focusable="false"
            android:focusableInTouchMode="false"/>


    </LinearLayout>



</LinearLayout>