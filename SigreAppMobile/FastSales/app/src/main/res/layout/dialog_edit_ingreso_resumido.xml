<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#1976D2"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Edición de Registro"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Modifique cantidad y precios del artículo"
            android:textColor="#E3F2FD"
            android:textSize="12sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TableLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:shrinkColumns="1">

            <TableRow
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <TextView
                    android:layout_width="150dip"
                    android:layout_height="wrap_content"
                    android:layout_marginRight="10dip"
                    android:gravity="right|center_vertical"
                    android:text="Código SKU: "
                    android:textColor="#1565C0"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvCodSKU"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="1234567890"
                    android:textSize="14sp" />
            </TableRow>

            <TableRow
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <TextView
                    android:layout_width="150dip"
                    android:layout_height="wrap_content"
                    android:layout_marginRight="10dip"
                    android:gravity="right|center_vertical"
                    android:text="Cod. Articulo: "
                    android:textColor="#1565C0"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvCodArt"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="123123.0001"
                    android:textSize="14sp" />
            </TableRow>

            <TableRow
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <TextView
                    android:layout_width="150dip"
                    android:layout_height="wrap_content"
                    android:layout_marginRight="10dip"
                    android:gravity="right|center_vertical"
                    android:text="Talla Articulo: "
                    android:textColor="#1565C0"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvTalla"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="45"
                    android:textSize="14sp" />
            </TableRow>

            <TableRow
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <TextView
                    android:layout_width="150dip"
                    android:layout_height="wrap_content"
                    android:layout_marginRight="10dip"
                    android:gravity="right|center_vertical"
                    android:text="Descripción: "
                    android:textColor="#1565C0"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvDescArt"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Balanza de plastico con texto muy pero muy largo de prueba, asi que no hay que hacerle caso"
                    android:textSize="14sp" />
            </TableRow>

            <TableRow
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <TextView
                    android:layout_width="150dip"
                    android:layout_height="wrap_content"
                    android:layout_marginRight="10dip"
                    android:gravity="right|center_vertical"
                    android:text="Cantidad: "
                    android:textColor="#1565C0"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="left|center_vertical"
                    android:orientation="horizontal">

                    <EditText
                        android:id="@+id/etCantidad"
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:background="@drawable/rounded_edit_text"
                        android:gravity="right|center_vertical"
                        android:inputType="number"
                        android:paddingLeft="10dip"
                        android:paddingRight="10dip"
                        android:singleLine="true"
                        android:text="1"
                        android:textSize="16sp" />

                    <TextView
                        android:id="@+id/tvUnidad"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="10dip"
                        android:text="PAR"
                        android:textSize="14sp" />
                </LinearLayout>
            </TableRow>

            <TableRow
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <TextView
                    android:layout_width="150dip"
                    android:layout_height="wrap_content"
                    android:gravity="right|center_vertical"
                    android:layout_marginRight="10dip"
                    android:text="Precio Compra (Inluido IGV): "
                    android:textColor="#1565C0"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="left|center_vertical"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="150dip"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="10dip"
                            android:layout_marginRight="10dip"
                            android:gravity="right|center_vertical"
                            android:text="Antiguo Precio: "
                            android:textColor="#1565C0"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvOldPrecioCompra"
                            android:layout_width="100dp"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="10dip"
                            android:gravity="right|center_vertical"
                            android:text="90.00"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="150dip"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="10dip"
                            android:layout_marginRight="10dip"
                            android:gravity="right|center_vertical"
                            android:text="Nuevo Precio: "
                            android:textColor="#1565C0"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <EditText
                            android:id="@+id/etNewPrecioCompra"
                            android:layout_width="100dp"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="10dip"
                            android:background="@drawable/rounded_edit_text"
                            android:gravity="right|center_vertical"
                            android:inputType="number"
                            android:paddingLeft="10dip"
                            android:paddingRight="10dip"
                            android:singleLine="true"
                            android:text="80.00"
                            android:textSize="16sp" />
                    </LinearLayout>
                </LinearLayout>
            </TableRow>

            <TableRow
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <TextView
                    android:layout_width="120dip"
                    android:layout_height="wrap_content"
                    android:gravity="right|center_vertical"
                    android:layout_marginRight="10dip"
                    android:text="Precio Venta (Inluido IGV): "
                    android:textColor="#1565C0"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="left|center_vertical"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="150dip"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="10dip"
                            android:layout_marginRight="10dip"
                            android:gravity="right|center_vertical"
                            android:text="Antiguo Precio: "
                            android:textColor="#1565C0"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvOldPrecioVenta"
                            android:layout_width="100dp"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="10dip"
                            android:layout_marginRight="10dip"
                            android:gravity="right|center_vertical"
                            android:text="90.00"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="150dip"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="10dip"
                            android:layout_marginRight="10dip"
                            android:gravity="right|center_vertical"
                            android:text="Nuevo Precio: "
                            android:textColor="#1565C0"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <EditText
                            android:id="@+id/etNewPrecioVenta"
                            android:layout_width="100dp"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="10dip"
                            android:background="@drawable/rounded_edit_text"
                            android:gravity="right|center_vertical"
                            android:inputType="number"
                            android:paddingLeft="10dip"
                            android:paddingRight="10dip"
                            android:singleLine="true"
                            android:text="80.00"
                            android:textSize="16sp" />
                    </LinearLayout>
                </LinearLayout>
            </TableRow>
        </TableLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/llBotones"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/white"
        android:gravity="end|center_vertical"
        android:orientation="horizontal"
        android:padding="12dp">

        <Button
            android:id="@+id/btnCerrar"
            style="@style/PedidoButton.Muted"
            android:text="Cerrar" />

        <Button
            android:id="@+id/btnAceptar"
            style="@style/PedidoButton.Success"
            android:layout_marginEnd="0dp"
            android:text="Aceptar" />
    </LinearLayout>

</LinearLayout>
