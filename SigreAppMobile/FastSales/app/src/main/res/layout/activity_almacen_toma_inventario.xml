<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Activities.Almacen.AlmacenTomaInventarioActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/llTotales"
        android:orientation="vertical">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scrollbars="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tvAlmacen"
                        android:layout_width="170dp"
                        android:layout_height="wrap_content"
                        android:text="ALMACEN :"
                        android:textSize="25dp"/>

                    <Spinner
                        android:id="@+id/spAlmacen"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_weight="1" />


                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tvFechaConteo"
                        android:layout_width="170dp"
                        android:layout_height="wrap_content"
                        android:text="FECHA :"
                        android:textSize="25dp"/>

                    <EditText
                        android:id="@+id/etFechaConteo"
                        android:layout_width="160dp"
                        android:layout_height="wrap_content"
                        android:singleLine="true"
                        android:paddingRight="10dip"
                        android:paddingLeft="10dip"
                        android:gravity="right"
                        android:text="00/00/0000"
                        android:textSize="25dp"
                        android:background="@drawable/rounded_edit_text"
                        android:inputType="date" />

                    <ImageButton
                        android:id="@+id/ibObtenerFecha"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:src="@mipmap/ic_event_white_24dp"
                        tools:ignore="ContentDescription" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tvNroConteo"
                        android:layout_width="170dp"
                        android:layout_height="wrap_content"
                        android:text="NRO CONTEO :"
                        android:textSize="25dp"/>

                    <EditText
                        android:id="@+id/etNroConteo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:singleLine="true"
                        android:paddingRight="10dip"
                        android:paddingLeft="10dip"
                        android:gravity="right"
                        android:textSize="25dp"
                        android:text="1"
                        android:background="@drawable/rounded_edit_text"
                        android:inputType="number" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:paddingBottom="10dp"
                    android:paddingTop="10dp">

                    <Button
                        android:id="@+id/btnSalir"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Salir" />

                    <Button
                        android:id="@+id/btnStart"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Comenzar" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:paddingBottom="10dp"
                    android:paddingTop="10dp">

                    <TextView
                        android:id="@+id/tvText4"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="POSICION /  UBICACION"
                        android:textSize="25dp" />

                    <AutoCompleteTextView
                        xmlns:android="http://schemas.android.com/apk/res/android"
                        android:id="@+id/etPosicion"
                        android:layout_margin="10dp"
                        android:background="@drawable/rounded_edit_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:enabled="false"
                        android:gravity="center"
                        android:inputType="textCapCharacters"
                        android:paddingLeft="10dip"
                        android:paddingRight="10dip"
                        android:textSize="25dp"
                        android:focusable="true"
                        android:focusableInTouchMode="true"
                        android:windowSoftInputMode="stateAlwaysVisible"/>

                    <TextView
                        android:id="@+id/tvText3"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="CODIGO ARTICULO O SKU"
                        android:textSize="25dp" />

                    <EditText
                        android:id="@+id/etCodigoSKU"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_margin="10dp"
                        android:background="@drawable/rounded_edit_text"
                        android:enabled="false"
                        android:gravity="center"
                        android:inputType="text"
                        android:paddingLeft="10dip"
                        android:paddingRight="10dip"
                        android:singleLine="true"
                        android:text="022002.0001"
                        android:textSize="40dp" />

                    <TextView
                        android:id="@+id/tvMensaje"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="ARTICULO GRABADO CORRECTAMENTE"
                        android:textSize="15dp"
                        android:textColor="@android:color/holo_red_dark"/>

                    <Button
                        android:id="@+id/btnLeerCodigo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginTop="10dp"
                        android:enabled="false"
                        android:text="LEER CODIGO"
                        android:textSize="30dp" />

                </LinearLayout>

            </LinearLayout>

        </ScrollView>


    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:id="@+id/llTotales"
        app:layout_constraintBottom_toTopOf="@id/navigation"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvText5"
                android:layout_width="220dp"
                android:layout_height="wrap_content"
                android:text="Ultimo SKU Leido :"
                android:textSize="17dp"/>

            <TextView
                android:id="@+id/tvUltimoSKU"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:gravity="right"
                android:textSize="17dp"/>

        </LinearLayout>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvText7"
                android:layout_width="220dp"
                android:layout_height="wrap_content"
                android:text="Ultimo CU Leido :"
                android:textSize="17dp"/>

            <TextView
                android:id="@+id/tvUltimoCU"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:gravity="right"
                android:textSize="17dp"/>

        </LinearLayout>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvText6"
                android:layout_width="220dp"
                android:layout_height="wrap_content"
                android:text="Total Artic. x Posicion:"
                android:textSize="17dp"/>

            <TextView
                android:id="@+id/tvTotalLeidoPosicion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="0,000"
                android:gravity="right"
                android:textSize="17dp"/>

        </LinearLayout>
        <LinearLayout
            android:id="@+id/llTotalArticulosLeidos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvText1"
                android:layout_width="220dp"
                android:layout_height="wrap_content"
                android:text="Total Artículos Leidos :"
                android:textSize="17dp"/>

            <TextView
                android:id="@+id/tvTotalLeido"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="0,000"
                android:gravity="right"
                android:textSize="17dp"/>

        </LinearLayout>
        <LinearLayout
            android:id="@+id/llTotalArticulosUsuario"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvText2"
                android:layout_width="220dp"
                android:layout_height="wrap_content"
                android:text="Total Artículos Usuario :"
                android:textSize="17dp"/>

            <TextView
                android:id="@+id/tvTotalUser"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="0,000"
                android:gravity="right"
                android:textSize="17dp"/>

        </LinearLayout>
    </LinearLayout>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/navigation"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginEnd="0dp"
        android:layout_marginStart="0dp"
        android:background="?android:attr/windowBackground"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:menu="@menu/navigation" />

</androidx.constraintlayout.widget.ConstraintLayout>