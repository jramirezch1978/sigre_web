<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:cardCornerRadius="8dp"
        app:cardElevation="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <TextView
                style="@style/RrhhCardHeaderBar"
                android:text="👷 TRABAJADORES DEL PARTE" />

            <ListView
                android:id="@+id/lvTrabajadores"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:background="#FAFAFA"
                android:clipToPadding="false"
                android:divider="#E0E0E0"
                android:dividerHeight="1dp"
                android:minHeight="120dp"
                android:padding="4dp"
                android:scrollbars="vertical" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@android:color/white"
                android:orientation="vertical"
                android:padding="12dp">

                <Button
                    android:id="@+id/btnCargarCuadrilla"
                    style="@style/RrhhButtonSecondary"
                    android:text="CARGAR TRABAJADORES DE CUADRILLA" />

                <Button
                    android:id="@+id/btnAgregarTrabajador"
                    style="@style/RrhhButtonSecondary"
                    android:layout_marginTop="8dp"
                    android:text="+ AGREGAR TRABAJADOR" />
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>
</merge>
