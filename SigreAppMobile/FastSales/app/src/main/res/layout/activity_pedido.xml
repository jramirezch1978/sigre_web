<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:openDrawer="start">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <com.google.android.material.appbar.AppBarLayout
            android:layout_width="match_parent"
            android:layout_height="40dip"
            android:theme="@style/MyMaterialTheme.AppBarOverlay">

            <androidx.appcompat.widget.Toolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                android:background="?attr/colorPrimary"
                app:popupTheme="@style/MyMaterialTheme.PopupOverlay" />

        </com.google.android.material.appbar.AppBarLayout>


        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:onClick="clickLayout">


            <LinearLayout
                android:id="@+id/llBusqueda"
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_weight="1">

                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:padding="0dip"
                    android:layout_margin="0dip">

                    <ImageButton
                        android:id="@+id/ibOcultarBusqueda"
                        android:layout_width="40dp"
                        android:layout_height="match_parent"
                        android:src="@drawable/ocultar"
                        android:scaleType="fitCenter"
                        android:padding="0dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:text="Buscar: "
                        android:textSize="18dp"
                        android:textStyle="bold"
                        android:gravity="right|center_vertical"
                        android:id="@+id/textView5"/>

                    <EditText
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:id="@+id/etFiltro"
                        android:singleLine="true"
                        android:paddingLeft="5dp"
                        android:paddingRight="5dp"
                        android:layout_weight="1"
                        android:background="@drawable/rounded_edit_text" />

                    <Button
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:text="Buscar"
                        android:layout_marginLeft="5dp"
                        android:id="@+id/btnBuscar"
                        android:background="@drawable/boton_rectangular"/>

                </LinearLayout>

                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="fill_parent"
                    android:layout_weight="1">

                    <ListView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:id="@+id/lvListaArticulos" />

                </LinearLayout>

                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="20dp"
                    android:background="#7edd93"
                    android:gravity="right">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:text="Total Registros: "
                        android:layout_gravity="right"
                        android:id="@+id/textView6" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:text="0"
                        android:layout_gravity="right"
                        android:id="@+id/tvTotalRegistros"
                        android:layout_marginRight="20dip"/>


                </LinearLayout>

            </LinearLayout>

            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#0000FF"
                android:layout_weight="1">

                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="20dip"
                    android:padding="0dip"
                    android:layout_margin="0dip"
                    android:background="#00FFFF"
                    android:gravity="center_horizontal">


                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ULTIMA PROFORMA GENERADA: "
                        android:id="@+id/tvCaption"
                        android:linksClickable="false" />

                </LinearLayout>

                <ScrollView
                    android:layout_width="match_parent"
                    android:layout_height="fill_parent"
                    android:layout_weight="1"
                    android:background="#8cbe4a"
                    android:scrollbars="vertical|horizontal">

                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="fill_parent"
                        android:id="@+id/horizontalScrollView"
                        android:layout_weight="1">

                        <TableLayout
                            android:id="@+id/tablePedido"
                            android:stretchColumns="1"
                            android:layout_width="match_parent"
                            android:layout_height="fill_parent"
                            android:layout_weight="1">

                        </TableLayout>

                    </HorizontalScrollView>
                </ScrollView>

                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="0dip"
                    android:layout_margin="0dip"
                    android:background="#00FFFF"
                    android:gravity="right">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Base Imponible: "
                            android:id="@+id/textView10"
                            android:gravity="center_vertical"
                            android:layout_marginRight="10dip"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="S/"
                            android:id="@+id/tvMonedaBI"
                            android:layout_marginRight="5dip"/>

                        <TextView
                            android:layout_width="60dip"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical|right"
                            android:text="0.00"
                            android:id="@+id/tvBaseImponible"
                            android:layout_marginRight="10dip"/>

                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="IGV: "
                            android:id="@+id/textView11"
                            android:gravity="center_vertical"
                            android:layout_marginRight="10dip"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="S/"
                            android:id="@+id/tvMonedaIGV"
                            android:layout_marginRight="5dip"/>

                        <TextView
                            android:layout_width="60dip"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical|right"
                            android:text="0.00"
                            android:id="@+id/tvIGV"
                            android:layout_marginRight="10dip"/>

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Importe Venta: "
                            android:id="@+id/textView9"
                            android:gravity="center_vertical"
                            android:layout_marginRight="10dip"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="S/"
                            android:id="@+id/tvMonedaVta"
                            android:layout_marginRight="5dip"/>

                        <TextView
                            android:layout_width="60dip"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical|right"
                            android:text="0.00"
                            android:id="@+id/tvImporteVenta"
                            android:layout_marginRight="10dip"/>

                    </LinearLayout>

                </LinearLayout>


                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#FFFFFF"
                    android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:text="Tipo Comprobante: "
                            android:id="@+id/textView8"
                            android:gravity="center_vertical"/>

                        <RadioGroup xmlns:android="http://schemas.android.com/apk/res/android"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="horizontal"
                            android:gravity="center_vertical|center_horizontal"
                            android:id="@+id/rgFlagFacturaBoleta">

                            <RadioButton
                                android:layout_width="wrap_content"
                                android:layout_height="match_parent"
                                android:text="Factura"
                                android:id="@+id/rbFactura" />

                            <RadioButton
                                android:layout_width="wrap_content"
                                android:layout_height="match_parent"
                                android:text="Boleta"
                                android:id="@+id/rbBoleta" />

                            <RadioButton
                                android:layout_width="wrap_content"
                                android:layout_height="match_parent"
                                android:text="Nota Venta"
                                android:id="@+id/rbNotaVenta" />
                        </RadioGroup>


                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#FFFFFF"
                    android:orientation="horizontal"
                    android:gravity="right">

                    <Button
                        android:id="@+id/btnMostrarBusqueda"
                        android:layout_width="wrap_content"
                        android:layout_height="30dip"
                        android:text="Mostrar Busqueda"
                        android:textSize="10dip"
                        android:layout_marginRight="5sp"
                        android:paddingLeft="5dip"
                        android:paddingRight="5dip"
                        android:visibility="gone"
                        android:background="@drawable/boton_rectangular" />

                    <Button
                        android:layout_width="wrap_content"
                        android:layout_height="30dip"
                        android:text="Lectura Codigo"
                        android:id="@+id/btnLecturaQR"
                        android:textSize="10dip"
                        android:layout_marginRight="5sp"
                        android:padding="0dip"
                        android:background="@drawable/boton_rectangular" />

                    <Button
                        android:layout_width="wrap_content"
                        android:layout_height="30dip"
                        android:text="Limpiar Pedido"
                        android:id="@+id/btnLimpiarPedido"
                        android:textSize="10dip"
                        android:layout_marginRight="5dp"
                        android:padding="0dip"
                        android:background="@drawable/boton_rectangular" />

                    <Button
                        android:layout_width="wrap_content"
                        android:layout_height="30dip"
                        android:text="Grabar"
                        android:id="@+id/btnGrabar"
                        android:textSize="10dip"
                        android:layout_marginRight="5dp"
                        android:padding="0dip"
                        android:background="@drawable/boton_rectangular"/>

                    <Button
                        android:layout_width="wrap_content"
                        android:layout_height="30dip"
                        android:text="Salir"
                        android:id="@+id/btnSalir"
                        android:textSize="10dip"
                        android:layout_marginRight="5dp"
                        android:padding="0dip"
                        android:background="@drawable/boton_transparente"/>

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>


</androidx.drawerlayout.widget.DrawerLayout>

