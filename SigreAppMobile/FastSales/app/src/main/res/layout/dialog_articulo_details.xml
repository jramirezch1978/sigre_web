<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#1976D2"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Detalle de Artículo"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Información comercial y de stock del artículo"
            android:textColor="#E3F2FD"
            android:textSize="12sp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="vertical">

        <TableLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:shrinkColumns="1">

            <TableRow
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <TextView
                    android:id="@+id/textView10"
                    android:layout_width="100dip"
                    android:layout_height="wrap_content"
                    android:text="Código: "
                    android:textColor="#1565C0"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvCodArt"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="123123.0001" />
            </TableRow>

            <TableRow
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <TextView
                    android:id="@+id/textView11"
                    android:layout_width="100dip"
                    android:layout_height="wrap_content"
                    android:text="Descripción: "
                    android:textColor="#1565C0"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvDescArt"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Balanza de plastico con texto muy pero muy largo de prueba, asi que no hay que hacerle caso" />
            </TableRow>

            <TableRow
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <TextView
                    android:id="@+id/textView12"
                    android:layout_width="100dip"
                    android:layout_height="wrap_content"
                    android:text="Marca: "
                    android:textColor="#1565C0"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvMarca"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="Mi Patito" />
            </TableRow>

            <TableRow
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <TextView
                    android:id="@+id/textView13"
                    android:layout_width="100dip"
                    android:layout_height="wrap_content"
                    android:text="Stock Total: "
                    android:textColor="#1565C0"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvStock"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="3.00" />
            </TableRow>

            <TableRow
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <TextView
                    android:id="@+id/textView14"
                    android:layout_width="120dip"
                    android:layout_height="wrap_content"
                    android:text="Precio x unidad: "
                    android:textColor="#1565C0"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvMonedaVtaUnidad"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="S/." />

                    <TextView
                        android:id="@+id/tvPrecioVentaUnidad"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="10dip"
                        android:text="1.00" />
                </LinearLayout>
            </TableRow>

            <TableRow
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <TextView
                    android:id="@+id/textView15"
                    android:layout_width="120dip"
                    android:layout_height="wrap_content"
                    android:text="Precio x mayor: "
                    android:textColor="#1565C0"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvMonedaVtaMayor"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="S/." />

                    <TextView
                        android:id="@+id/tvPrecioVentaMayor"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="10dip"
                        android:text="1.00" />
                </LinearLayout>
            </TableRow>

            <TableRow
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <TextView
                    android:id="@+id/textView16"
                    android:layout_width="120dip"
                    android:layout_height="wrap_content"
                    android:text="Imagen: "
                    android:textColor="#1565C0"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/ivImagen"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scaleType="fitCenter"
                    android:src="@drawable/noimagen" />
            </TableRow>
        </TableLayout>
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/white"
        android:gravity="end"
        android:orientation="horizontal"
        android:padding="12dp">

        <Button
            android:id="@+id/btnCerrar"
            style="@style/PedidoButton.Muted"
            android:layout_marginEnd="0dp"
            android:text="Cerrar" />
    </LinearLayout>

</LinearLayout>
