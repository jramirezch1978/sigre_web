<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Activities.Almacen.AlmacenParteRecepcionActivity">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <com.google.android.material.appbar.AppBarLayout
            android:layout_width="match_parent"
            android:layout_height="40dip"
            android:theme="@style/MyMaterialTheme.AppBarOverlay">

            <androidx.appcompat.widget.Toolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                android:background="?attr/colorPrimary"
                app:popupTheme="@style/MyMaterialTheme.PopupOverlay" />

        </com.google.android.material.appbar.AppBarLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical|center_horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Desde: "
                android:layout_marginRight="10dip"
                android:layout_marginLeft="10dip"
                android:textSize="18dip"/>

            <EditText
                android:id="@+id/etFechaDesde"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:singleLine="true"
                android:paddingRight="10dip"
                android:paddingLeft="10dip"
                android:gravity="center"
                android:text="00/00/0000"
                android:textSize="20dp"
                android:background="@drawable/rounded_edit_text"
                android:inputType="date"/>

            <ImageButton
                android:id="@+id/ibObtenerFechaDesde"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@mipmap/ic_event_white_24dp"
                tools:ignore="ContentDescription" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hasta: "
                android:layout_marginRight="10dip"
                android:layout_marginLeft="10dip"
                android:textSize="18dip"/>

            <EditText
                android:id="@+id/etFechaHasta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:singleLine="true"
                android:paddingRight="10dip"
                android:paddingLeft="10dip"
                android:gravity="center"
                android:text="00/00/0000"
                android:textSize="20dp"
                android:background="@drawable/rounded_edit_text"
                android:inputType="date"/>

            <ImageButton
                android:id="@+id/ibObtenerFechaHasta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@mipmap/ic_event_white_24dp"
                tools:ignore="ContentDescription" />

            <Button
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Buscar"
                android:id="@+id/btnBuscar"
                android:layout_marginLeft="5dp"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="10dp"
                android:background="@drawable/boton_rectangular"/>

            <Button
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Salir"
                android:layout_marginLeft="5dp"
                android:layout_marginRight="5dp"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="10dp"
                android:id="@+id/btnSalir"
                android:background="@drawable/boton_rectangular"/>

        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="LISTADO DE PARTES DE RECEPCION"
            android:textSize="20sp"
            android:textStyle="bold"
            android:background="@android:color/holo_blue_dark"
            android:textColor="@android:color/white"/>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="#C0C0C0"
            android:scrollbars="vertical|horizontal">

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:id="@+id/horizontalScrollView"
                android:layout_weight="1">

                <TableLayout
                    android:id="@+id/tblParteRecepcion"
                    android:stretchColumns="1"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_weight="1">

                </TableLayout>

            </HorizontalScrollView>
        </ScrollView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_weight="1"
                android:gravity="center_vertical|center_horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total registros: "
                    android:layout_marginLeft="5dp"
                    android:textSize="15dip"
                    android:textColor="@android:color/black"/>

                <TextView
                    android:id="@+id/tvTotalRegistros"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0.00"
                    android:layout_marginLeft="5dp"
                    android:textSize="15dip"
                    android:textColor="#0000FF"
                    android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_weight="1"
                android:gravity="center_vertical|center_horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total de Cajas: "
                    android:layout_marginLeft="5dp"
                    android:textSize="15dip"
                    android:textColor="@android:color/black"/>

                <TextView
                    android:id="@+id/tvTotalCajas"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0.00"
                    android:layout_marginLeft="5dp"
                    android:textSize="15dip"
                    android:textColor="#0000FF"
                    android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_weight="1"
                android:gravity="center_vertical|center_horizontal">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total Valor Compra: "
                    android:layout_marginLeft="5dp"
                    android:textSize="15dip"
                    android:textColor="@android:color/black"/>

                <TextView
                    android:id="@+id/tvTotalCompra"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0.00"
                    android:layout_marginLeft="5dp"
                    android:textSize="15dip"
                    android:textColor="#0000FF"
                    android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_weight="1"
                android:gravity="center_vertical|center_horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total Valor Venta: "
                    android:layout_marginLeft="5dp"
                    android:textSize="15dip"
                    android:textColor="@android:color/black"/>

                <TextView
                    android:id="@+id/tvTotalVenta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0.00"
                    android:layout_marginLeft="5dp"
                    android:textSize="15dip"
                    android:textColor="#0000FF"
                    android:textStyle="bold"/>

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>


    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="@dimen/fab_margin"
        app:srcCompat="@mipmap/ic_menu_folder_plus" />

</androidx.constraintlayout.widget.ConstraintLayout>