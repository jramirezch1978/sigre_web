<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/llBottom"
        android:orientation="vertical">

        <!-- Titulo -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="DESPACHO POR PALLETS / CU SIMPLIFICADO"
            android:textSize="20sp"
            android:textStyle="bold"
            android:background="@android:color/holo_blue_dark"
            android:textColor="@android:color/white" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scrollbars="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <!-- Almacen Despacho -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Almacen Despacho"
                    android:gravity="center_horizontal|center_vertical"
                    android:textStyle="bold"
                    android:textSize="20dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical|center_horizontal">

                    <EditText
                        android:id="@+id/etAlmacen"
                        android:layout_width="130dip"
                        android:layout_height="wrap_content"
                        android:singleLine="true"
                        android:paddingRight="10dip"
                        android:paddingLeft="10dip"
                        android:gravity="center"
                        android:text="ALMPI"
                        android:textSize="20dp"
                        android:background="@drawable/rounded_edit_text"/>

                    <Button
                        android:id="@+id/btnAlmacen"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_marginLeft="5dp"
                        android:gravity="center_horizontal|center_vertical"
                        android:padding="0dp"
                        android:text="..."
                        android:textSize="20dp" />

                    <TextView
                        android:id="@+id/tvDescAlmacen"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="ALMACEN TIENDA PIURA "
                        android:layout_marginRight="5dip"
                        android:layout_marginLeft="5dip"
                        android:layout_gravity="left|center_vertical"
                        android:textSize="18sp"
                        android:textColor="@android:color/holo_blue_dark"/>


                </LinearLayout>


                <!-- Orden de Venta -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Orden de Venta"
                    android:gravity="center_horizontal|center_vertical"
                    android:textStyle="bold"
                    android:textSize="20dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical|center_horizontal">



                    <EditText
                        android:id="@+id/etOrdenVenta"
                        android:layout_width="130dp"
                        android:layout_height="wrap_content"
                        android:singleLine="true"
                        android:paddingRight="10dip"
                        android:paddingLeft="10dip"
                        android:gravity="center_horizontal|center_vertical"
                        android:text="P10000003"
                        android:textSize="20dp"
                        android:background="@drawable/rounded_edit_text"/>

                    <Button
                        android:id="@+id/btnOrdenVenta"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_marginLeft="5dp"
                        android:gravity="center_horizontal|center_vertical"
                        android:padding="0dp"
                        android:text="..."
                        android:textSize="20dp" />

                    <TextView
                        android:id="@+id/tvNomCliente"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Venta de Conservas"
                        android:layout_marginRight="5dp"
                        android:layout_marginLeft="5dp"
                        android:layout_gravity="center_vertical|left"
                        android:textSize="18sp"
                        android:textColor="@android:color/holo_blue_dark"/>

                </LinearLayout>

                <!-- Articulo Orden Venta -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Articulo a despachar"
                    android:gravity="center_horizontal|center_vertical"
                    android:textStyle="bold"
                    android:textSize="20dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical|top">

                    <EditText
                        android:id="@+id/etArticulo"
                        android:layout_width="130dp"
                        android:layout_height="wrap_content"
                        android:singleLine="true"
                        android:paddingRight="10dip"
                        android:paddingLeft="10dip"
                        android:gravity="center_horizontal|center_vertical"
                        android:text="101171.00034"
                        android:textSize="16dp"
                        android:background="@drawable/rounded_edit_text"/>

                    <Button
                        android:id="@+id/btnArticulo"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_marginLeft="5dp"
                        android:gravity="center_horizontal|center_vertical"
                        android:padding="0dp"
                        android:text="..."
                        android:textSize="20dp" />

                    <TextView
                        android:id="@+id/tvDescArticulo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="POTA DARUMA STANDAR 0.8-1.2 CM/ESP BLOCK 3X7.5KG SACO 22.5 K"
                        android:layout_marginRight="5dp"
                        android:layout_marginLeft="5dp"
                        android:layout_gravity="center_vertical|left"
                        android:textSize="16sp"
                        android:textColor="@android:color/holo_blue_dark"/>

                    <TextView
                        android:id="@+id/tvOrgAMP"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:visibility="gone"/>

                    <TextView
                        android:id="@+id/tvNroAMP"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:visibility="gone"/>

                </LinearLayout>


                <!-- Fecha Despacho -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Fecha Despacho:"
                    android:gravity="center_horizontal|center_vertical"
                    android:textStyle="bold"
                    android:textSize="20dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="left|center_vertical">



                    <EditText
                        android:id="@+id/etFechaDespacho"
                        android:layout_width="180dp"
                        android:layout_height="wrap_content"
                        android:singleLine="true"
                        android:paddingRight="10dip"
                        android:paddingLeft="10dip"
                        android:gravity="center_vertical|center_horizontal"
                        android:text="00/00/0000"
                        android:textSize="20dp"
                        android:background="@drawable/rounded_edit_text"
                        android:inputType="date" />

                    <ImageButton
                        android:id="@+id/ibObtenerFecha"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:padding="7dp"
                        android:src="@mipmap/ic_event_white_24dp"
                        tools:ignore="ContentDescription" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_gravity="center_horizontal|center_vertical"
                    android:layout_marginTop="5dp"
                    android:paddingBottom="5dp">
                    <Button
                        android:id="@+id/btnComienzo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="Comenzar Lectura"
                        android:textSize="16dp"
                        android:layout_marginRight="10dp"
                        android:enabled="true"/>

                    <Button
                        android:id="@+id/btnTerminar"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="Terminar Lectura"
                        android:textSize="16dp"
                        android:enabled="false"/>
                </LinearLayout>



                <TabHost
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:id="@+id/tabHost">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical">

                        <TabWidget
                            android:id="@android:id/tabs"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"></TabWidget>

                        <FrameLayout
                            android:id="@android:id/tabcontent"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">

                            <!-- TAB 1 -->
                            <LinearLayout
                                android:id="@+id/tab1"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="center"
                                    android:text="LECTURA PALLET / CODIGO CU"
                                    android:textSize="20sp"
                                    android:textStyle="bold"
                                    android:background="@android:color/holo_blue_dark"
                                    android:textColor="@android:color/white" />

                                <ScrollView
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:scrollbars="vertical">

                                    <LinearLayout
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:orientation="vertical">

                                        <TextView
                                            android:id="@+id/tvText3"
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"
                                            android:gravity="center_horizontal|center_vertical"
                                            android:text="LEER PALLET / CODIGO CU"
                                            android:textSize="25dp"
                                            android:textStyle="bold"
                                            android:layout_marginTop="10sp"/>

                                        <EditText
                                            android:id="@+id/etNroPallet"
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"
                                            android:layout_margin="10dp"
                                            android:background="@drawable/rounded_edit_text"
                                            android:gravity="center"
                                            android:inputType="text"
                                            android:paddingLeft="10dip"
                                            android:paddingRight="10dip"
                                            android:singleLine="true"
                                            android:text="022002.0001"
                                            android:textSize="40dp"
                                            android:enabled="false"/>

                                        <Button
                                            android:id="@+id/btnLeerCodigo"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_gravity="center"
                                            android:text="LEER CODIGO"
                                            android:textSize="20dp"
                                            android:layout_marginBottom="10dp"
                                            android:enabled="false"/>

                                    </LinearLayout>

                                </ScrollView>

                            </LinearLayout>

                            <!-- TAB 2 -->
                            <LinearLayout
                                android:id="@+id/tab2"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="center"
                                    android:text="LISTADO DE CUS LEIDOS"
                                    android:textSize="20sp"
                                    android:textStyle="bold"
                                    android:background="@android:color/holo_blue_dark"
                                    android:textColor="@android:color/white" />

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_gravity="right|center_vertical"
                                    android:orientation="horizontal">

                                    <Button
                                        android:id="@+id/btnResetear"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_gravity="left|center_vertical"
                                        android:text="Limpiar Lectura"
                                        android:textSize="16dp"
                                        android:enabled="false"/>

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="match_parent"
                                        android:text="Total Registros:"
                                        android:gravity="right|center_vertical"
                                        android:textStyle="bold"
                                        android:textSize="20dp"/>

                                    <TextView
                                        android:id="@+id/tvNroRegistros"
                                        android:layout_width="wrap_content"
                                        android:layout_height="match_parent"
                                        android:text="1,000"
                                        android:gravity="right|center_vertical"
                                        android:textStyle="bold"
                                        android:textSize="20dp"/>

                                </LinearLayout>


                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:orientation="vertical">

                                    <ScrollView
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:background="@android:color/darker_gray"
                                        android:scrollbars="vertical|horizontal">

                                        <HorizontalScrollView
                                            android:layout_width="match_parent"
                                            android:layout_height="match_parent"
                                            android:layout_weight="1">

                                            <TableLayout
                                                android:id="@+id/tblListadoCUS"
                                                android:stretchColumns="1"
                                                android:layout_width="match_parent"
                                                android:layout_height="match_parent"
                                                android:layout_weight="1">

                                            </TableLayout>

                                        </HorizontalScrollView>
                                    </ScrollView>

                                </LinearLayout>

                            </LinearLayout>

                            <!-- TAB 3 -->
                            <LinearLayout
                                android:id="@+id/tab3"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="center"
                                    android:text="RESUMEN DE LECTURA"
                                    android:textSize="20sp"
                                    android:textStyle="bold"
                                    android:background="@android:color/holo_blue_dark"
                                    android:textColor="@android:color/white" />

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_gravity="right|center_vertical"
                                    android:orientation="horizontal">

                                    <Button
                                        android:id="@+id/btnReporte"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_gravity="left|center_vertical"
                                        android:text="Reporte"
                                        android:textSize="16dp"
                                        android:enabled="false"/>

                                </LinearLayout>


                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:orientation="vertical">

                                    <ScrollView
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:background="@android:color/darker_gray"
                                        android:scrollbars="vertical|horizontal">

                                        <HorizontalScrollView
                                            android:layout_width="match_parent"
                                            android:layout_height="match_parent"
                                            android:layout_weight="1">

                                            <TableLayout
                                                android:id="@+id/tblResumenLectura"
                                                android:stretchColumns="1"
                                                android:layout_width="match_parent"
                                                android:layout_height="match_parent"
                                                android:layout_weight="1">

                                            </TableLayout>

                                        </HorizontalScrollView>
                                    </ScrollView>

                                </LinearLayout>

                            </LinearLayout>

                        </FrameLayout>

                    </LinearLayout>

                </TabHost>


            </LinearLayout>

        </ScrollView>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingBottom="5dp"
        android:paddingTop="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        android:background="?android:attr/windowBackground"
        android:id="@+id/llBottom">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="5dp"
            android:paddingTop="5dp">

            <TextView
                android:id="@+id/tvMensaje"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="Registro grabado correcamente"
                android:textSize="15dp"
                android:textColor="@android:color/holo_red_dark"/>


        </LinearLayout>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingBottom="5dp"
            android:paddingTop="5dp">

            <Button
                android:id="@+id/btnDespachar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:enabled="false"
                android:text="Despachar" />

            <Button
                android:id="@+id/btnSalir"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Salir" />
        </LinearLayout>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>