<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/colorPrimary"
        android:elevation="4dp"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
        app:titleTextColor="@android:color/white"
        app:popupTheme="@style/ThemeOverlay.AppCompat.Light"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Sección de Búsqueda -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔍 BUSCAR TRABAJADOR"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/colorPrimary"
                        android:layout_marginBottom="12dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ingrese DNI, código o nombre del trabajador"
                        android:textSize="12sp"
                        android:textColor="#666666"
                        android:layout_marginBottom="8dp"/>

                    <EditText
                        android:id="@+id/etBusqueda"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="DNI, Código o Nombre"
                        android:inputType="text"
                        android:imeOptions="actionSearch"
                        android:padding="12dp"
                        android:background="@drawable/login_edit_text_background"
                        android:layout_marginBottom="12dp"/>

                    <Button
                        android:id="@+id/btnBuscar"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="🔍 BUSCAR"
                        android:textColor="#FFFFFF"
                        android:background="@drawable/login_button_primary"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Sección de Datos del Trabajador -->
            <androidx.cardview.widget.CardView
                android:id="@+id/layoutDatosTrabajador"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:visibility="gone"
                app:cardCornerRadius="8dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="👤 DATOS DEL TRABAJADOR"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/colorPrimary"
                        android:layout_marginBottom="16dp"/>

                    <!-- Foto con frame - MÁS GRANDE -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="280dp"
                        android:layout_height="280dp"
                        android:layout_gravity="center"
                        android:layout_marginBottom="16dp"
                        app:cardCornerRadius="8dp"
                        app:cardElevation="2dp">

                        <ImageView
                            android:id="@+id/ivFotoTrabajador"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@drawable/ic_user_placeholder"/>
                    </androidx.cardview.widget.CardView>

                    <!-- Botones de acción de foto -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:layout_marginBottom="16dp">

                        <ImageButton
                            android:id="@+id/ibTomarFoto"
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            android:src="@android:drawable/ic_menu_camera"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:contentDescription="Tomar foto"
                            android:layout_marginEnd="24dp"
                            android:tint="@color/colorPrimary"/>

                        <ImageButton
                            android:id="@+id/ibEliminarFoto"
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            android:src="@android:drawable/ic_menu_delete"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:contentDescription="Eliminar foto"
                            android:layout_marginStart="24dp"
                            android:tint="#F44336"/>
                    </LinearLayout>

                    <!-- Datos del trabajador -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp"
                        android:background="#F0F0F0"
                        android:layout_marginBottom="16dp">

                        <TextView
                            android:id="@+id/tvCodTrabajador"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Código: 20000001"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#333333"
                            android:layout_marginBottom="4dp"/>

                        <TextView
                            android:id="@+id/tvNombreTrabajador"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="NOMBRE DEL TRABAJADOR"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/colorPrimary"
                            android:layout_marginBottom="8dp"/>

                        <TextView
                            android:id="@+id/tvDNI"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="DNI: 12345678"
                            android:textSize="14sp"
                            android:textColor="#666666"
                            android:layout_marginBottom="4dp"/>

                        <TextView
                            android:id="@+id/tvCargo"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Cargo: OPERARIO"
                            android:textSize="14sp"
                            android:textColor="#666666"
                            android:layout_marginBottom="4dp"/>

                        <TextView
                            android:id="@+id/tvArea"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Área: PRODUCCIÓN"
                            android:textSize="14sp"
                            android:textColor="#666666"
                            android:layout_marginBottom="4dp"/>

                        <TextView
                            android:id="@+id/tvFechaNacimiento"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Nacimiento: 01/01/1990"
                            android:textSize="14sp"
                            android:textColor="#666666"
                            android:layout_marginBottom="4dp"/>

                        <TextView
                            android:id="@+id/tvFechaIngreso"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Ingreso: 01/01/2020"
                            android:textSize="14sp"
                            android:textColor="#666666"
                            android:layout_marginBottom="4dp"/>

                        <TextView
                            android:id="@+id/tvFechaCese"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Cese: N/A"
                            android:textSize="14sp"
                            android:textColor="#666666"
                            android:layout_marginBottom="8dp"
                            android:visibility="gone"/>

                        <TextView
                            android:id="@+id/tvEstado"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Estado: Activo"
                            android:textSize="14sp"
                            android:textColor="#4CAF50"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <!-- Botones de acción -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center">

                        <Button
                            android:id="@+id/btnAceptar"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="✓ ACEPTAR"
                            android:textColor="#FFFFFF"
                            android:background="@drawable/login_button_primary"
                            android:layout_marginEnd="8dp"
                            android:enabled="false"/>

                        <Button
                            android:id="@+id/btnCancelar"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="✕ CANCELAR"
                            android:textColor="#757575"
                            android:textStyle="bold"
                            android:background="@drawable/login_button_secondary"
                            android:layout_marginStart="8dp"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
