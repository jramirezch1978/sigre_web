<?xml version="1.0" encoding="utf-8"?>
<!-- Portrait: pedido a pantalla completa; artículos en drawer izquierdo -->
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerArticulos"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <!-- Contenido principal: pedido -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#E3F2FD">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#1976D2"
            android:gravity="center_vertical"
            android:padding="4dp">

            <ImageButton
                android:id="@+id/ibMenuArticulos"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_menu_lines_vertical"
                android:scaleType="centerInside"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Menú artículos" />

            <TextView
                android:id="@+id/tvCaption"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="ULTIMA PROFORMA GENERADA: "
                android:textColor="@android:color/white"
                android:textStyle="bold"
                android:gravity="center"
                android:paddingStart="4dp"
                android:paddingEnd="4dp" />

            <ImageButton
                android:id="@+id/btnAddArticulo"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_input_add"
                android:scaleType="centerInside"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Añadir artículo"
                app:tint="@android:color/white" />
        </LinearLayout>

        <!-- Portrait: listado tipo POS (toda la info por ítem, sin scroll horizontal) -->
        <ListView
            android:id="@+id/lvPedidoDetalle"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="#F5F5F5"
            android:divider="#E0E0E0"
            android:dividerHeight="1dp"
            android:paddingTop="4dp"
            android:clipToPadding="false"
            android:scrollbarStyle="outsideOverlay" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#E3F2FD"
            android:gravity="end"
            android:padding="4dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Base Imponible: "
                    android:layout_marginRight="10dp" />

                <TextView
                    android:id="@+id/tvMonedaBI"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="S/"
                    android:layout_marginRight="5dp" />

                <TextView
                    android:id="@+id/tvBaseImponible"
                    android:layout_width="60dp"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical|end"
                    android:text="0.00"
                    android:layout_marginRight="10dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="IGV: "
                    android:layout_marginRight="10dp" />

                <TextView
                    android:id="@+id/tvMonedaIGV"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="S/"
                    android:layout_marginRight="5dp" />

                <TextView
                    android:id="@+id/tvIGV"
                    android:layout_width="60dp"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical|end"
                    android:text="0.00"
                    android:layout_marginRight="10dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Importe Venta: "
                    android:layout_marginRight="10dp" />

                <TextView
                    android:id="@+id/tvMonedaVta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="S/"
                    android:layout_marginRight="5dp" />

                <TextView
                    android:id="@+id/tvImporteVenta"
                    android:layout_width="60dp"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical|end"
                    android:text="0.00"
                    android:layout_marginRight="10dp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@android:color/white"
            android:padding="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:text="Tipo Comprobante: "
                android:gravity="center_vertical" />

            <RadioGroup
                android:id="@+id/rgFlagFacturaBoleta"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center">

                <RadioButton
                    android:id="@+id/rbFactura"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:text="Factura" />

                <RadioButton
                    android:id="@+id/rbBoleta"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:text="Boleta" />

                <RadioButton
                    android:id="@+id/rbNotaVenta"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:text="Nota Venta" />
            </RadioGroup>
        </LinearLayout>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:fillViewport="true"
            android:background="@android:color/white">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="end|center_vertical"
                android:padding="8dp">

                <Button
                    android:id="@+id/btnMostrarBusqueda"
                    style="@style/PedidoButton.Primary"
                    android:text="Añadir artículo" />

                <Button
                    android:id="@+id/btnLecturaQR"
                    style="@style/PedidoButton.Secondary"
                    android:text="Lectura código" />

                <Button
                    android:id="@+id/btnLimpiarPedido"
                    style="@style/PedidoButton.Muted"
                    android:text="Limpiar" />

                <Button
                    android:id="@+id/btnGrabar"
                    style="@style/PedidoButton.Success"
                    android:text="Grabar" />

                <Button
                    android:id="@+id/btnSalir"
                    style="@style/PedidoButton.Danger"
                    android:layout_marginEnd="0dp"
                    android:text="Salir" />
            </LinearLayout>
        </HorizontalScrollView>
    </LinearLayout>

    <!-- Panel deslizable desde la izquierda: búsqueda de artículos -->
    <LinearLayout
        android:id="@+id/llBusqueda"
        android:layout_width="300dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:orientation="vertical"
        android:background="#E3F2FD"
        android:clickable="true"
        android:focusable="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:orientation="horizontal"
            android:background="#1976D2"
            android:gravity="center_vertical">

            <ImageButton
                android:id="@+id/ibOcultarBusqueda"
                android:layout_width="40dp"
                android:layout_height="match_parent"
                android:src="@drawable/ocultar"
                android:scaleType="fitCenter"
                android:padding="0dp"
                android:background="@android:color/transparent"
                android:contentDescription="Cerrar búsqueda" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:text="Buscar: "
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:gravity="center_vertical" />

            <EditText
                android:id="@+id/etFiltro"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:singleLine="true"
                android:paddingLeft="5dp"
                android:paddingRight="5dp"
                android:background="@drawable/rounded_edit_text" />

            <Button
                android:id="@+id/btnBuscar"
                style="@style/PedidoButton.Primary"
                android:layout_height="match_parent"
                android:layout_marginLeft="4dp"
                android:layout_marginEnd="4dp"
                android:text="Buscar" />
        </LinearLayout>

        <ListView
            android:id="@+id/lvListaArticulos"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@android:color/white" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="22dp"
            android:orientation="horizontal"
            android:background="#BBDEFB"
            android:gravity="end">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:text="Total Registros: "
                android:textColor="#1976D2"
                android:gravity="center_vertical" />

            <TextView
                android:id="@+id/tvTotalRegistros"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:text="0"
                android:textColor="#1976D2"
                android:layout_marginRight="16dp"
                android:gravity="center_vertical" />
        </LinearLayout>
    </LinearLayout>
</androidx.drawerlayout.widget.DrawerLayout>
