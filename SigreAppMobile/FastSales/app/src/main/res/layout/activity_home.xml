<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/db1_root"
    android:orientation="vertical"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent">

    <!-- Barra de título SIGRE (azul) -->
    <LinearLayout style="@style/TitleBar">

        <ImageView style="@style/TitleBarLogo"
            android:contentDescription="@string/lblDescripcionLogo"
            android:src="@drawable/title_logo"
            android:layout_width="120dp"/>

        <ImageView style="@style/TitleBarSeparator" />

        <TextView style="@style/TitleBarText" />

        <TextView
            android:id="@+id/tvOrigen"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:text="Org [XX]"
            android:textColor="@android:color/white"
            android:textSize="20sp"
            android:fontFamily="Arial"
            android:gravity="center_vertical" />

        <ImageButton style="@style/TitleBarAction"
            android:contentDescription="@string/lblDescripcionAbout"
            android:src="@drawable/title_about"
            android:id="@+id/ibAbout"/>

        <ImageButton style="@style/TitleBarAction"
            android:contentDescription="@string/lblDescripcionSearch"
            android:src="@drawable/title_search"/>
    </LinearLayout>

    <!-- Encabezado de Empresa (debajo de la barra azul) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:padding="8dp"
        android:background="#E3F2FD">

        <ImageView
            android:id="@+id/ivLogoEmpresa"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginEnd="8dp"
            android:scaleType="fitCenter"
            android:background="@android:color/white"
            android:padding="2dp"
            android:src="@drawable/icono_empresa"
            android:contentDescription="Logo Empresa"/>

        <TextView
            android:id="@+id/tvNombreEmpresa"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="EMPRESA SAC"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#1976D2"
            android:maxLines="1"
            android:ellipsize="end"/>
    </LinearLayout>

    <!-- Contenido con los módulos -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:background="@android:color/white"
        android:scrollbars="vertical">

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="6dip">

            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_weight="1">

                <Button android:id="@+id/btnFastSales"
                    style="@style/HomeButton"
                    android:onClick="onClickFeature"
                    android:text="@string/lblModulo1"
                    android:drawableTop="@drawable/home_button1"/>

                <Button android:id="@+id/almacen"
                    style="@style/HomeButton"
                    android:onClick="onClickFeature"
                    android:text="@string/lblModulo2"
                    android:drawableTop="@drawable/home_button2"/>

            </LinearLayout>

            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_weight="1">

                <Button android:id="@+id/asistencia"
                    style="@style/HomeButton"
                    android:onClick="onClickFeature"
                    android:text="@string/lblModulo11"
                    android:drawableTop="@drawable/home_button11"/>

                <Button android:id="@+id/compras"
                    style="@style/HomeButton"
                    android:onClick="onClickFeature"
                    android:text="@string/lblModulo3"
                    android:drawableTop="@drawable/home_button3"/>

            </LinearLayout>

            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_weight="1">

                <Button android:id="@+id/btnHoreca"
                    style="@style/HomeButton"
                    android:onClick="onClickFeature"
                    android:text="@string/lblModulo4"
                    android:drawableTop="@drawable/home_button4"/>

                <Button android:id="@+id/btnFinanzas"
                    style="@style/HomeButton"
                    android:onClick="onClickFeature"
                    android:text="@string/lblModulo5"
                    android:drawableTop="@drawable/home_button5"/>

            </LinearLayout>

            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_weight="1">

                <Button android:id="@+id/rrhh"
                    style="@style/HomeButton"
                    android:onClick="onClickFeature"
                    android:text="RRHH"
                    android:drawableTop="@drawable/ic_rrhh"
                    android:background="@drawable/home_button_rrhh"/>

                <Button android:id="@+id/ventas"
                    style="@style/HomeButton"
                    android:onClick="onClickFeature"
                    android:text="@string/lblModulo6"
                    android:drawableTop="@drawable/home_button6"/>

            </LinearLayout>

            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_weight="1">

                <Button android:id="@+id/btnSIG"
                    style="@style/HomeButton"
                    android:onClick="onClickFeature"
                    android:text="@string/lblModulo7"
                    android:drawableTop="@drawable/home_button7"/>

                <Button android:id="@+id/btnSeguridad"
                    style="@style/HomeButton"
                    android:onClick="onClickFeature"
                    android:text="@string/lblModulo8"
                    android:drawableTop="@drawable/home_button8"/>

            </LinearLayout>

            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_weight="1">

                <Button android:id="@+id/btnConfiguracion"
                    style="@style/HomeButton"
                    android:onClick="onClickFeature"
                    android:text="@string/lblModulo9"
                    android:drawableTop="@drawable/home_button9"/>

                <Button android:id="@+id/btnSalir"
                    style="@style/HomeButton"
                    android:onClick="onClickFeature"
                    android:text="@string/lblModulo10"
                    android:drawableTop="@drawable/home_button10"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center">

        <TextView
            style="@style/MiTexto"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:text="Developer for Ing Jhonny Ramirez Chiroque" />

    </LinearLayout>

</LinearLayout>
