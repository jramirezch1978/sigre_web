<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <TextView
                    style="@style/RrhhCardHeaderBar"
                    android:text="👤 TRABAJADOR SELECCIONADO" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <include layout="@layout/include_rrhh_trabajador_card" />

                    <TextView
                        style="@style/RrhhFieldLabel"
                        android:text="BUSCAR TRABAJADOR" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_rrhh_search_row"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="6dp">

                        <EditText
                            android:id="@+id/etBuscarTrabajador"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:background="@null"
                            android:hint="DNI, código o nombre"
                            android:minHeight="44dp"
                            android:paddingStart="8dp"
                            android:paddingEnd="8dp"
                            android:textSize="16sp" />

                        <Button
                            android:id="@+id/btnBuscarTrabajador"
                            style="@style/RrhhButtonSearch"
                            android:text="BUSCAR" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="8dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    style="@style/RrhhCardHeaderBar"
                    android:text="💰 IMPORTES CALCULADOS" />

                <TextView
                    android:id="@+id/tvImportes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#FAFAFA"
                    android:lineSpacingExtra="4dp"
                    android:minHeight="120dp"
                    android:padding="16dp"
                    android:text="Guarde el jornal para ver importes calculados."
                    android:textColor="#424242"
                    android:textSize="15sp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>
</merge>
