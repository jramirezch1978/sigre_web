<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Activities.Almacen.AlmacenTransferenciaPPTTActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/llBottom"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="PARTE DE TRANSFERENCIA"
                android:textSize="20sp"
                android:textStyle="bold"
                android:background="@android:color/holo_blue_dark"
                android:textColor="@android:color/white"
                android:layout_marginBottom="2sp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView
                    android:id="@+id/tvFechaConteo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fecha Recepcion"
                    android:layout_gravity="center_vertical|left"
                    android:gravity="center"
                    android:textSize="25dp"/>
                <TextView
                    android:id="@+id/tvVersionName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="1.80.0"
                    android:gravity="right"
                    android:layout_gravity="center_vertical|right"
                    android:textSize="14dip"/>
            </LinearLayout>


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical|center_horizontal">

                <EditText
                    android:id="@+id/etFechaRecepcion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:singleLine="true"
                    android:paddingRight="10dip"
                    android:paddingLeft="10dip"
                    android:gravity="center"
                    android:text="00/00/0000"
                    android:textSize="25dp"
                    android:background="@drawable/rounded_edit_text"
                    android:inputType="date"
                    android:layout_weight="1"/>

                <ImageButton
                    android:id="@+id/ibObtenerFecha"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@mipmap/ic_event_white_24dp"
                    tools:ignore="ContentDescription" />

            </LinearLayout>


            <TextView
                android:id="@+id/tvText3"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="LEER NRO PALLET ORIGEN"
                android:textSize="25dp" />

            <EditText
                android:id="@+id/etNroPalletOrg"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="10dp"
                android:background="@drawable/rounded_edit_text"
                android:gravity="center"
                android:inputType="text"
                android:paddingLeft="10dip"
                android:paddingRight="10dip"
                android:singleLine="true"
                android:text="022002.0001"
                android:textSize="40dp" />

            <Button
                android:id="@+id/btnLeerPalletOrg"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Leer Pallet" />

        </LinearLayout>

        <TabHost
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:id="@+id/tabHost"
            android:layout_alignParentTop="true"
            android:layout_centerHorizontal="true">

            <LinearLayout
                android:layout_width="fill_parent"
                android:layout_height="fill_parent"
                android:orientation="vertical">

                <TabWidget
                    android:id="@android:id/tabs"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"></TabWidget>

                <FrameLayout
                    android:id="@android:id/tabcontent"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <LinearLayout
                        android:id="@+id/tab1"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:text="Punto de origen"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:background="@android:color/holo_blue_dark"
                            android:textColor="@android:color/white"
                            android:layout_marginBottom="5dip"/>

                        <ScrollView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scrollbars="vertical">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:paddingBottom="2sp"
                                android:paddingTop="2sp"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/tvAlmacenOrg"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="Almacen Origen"
                                    android:gravity="center"
                                    android:textSize="25dp"/>

                                <Spinner
                                    android:id="@+id/spAlmacenOrg"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginBottom="10sp"
                                    android:layout_weight="1"
                                    android:spinnerMode="dropdown" />

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:paddingBottom="2sp"
                                    android:paddingTop="2sp"
                                    android:orientation="vertical">

                                    <LinearLayout
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:orientation="horizontal">
                                        <TextView
                                            android:layout_width="150sp"
                                            android:layout_height="wrap_content"
                                            android:text="Anaquel Org :"
                                            android:id="@+id/textView03"
                                            android:textStyle="bold"
                                            android:textSize="20dp"
                                            android:gravity="right"/>

                                        <Spinner
                                            android:id="@+id/spAnaquelOrg"
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"
                                            android:layout_weight="1"
                                            android:spinnerMode="dropdown"
                                            android:textSize="25dp" />
                                    </LinearLayout>

                                    <LinearLayout
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:orientation="horizontal">

                                        <TextView
                                            android:layout_width="150sp"
                                            android:layout_height="wrap_content"
                                            android:text="Fila Org :"
                                            android:gravity="right"
                                            android:id="@+id/textView02"
                                            android:textSize="20dp"
                                            android:textStyle="bold" />

                                        <Spinner
                                            android:id="@+id/spFilaOrg"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_weight="1"
                                            android:spinnerMode="dropdown"
                                            android:textSize="25dp" />
                                    </LinearLayout>

                                    <LinearLayout
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:orientation="horizontal">

                                        <TextView
                                            android:layout_width="150sp"
                                            android:layout_height="wrap_content"
                                            android:text="Columna Org :"
                                            android:gravity="right"
                                            android:id="@+id/textView04"
                                            android:textSize="20dp"
                                            android:textStyle="bold" />

                                        <Spinner
                                            android:id="@+id/spColumnaOrg"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:spinnerMode="dropdown"
                                            android:layout_weight="1"
                                            android:textSize="25dp"/>

                                    </LinearLayout>

                                </LinearLayout>

                            </LinearLayout>



                        </ScrollView>


                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/tab2"
                        android:layout_width="fill_parent"
                        android:layout_height="fill_parent"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:text="Listado de Cajas"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:background="@android:color/holo_blue_dark"
                            android:textColor="@android:color/white"
                            android:layout_marginBottom="10sp"/>

                        <Button
                            android:id="@+id/btnListarCajas"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Listar Cajas" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">
                            <TextView
                                android:layout_width="150sp"
                                android:layout_height="wrap_content"
                                android:text="Nro de Cajas:"
                                android:gravity="right"/>

                            <TextView
                                android:layout_width="150sp"
                                android:layout_height="wrap_content"
                                android:id="@+id/tvNroRegistros"
                                android:text="0"
                                android:gravity="right"/>
                        </LinearLayout>

                        <ScrollView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scrollbars="vertical">

                            <LinearLayout
                                android:orientation="vertical"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content">



                                <ListView
                                    android:id="@+id/lvListadoCajas"
                                    android:layout_width="match_parent"
                                    android:layout_height="600dp"
                                    android:paddingBottom="10sp"
                                    android:scrollbars="vertical" />


                            </LinearLayout>

                        </ScrollView>

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/tab3"
                        android:layout_width="fill_parent"
                        android:layout_height="fill_parent"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:text="Punto de destino"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:background="@android:color/holo_blue_dark"
                            android:textColor="@android:color/white"
                            android:layout_marginBottom="10sp"/>

                        <ScrollView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scrollbars="vertical">

                            <LinearLayout
                                android:orientation="vertical"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content">



                                <TextView
                                    android:id="@+id/tvText4"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:gravity="center"
                                    android:text="NRO PALLET DESTINO"
                                    android:textSize="25dp" />

                                <EditText
                                    android:id="@+id/etNroPalletDst"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_margin="10dp"
                                    android:background="@drawable/rounded_edit_text"
                                    android:gravity="center"
                                    android:inputType="text"
                                    android:paddingLeft="10dip"
                                    android:paddingRight="10dip"
                                    android:singleLine="true"
                                    android:text="022002.0001"
                                    android:textSize="40dp" />

                                <Button
                                    android:id="@+id/btnLeerPalletDst"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="Leer Pallet" />

                                <TextView
                                    android:id="@+id/tvAlmacenDst"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="Almacen Destino"
                                    android:gravity="center"
                                    android:textSize="25dp"/>

                                <Spinner
                                    android:id="@+id/spAlmacenDst"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:spinnerMode="dropdown"
                                    android:layout_weight="1"/>

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:paddingBottom="2sp"
                                    android:paddingTop="2sp"
                                    android:orientation="vertical">

                                    <LinearLayout
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:orientation="horizontal">
                                        <TextView
                                            android:layout_width="150sp"
                                            android:layout_height="wrap_content"
                                            android:text="Anaquel Dst :"
                                            android:id="@+id/textView05"
                                            android:textStyle="bold"
                                            android:textSize="20dp"
                                            android:gravity="right"/>

                                        <Spinner
                                            android:id="@+id/spAnaquelDst"
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"
                                            android:spinnerMode="dropdown"
                                            android:layout_weight="1"
                                            android:textSize="25dp"/>
                                    </LinearLayout>

                                    <LinearLayout
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:orientation="horizontal">

                                        <TextView
                                            android:layout_width="150sp"
                                            android:layout_height="wrap_content"
                                            android:text="Fila Dst :"
                                            android:gravity="right"
                                            android:id="@+id/textView06"
                                            android:textSize="20dp"
                                            android:textStyle="bold" />

                                        <Spinner
                                            android:id="@+id/spFilaDst"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:spinnerMode="dropdown"
                                            android:layout_weight="1"
                                            android:textSize="25dp"/>
                                    </LinearLayout>

                                    <LinearLayout
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:orientation="horizontal">

                                        <TextView
                                            android:layout_width="150sp"
                                            android:layout_height="wrap_content"
                                            android:text="Columna Dst :"
                                            android:gravity="right"
                                            android:id="@+id/textView07"
                                            android:textSize="20dp"
                                            android:textStyle="bold" />

                                        <Spinner
                                            android:id="@+id/spColumnaDst"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:spinnerMode="dropdown"
                                            android:layout_weight="1"
                                            android:textSize="25dp"/>

                                    </LinearLayout>

                                </LinearLayout>

                            </LinearLayout>

                        </ScrollView>

                    </LinearLayout>
                </FrameLayout>
            </LinearLayout>
        </TabHost>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingBottom="10dp"
        android:paddingTop="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        android:background="?android:attr/windowBackground"
        android:id="@+id/llBottom">


        <TextView
            android:id="@+id/tvMensaje"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="Registro grabado correcamente"
            android:textSize="15dp"
            android:textColor="@android:color/holo_red_dark"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <Button
                android:id="@+id/btnSalir"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Salir" />

            <Button
                android:id="@+id/btnTransferir"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Transferir" />
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>