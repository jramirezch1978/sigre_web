<?xml version="1.0" encoding="utf-8"?>
<!-- Fila tipo POS para el detalle del pedido en portrait -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/llPedidoItemRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="#FFFFFF"
    android:paddingStart="0dp"
    android:paddingEnd="8dp"
    android:paddingTop="8dp"
    android:paddingBottom="8dp"
    android:descendantFocusability="blocksDescendants">

    <View
        android:id="@+id/vAccent"
        android:layout_width="4dp"
        android:layout_height="match_parent"
        android:layout_marginEnd="10dp"
        android:background="#1976D2" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvItemNro"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="28dp"
                android:gravity="center"
                android:paddingLeft="6dp"
                android:paddingRight="6dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:background="#E3F2FD"
                android:textColor="#0D47A1"
                android:textStyle="bold"
                android:textSize="12sp"
                android:text="1" />

            <TextView
                android:id="@+id/tvItemDescripcion"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:textColor="#212121"
                android:textStyle="bold"
                android:textSize="14sp"
                android:maxLines="2"
                android:ellipsize="end"
                android:text="Descripción del artículo" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvItemMeta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="#616161"
            android:textSize="12sp"
            android:text="Almacén · Unidad" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvItemCantidad"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="#37474F"
                android:textSize="13sp"
                android:text="0.00 UND × S/ 0.00" />

            <TextView
                android:id="@+id/tvItemSubTotal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#0D47A1"
                android:textStyle="bold"
                android:textSize="16sp"
                android:text="S/ 0.00" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvItemExtra"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:textColor="#757575"
            android:textSize="11sp"
            android:text="IGV · Bolsa · ICBPER" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingStart="4dp">

        <ImageButton
            android:id="@+id/ibItemSelect"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@android:color/transparent"
            android:scaleType="fitCenter"
            android:src="@drawable/rombo"
            android:contentDescription="Seleccionar" />

        <ImageButton
            android:id="@+id/ibItemEditar"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@android:color/transparent"
            android:scaleType="fitCenter"
            android:src="@drawable/editar"
            android:contentDescription="Editar precio" />

        <ImageButton
            android:id="@+id/ibItemEliminar"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@android:color/transparent"
            android:scaleType="fitCenter"
            android:src="@drawable/cancelar"
            android:contentDescription="Eliminar" />
    </LinearLayout>
</LinearLayout>
