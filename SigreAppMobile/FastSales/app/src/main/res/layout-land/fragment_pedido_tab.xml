<?xml version="1.0" encoding="utf-8"?>
<!-- Landscape: misma raíz DrawerLayout que portrait (data binding + restore state).
     Contenido en dos columnas; llBusqueda NO es panel drawer (sin layout_gravity). -->
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/drawerArticulos"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal">

    <!-- Búsqueda más estrecha (~32%); la tabla del pedido gana espacio (~68%). -->
    <LinearLayout
        android:id="@+id/llBusqueda"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="32"
        android:orientation="vertical"
        android:background="#E3F2FD">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:orientation="horizontal"
            android:background="#1976D2">

            <ImageButton
                android:id="@+id/ibOcultarBusqueda"
                android:layout_width="40dp"
                android:layout_height="match_parent"
                android:src="@drawable/ocultar"
                android:scaleType="fitCenter"
                android:padding="0dp"
                android:background="@android:color/transparent" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:text="Buscar: "
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:gravity="center_vertical|end" />

            <EditText
                android:id="@+id/etFiltro"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:singleLine="true"
                android:paddingLeft="5dp"
                android:paddingRight="5dp"
                android:background="@drawable/rounded_edit_text" />

            <Button
                android:id="@+id/btnBuscar"
                style="@style/PedidoButton.Primary"
                android:layout_height="match_parent"
                android:layout_marginLeft="5dp"
                android:layout_marginEnd="4dp"
                android:text="Buscar" />
        </LinearLayout>

        <ListView
            android:id="@+id/lvListaArticulos"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@android:color/white" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="20dp"
            android:orientation="horizontal"
            android:background="#BBDEFB"
            android:gravity="end">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:text="Total Registros: "
                android:textColor="#1976D2"
                android:gravity="center_vertical" />

            <TextView
                android:id="@+id/tvTotalRegistros"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:text="0"
                android:textColor="#1976D2"
                android:layout_marginRight="20dp"
                android:gravity="center_vertical" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="68"
        android:orientation="vertical"
        android:background="#E3F2FD">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#1976D2"
            android:gravity="center_horizontal"
            android:padding="4dp">

            <TextView
                android:id="@+id/tvCaption"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ULTIMA PROFORMA GENERADA: "
                android:textColor="@android:color/white"
                android:textStyle="bold" />
        </LinearLayout>

        <HorizontalScrollView
            android:id="@+id/hsvPedidoDetalle"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@android:color/white"
            android:scrollbars="horizontal"
            android:fadeScrollbars="false"
            android:scrollbarStyle="outsideInset"
            android:fillViewport="false">

            <ScrollView
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:scrollbars="vertical"
                android:fadeScrollbars="false">

                <TableLayout
                    android:id="@+id/tablePedido"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </ScrollView>
        </HorizontalScrollView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#E3F2FD"
            android:gravity="end"
            android:padding="4dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Base Imponible: "
                    android:layout_marginRight="10dp" />

                <TextView
                    android:id="@+id/tvMonedaBI"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="S/"
                    android:layout_marginRight="5dp" />

                <TextView
                    android:id="@+id/tvBaseImponible"
                    android:layout_width="60dp"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical|end"
                    android:text="0.00"
                    android:layout_marginRight="10dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="IGV: "
                    android:layout_marginRight="10dp" />

                <TextView
                    android:id="@+id/tvMonedaIGV"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="S/"
                    android:layout_marginRight="5dp" />

                <TextView
                    android:id="@+id/tvIGV"
                    android:layout_width="60dp"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical|end"
                    android:text="0.00"
                    android:layout_marginRight="10dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Importe Venta: "
                    android:layout_marginRight="10dp" />

                <TextView
                    android:id="@+id/tvMonedaVta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="S/"
                    android:layout_marginRight="5dp" />

                <TextView
                    android:id="@+id/tvImporteVenta"
                    android:layout_width="60dp"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical|end"
                    android:text="0.00"
                    android:layout_marginRight="10dp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@android:color/white"
            android:padding="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:text="Tipo Comprobante: "
                android:gravity="center_vertical" />

            <RadioGroup
                android:id="@+id/rgFlagFacturaBoleta"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center">

                <RadioButton
                    android:id="@+id/rbFactura"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:text="Factura" />

                <RadioButton
                    android:id="@+id/rbBoleta"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:text="Boleta" />

                <RadioButton
                    android:id="@+id/rbNotaVenta"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:text="Nota Venta" />
            </RadioGroup>
        </LinearLayout>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:fillViewport="true"
            android:background="@android:color/white">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="end|center_vertical"
                android:padding="6dp">

                <Button
                    android:id="@+id/btnMostrarBusqueda"
                    style="@style/PedidoButton.Primary"
                    android:visibility="gone"
                    android:text="Añadir artículo" />

                <Button
                    android:id="@+id/btnLecturaQR"
                    style="@style/PedidoButton.Secondary"
                    android:text="Lectura código" />

                <Button
                    android:id="@+id/btnLimpiarPedido"
                    style="@style/PedidoButton.Muted"
                    android:text="Limpiar" />

                <Button
                    android:id="@+id/btnGrabar"
                    style="@style/PedidoButton.Success"
                    android:text="Grabar" />

                <Button
                    android:id="@+id/btnSalir"
                    style="@style/PedidoButton.Danger"
                    android:layout_marginEnd="0dp"
                    android:text="Salir" />
            </LinearLayout>
        </HorizontalScrollView>
    </LinearLayout>
</LinearLayout>
</androidx.drawerlayout.widget.DrawerLayout>
