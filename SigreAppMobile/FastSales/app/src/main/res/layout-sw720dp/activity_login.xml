<?xml version="1.0" encoding="utf-8"?>
<!-- Layout optimizado para tablets 10" (720dp width) -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/login_background"
    android:fitsSystemWindows="true">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="48dp">

            <!-- Card contenedor con ancho máximo de 600dp para tablets grandes -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                android:layout_marginBottom="40dp"
                android:maxWidth="600dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="16dp"
                app:cardMaxElevation="20dp"
                app:cardUseCompatPadding="true"
                android:layout_marginStart="64dp"
                android:layout_marginEnd="64dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@color/login_card_background"
                    android:padding="48dp">

                    <!-- Logo más grande para tablets -->
                    <ImageView
                        android:id="@+id/ivLogo"
                        android:src="@drawable/sigre"
                        android:layout_width="match_parent"
                        android:layout_height="200dp"
                        android:layout_marginTop="24dp"
                        android:layout_marginBottom="16dp"
                        android:scaleType="fitCenter"
                        android:contentDescription="Logo SIGRE" />

                    <!-- Versión -->
                    <TextView
                        android:id="@+id/tvVersionName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="1.80.0"
                        android:gravity="end"
                        android:textSize="16sp"
                        android:textColor="@color/login_text_secondary"
                        android:layout_marginBottom="40dp"
                        android:fontFamily="sans-serif-medium" />

                    <!-- Título -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Iniciar Sesión"
                        android:textSize="32sp"
                        android:textColor="@color/login_text_primary"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:layout_marginBottom="40dp"
                        android:fontFamily="sans-serif" />

                    <!-- Campo Usuario -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilUsuario"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="24dp"
                        app:boxBackgroundMode="outline"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxStrokeColor="@color/login_primary"
                        app:boxStrokeWidth="2dp"
                        app:hintTextColor="@color/login_primary"
                        app:startIconDrawable="@android:drawable/ic_menu_myplaces"
                        app:startIconTint="@color/login_primary">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etUsuario"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="text"
                            android:hint="Usuario"
                            android:textSize="20sp"
                            android:textColor="@color/login_text_primary"
                            android:textColorHint="@color/login_text_hint"
                            android:singleLine="true"
                            android:paddingTop="18dp"
                            android:paddingBottom="18dp" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Campo Password -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilClave"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="40dp"
                        app:boxBackgroundMode="outline"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxStrokeColor="@color/login_primary"
                        app:boxStrokeWidth="2dp"
                        app:hintTextColor="@color/login_primary"
                        app:startIconDrawable="@android:drawable/ic_lock_lock"
                        app:startIconTint="@color/login_primary"
                        app:endIconMode="password_toggle"
                        app:endIconTint="@color/login_text_secondary">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etClave"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPassword"
                            android:hint="Contraseña"
                            android:textSize="20sp"
                            android:textColor="@color/login_text_primary"
                            android:textColorHint="@color/login_text_hint"
                            android:singleLine="true"
                            android:paddingTop="18dp"
                            android:paddingBottom="18dp" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Sección Servidor -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Configuración de Conexión"
                        android:textSize="18sp"
                        android:textColor="@color/login_text_secondary"
                        android:textStyle="bold"
                        android:layout_marginBottom="20dp"
                        android:layout_marginTop="16dp" />

                    <!-- Servidor por defecto -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="20dp">

                        <TextView
                            android:layout_width="160dp"
                            android:layout_height="wrap_content"
                            android:text="Servidor:"
                            android:textSize="17sp"
                            android:textColor="@color/login_text_primary"
                            android:gravity="start"
                            android:layout_marginEnd="16dp" />

                        <Button
                            android:id="@+id/btnServerDefault"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:textSize="16sp"
                            android:textColor="@color/login_text_primary"
                            android:background="@drawable/login_button_config"
                            android:paddingStart="20dp"
                            android:paddingEnd="20dp"
                            android:paddingTop="14dp"
                            android:paddingBottom="14dp"
                            android:textAllCaps="false"
                            android:ellipsize="end"
                            android:maxLines="1" />

                        <ImageButton
                            android:id="@+id/btnRefrescar"
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:layout_marginStart="16dp"
                            android:background="@drawable/login_button_config"
                            android:src="@drawable/icon_reload"
                            android:scaleType="centerInside"
                            android:padding="12dp"
                            android:contentDescription="Refrescar" />

                    </LinearLayout>

                    <!-- Empresa seleccionada -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="32dp">

                        <TextView
                            android:layout_width="160dp"
                            android:layout_height="wrap_content"
                            android:text="Empresa:"
                            android:textSize="17sp"
                            android:textColor="@color/login_text_primary"
                            android:gravity="start"
                            android:layout_marginEnd="16dp" />

                        <Button
                            android:id="@+id/btnEmpresaDefault"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:textSize="16sp"
                            android:textColor="@color/login_text_primary"
                            android:background="@drawable/login_button_config"
                            android:paddingStart="20dp"
                            android:paddingEnd="20dp"
                            android:paddingTop="14dp"
                            android:paddingBottom="14dp"
                            android:textAllCaps="false"
                            android:ellipsize="end"
                            android:maxLines="1" />

                    </LinearLayout>

                    <!-- Mensaje de Error -->
                    <TextView
                        android:id="@+id/tvMensajeError"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="@color/login_error"
                        android:textSize="16sp"
                        android:gravity="start"
                        android:visibility="gone"
                        android:layout_marginBottom="24dp"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"
                        android:paddingTop="14dp"
                        android:paddingBottom="14dp"
                        android:background="#FFEBEE"
                        android:drawableStart="@android:drawable/ic_dialog_alert"
                        android:drawablePadding="16dp"
                        android:drawableTint="@color/login_error" />

                    <!-- Botones -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="16dp"
                        android:gravity="center">

                        <Button
                            android:id="@+id/btnLogin"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Ingresar"
                            android:textSize="20sp"
                            android:textColor="@color/login_button_text"
                            android:textStyle="bold"
                            android:background="@drawable/login_button_primary"
                            android:paddingTop="18dp"
                            android:paddingBottom="18dp"
                            android:layout_marginEnd="16dp"
                            android:textAllCaps="false"
                            android:onClick="Ingresar"
                            android:elevation="3dp" />

                        <Button
                            android:id="@+id/btnCancelar"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Salir"
                            android:textSize="20sp"
                            android:textColor="@color/login_primary"
                            android:textStyle="bold"
                            android:background="@drawable/login_button_secondary"
                            android:paddingTop="18dp"
                            android:paddingBottom="18dp"
                            android:layout_marginStart="16dp"
                            android:textAllCaps="false"
                            android:onClick="Salir" />

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </ScrollView>

</LinearLayout>
