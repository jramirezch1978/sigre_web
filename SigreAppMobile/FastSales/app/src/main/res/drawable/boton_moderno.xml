<?xml version="1.0" encoding="utf-8"?>
<!-- res/drawable/boton_moderno.xml -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/colorPrimaryDark" /> <!-- Color al presionar -->
            <corners android:radius="50dp" /> <!-- Bordes redondeados -->
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/colorPrimary" /> <!-- Color de fondo normal -->
            <corners android:radius="50dp" /> <!-- Bordes redondeados -->
        </shape>
    </item>
</selector>
