<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.Hermes" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/hermes_ink</item>
        <item name="colorPrimaryVariant">@color/hermes_ink_deep</item>
        <item name="colorPrimaryDark">@color/hermes_ink_deep</item>
        <item name="colorSecondary">@color/hermes_copper</item>
        <item name="colorSecondaryVariant">@color/hermes_copper_soft</item>
        <item name="colorAccent">@color/hermes_copper</item>
        <item name="colorOnPrimary">@color/hermes_on_ink</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorSurface">@color/hermes_surface_elevated</item>
        <item name="colorOnSurface">@color/hermes_text</item>
        <item name="android:colorBackground">@color/hermes_mist</item>
        <item name="android:windowBackground">@drawable/bg_hermes_atmosphere</item>
        <item name="android:statusBarColor">@color/hermes_ink_deep</item>
        <item name="android:navigationBarColor">@color/hermes_ink_deep</item>
        <item name="android:fontFamily">@font/font_dm_sans</item>
        <item name="fontFamily">@font/font_dm_sans</item>
        <item name="materialButtonStyle">@style/Widget.Hermes.Button</item>
        <item name="toolbarStyle">@style/Widget.Hermes.Toolbar</item>
        <item name="textInputStyle">@style/Widget.Hermes.TextInput</item>
        <item name="floatingActionButtonStyle">@style/Widget.Hermes.Fab</item>
    </style>

    <style name="Theme.Hermes.DialogSeleccion" parent="Theme.MaterialComponents.DayNight.Dialog.Alert">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:backgroundDimAmount">0.55</item>
        <item name="colorPrimary">@color/hermes_ink</item>
        <item name="colorSecondary">@color/hermes_copper</item>
        <item name="android:fontFamily">@font/font_dm_sans</item>
    </style>
</resources>
