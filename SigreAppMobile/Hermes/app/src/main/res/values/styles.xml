<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Widget.Hermes.Toolbar" parent="Widget.MaterialComponents.Toolbar.Primary">
        <item name="android:background">@drawable/bg_toolbar_hermes</item>
        <item name="titleTextColor">@color/hermes_on_ink</item>
        <item name="subtitleTextColor">@color/hermes_mist</item>
        <item name="navigationIconTint">@color/hermes_on_ink</item>
        <item name="titleTextAppearance">@style/TextAppearance.Hermes.Toolbar.Title</item>
    </style>

    <style name="TextAppearance.Hermes.Toolbar.Title" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:fontFamily">@font/font_sora</item>
        <item name="fontFamily">@font/font_sora</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textColor">@color/hermes_on_ink</item>
        <item name="android:letterSpacing">0.02</item>
    </style>

    <style name="TextAppearance.Hermes.Brand" parent="TextAppearance.MaterialComponents.Headline4">
        <item name="android:fontFamily">@font/font_sora</item>
        <item name="fontFamily">@font/font_sora</item>
        <item name="android:textSize">34sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/hermes_ink</item>
        <item name="android:letterSpacing">0.08</item>
    </style>

    <style name="TextAppearance.Hermes.Title" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:fontFamily">@font/font_sora</item>
        <item name="fontFamily">@font/font_sora</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textColor">@color/hermes_text</item>
    </style>

    <style name="TextAppearance.Hermes.Body" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:fontFamily">@font/font_dm_sans</item>
        <item name="fontFamily">@font/font_dm_sans</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textColor">@color/hermes_text</item>
    </style>

    <style name="TextAppearance.Hermes.Caption" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:fontFamily">@font/font_dm_sans</item>
        <item name="fontFamily">@font/font_dm_sans</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/hermes_text_muted</item>
    </style>

    <style name="Widget.Hermes.Button" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/hermes_ink</item>
        <item name="android:textColor">@color/hermes_on_ink</item>
        <item name="cornerRadius">10dp</item>
        <item name="android:fontFamily">@font/font_sora</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="android:minHeight">48dp</item>
    </style>

    <style name="Widget.Hermes.Button.Accent" parent="Widget.Hermes.Button">
        <item name="backgroundTint">@color/hermes_copper</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="Widget.Hermes.Button.Text" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textColor">@color/hermes_teal</item>
        <item name="android:fontFamily">@font/font_dm_sans</item>
    </style>

    <style name="Widget.Hermes.TextInput" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/hermes_teal</item>
        <item name="hintTextColor">@color/hermes_teal</item>
        <item name="android:textColorHint">@color/hermes_text_muted</item>
    </style>

    <style name="Widget.Hermes.Fab" parent="Widget.MaterialComponents.FloatingActionButton">
        <item name="backgroundTint">@color/hermes_copper</item>
        <item name="tint">@color/white</item>
        <item name="borderWidth">0dp</item>
    </style>
</resources>
