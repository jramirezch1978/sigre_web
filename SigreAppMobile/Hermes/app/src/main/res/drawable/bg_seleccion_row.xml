<?xml version="1.0" encoding="utf-8"?>
<!-- Misma regla de branding: filas continuas, solo divisor inferior. -->
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="#331A5C61">
    <item>
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="@color/hermes_surface_elevated" />
                </shape>
            </item>
            <item android:gravity="bottom">
                <shape android:shape="rectangle">
                    <size android:height="1dp" />
                    <solid android:color="@color/hermes_line" />
                </shape>
            </item>
        </layer-list>
    </item>
</ripple>
