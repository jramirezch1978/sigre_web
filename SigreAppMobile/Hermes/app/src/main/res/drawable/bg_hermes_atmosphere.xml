<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="165"
                android:startColor="#EAF3F4"
                android:centerColor="#DCEAED"
                android:endColor="#CFE0E2"
                android:type="linear" />
        </shape>
    </item>
    <item
        android:top="-120dp"
        android:right="-80dp">
        <shape android:shape="oval">
            <size
                android:width="280dp"
                android:height="280dp" />
            <solid android:color="#331A5C61" />
        </shape>
    </item>
    <item
        android:bottom="-100dp"
        android:left="-60dp">
        <shape android:shape="oval">
            <size
                android:width="240dp"
                android:height="240dp" />
            <solid android:color="#22C47A3A" />
        </shape>
    </item>
</layer-list>
