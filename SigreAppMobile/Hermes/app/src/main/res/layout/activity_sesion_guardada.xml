<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_hermes_atmosphere"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="28dp">

        <ImageView
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:layout_marginTop="32dp"
            android:contentDescription="@string/brand_name"
            android:src="@drawable/logo_hermes" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:letterSpacing="0.1"
            android:text="@string/brand_name"
            android:textAppearance="@style/TextAppearance.Hermes.Brand"
            android:textSize="28sp" />

        <View
            android:layout_width="40dp"
            android:layout_height="3dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_brand_accent_bar" />

        <TextView
            android:id="@+id/tvSaludo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:fontFamily="@font/font_sora"
            android:textColor="@color/hermes_ink"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvNombreUsuario"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:fontFamily="@font/font_dm_sans"
            android:textColor="@color/hermes_text"
            android:textSize="17sp" />

        <TextView
            android:id="@+id/tvEmpresaSucursal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:textAppearance="@style/TextAppearance.Hermes.Caption"
            android:textSize="14sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center"
            android:text="@string/sesion_guardada_subtitulo"
            android:textAppearance="@style/TextAppearance.Hermes.Caption"
            android:textSize="14sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnContinuar"
            style="@style/Widget.Hermes.Button.Accent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="@string/sesion_guardada_continuar" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCambiarCuenta"
            style="@style/Widget.Hermes.Button.Text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/sesion_guardada_cambiar" />

        <TextView
            android:id="@+id/tvVersion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:textAppearance="@style/TextAppearance.Hermes.Caption" />
    </LinearLayout>
</ScrollView>
