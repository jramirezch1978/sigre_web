<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_hermes_atmosphere">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingHorizontal="32dp">

        <ImageView
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:contentDescription="@string/brand_name"
            android:src="@drawable/logo_hermes" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:letterSpacing="0.12"
            android:text="@string/brand_name"
            android:textAppearance="@style/TextAppearance.Hermes.Brand" />

        <View
            android:layout_width="48dp"
            android:layout_height="3dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_brand_accent_bar" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/brand_tagline"
            android:textAppearance="@style/TextAppearance.Hermes.Caption"
            android:textSize="14sp" />

        <ProgressBar
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="36dp"
            android:indeterminateTint="@color/hermes_teal" />

        <TextView
            android:id="@+id/tvEstado"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:paddingHorizontal="24dp"
            android:text="Cargando…"
            android:textAppearance="@style/TextAppearance.Hermes.Caption" />

        <LinearLayout
            android:id="@+id/grupoAcciones"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="gone">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnReintentar"
                style="@style/Widget.Hermes.Button.Accent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/reintentar" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnConfigurarServidor"
                style="@style/Widget.Hermes.Button.Text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/splash_configurar_servidor"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/tvVersion"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:text="Version: —"
        android:textAppearance="@style/TextAppearance.Hermes.Caption" />

</FrameLayout>
