<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_hermes_atmosphere"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        style="@style/Widget.Hermes.Toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@drawable/bg_toolbar_hermes"
        app:navigationIconTint="@color/hermes_on_ink"
        app:titleTextColor="@color/hermes_on_ink" />

    <TextView
        android:id="@+id/tvMensaje"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="@font/font_dm_sans"
        android:lineSpacingExtra="4dp"
        android:padding="20dp"
        android:textColor="@color/hermes_text_muted"
        android:textSize="14sp" />
</LinearLayout>
