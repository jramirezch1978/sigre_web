<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_hermes_atmosphere"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="28dp"
        android:paddingBottom="28dp">

        <!-- Marca hero: sin card — logo + HERMES + tagline -->
        <ImageView
            android:layout_width="112dp"
            android:layout_height="112dp"
            android:contentDescription="@string/brand_name"
            android:src="@drawable/logo_hermes" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:letterSpacing="0.12"
            android:text="@string/brand_name"
            android:textAppearance="@style/TextAppearance.Hermes.Brand" />

        <View
            android:layout_width="40dp"
            android:layout_height="3dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_brand_accent_bar" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/brand_tagline"
            android:textAppearance="@style/TextAppearance.Hermes.Caption"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="end"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvVersion"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="start"
                android:text="Version: —"
                android:textAppearance="@style/TextAppearance.Hermes.Caption" />

            <ImageView
                android:layout_width="48dp"
                android:layout_height="wrap_content"
                android:adjustViewBounds="true"
                android:contentDescription="Perú"
                android:src="@drawable/logo_peru" />
        </LinearLayout>

        <!-- Formulario (interacción) -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="@color/hermes_surface_elevated"
            app:cardCornerRadius="14dp"
            app:cardElevation="2dp"
            app:strokeColor="@color/hermes_line"
            app:strokeWidth="1dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/login_titulo"
                            android:textAppearance="@style/TextAppearance.Hermes.Title" />

                        <LinearLayout
                            android:id="@+id/badgeConexion"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/badge_disconnected_bg"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingStart="10dp"
                            android:paddingTop="5dp"
                            android:paddingEnd="10dp"
                            android:paddingBottom="5dp">

                            <ImageView
                                android:id="@+id/ivEstadoConexion"
                                android:layout_width="14dp"
                                android:layout_height="14dp"
                                android:contentDescription="@null"
                                android:src="@drawable/ic_wifi_disconnected" />

                            <TextView
                                android:id="@+id/tvBadgeConexion"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="6dp"
                                android:text="Verificando…"
                                android:textColor="#F44336"
                                android:textSize="11sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvNroRegistro"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:gravity="end"
                        android:text="@string/login_nro_registro_pendiente"
                        android:textAppearance="@style/TextAppearance.Hermes.Caption"
                        android:textStyle="bold" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilUsuario"
                        style="@style/Widget.Hermes.TextInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        app:startIconDrawable="@drawable/ic_person"
                        app:startIconTint="@color/hermes_teal">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etUsuario"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/login_usuario_hint"
                            android:inputType="textEmailAddress" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilClave"
                        style="@style/Widget.Hermes.TextInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        app:endIconMode="password_toggle"
                        app:passwordToggleEnabled="true"
                        app:startIconDrawable="@drawable/ic_lock"
                        app:startIconTint="@color/hermes_teal">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etClave"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/login_clave_hint"
                            android:inputType="textPassword" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:layout_marginBottom="8dp"
                        android:text="@string/login_servidor_titulo"
                        android:textAppearance="@style/TextAppearance.Hermes.Caption"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tvServidorNombre"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="8dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_box_outline"
                            android:gravity="center"
                            android:paddingTop="10dp"
                            android:paddingBottom="10dp"
                            android:text="(sin configurar)"
                            android:textColor="@color/hermes_text"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <ImageButton
                            android:id="@+id/btnCambiarServidor"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_marginEnd="8dp"
                            android:background="@drawable/bg_badge_neutral"
                            android:backgroundTint="@color/hermes_ink"
                            android:contentDescription="Cambiar servidor"
                            android:padding="9dp"
                            android:src="@drawable/ic_swap" />

                        <ImageButton
                            android:id="@+id/btnRefrescarServidor"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@drawable/bg_badge_neutral"
                            android:backgroundTint="@color/hermes_ink"
                            android:contentDescription="Refrescar perfiles de conexión"
                            android:padding="9dp"
                            android:src="@drawable/ic_refresh" />
                    </LinearLayout>

                    <ProgressBar
                        android:id="@+id/progressRefrescarServidor"
                        style="?android:attr/progressBarStyleSmall"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="end"
                        android:layout_marginTop="4dp"
                        android:indeterminateTint="@color/hermes_teal"
                        android:visibility="gone" />

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switchGuardarSesion"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:checked="false"
                        android:text="@string/login_guardar_sesion"
                        android:textColor="@color/hermes_text"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/login_guardar_sesion_ayuda"
                        android:textAppearance="@style/TextAppearance.Hermes.Caption" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnLogin"
                        style="@style/Widget.Hermes.Button.Accent"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="22dp"
                        android:text="@string/login_boton" />

                    <ProgressBar
                        android:id="@+id/progressLogin"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="16dp"
                        android:indeterminateTint="@color/hermes_teal"
                        android:visibility="gone" />

                </LinearLayout>
            </FrameLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</ScrollView>
