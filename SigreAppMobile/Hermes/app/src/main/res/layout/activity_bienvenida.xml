<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_hermes_atmosphere">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingHorizontal="28dp">

        <ImageView
            android:id="@+id/ivLogoBienvenida"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:contentDescription="@string/brand_name"
            android:src="@drawable/logo_hermes" />

        <TextView
            android:id="@+id/tvSaludo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:fontFamily="@font/font_sora"
            android:text="¡Buenos días!"
            android:textColor="@color/hermes_ink"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvNombreUsuario"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:fontFamily="@font/font_dm_sans"
            android:text="@string/bienvenida_usuario_default"
            android:textColor="@color/hermes_text"
            android:textSize="18sp" />

        <View
            android:layout_width="48dp"
            android:layout_height="3dp"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_brand_accent_bar" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="@string/bienvenida_a"
            android:textAppearance="@style/TextAppearance.Hermes.Caption"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvNombreEmpresa"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:ellipsize="end"
            android:fontFamily="@font/font_sora"
            android:gravity="center"
            android:maxLines="2"
            android:text="@string/brand_name"
            android:textColor="@color/hermes_ink"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvSucursal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textAppearance="@style/TextAppearance.Hermes.Caption"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tvHoraActual"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:fontFamily="monospace"
            android:textColor="@color/hermes_text_muted"
            android:textSize="15sp" />

        <ProgressBar
            android:id="@+id/progressBienvenida"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:layout_marginTop="28dp"
            android:indeterminate="false"
            android:max="100"
            android:progress="0"
            android:progressTint="@color/hermes_copper" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvVersion"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="16dp"
        android:textAppearance="@style/TextAppearance.Hermes.Caption" />
</FrameLayout>
