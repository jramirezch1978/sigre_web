<?xml version="1.0" encoding="UTF-8"?>
<!--
  Subreporte reutilizable: Header completo para reportes de la empresa.
  Incluye logo, datos de empresa, título del reporte (3 niveles) y metadatos (3 niveles).

  PARÁMETROS del subreporte:
    logoSubreport    - JasperReport compilado del logo_container
    logoImage        - InputStream con la imagen del logo
    logoSize         - String: "S" | "M" | "L" (default: "M")
    empresaNombre    - String: Razón social de la empresa
    empresaRuc       - String: RUC de la empresa
    reporteTitulo    - String: Título principal del reporte
    anio             - Integer: Año del reporte
    mes              - Integer: Mes del reporte (1-12)
    mesNombre        - String: Nombre del mes (ej: "ENERO")
    subtitulo        - String: Subtítulo adicional del reporte
    usuario          - String: Nombre del usuario que genera el reporte
-->
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
                                  http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="header_empresa" pageWidth="1063" pageHeight="80"
              columnWidth="1063" leftMargin="0" rightMargin="0"
              topMargin="0" bottomMargin="0">

    <parameter name="logoSubreport" class="net.sf.jasperreports.engine.JasperReport"/>
    <parameter name="logoImage" class="java.io.InputStream"/>
    <parameter name="logoSize" class="java.lang.String">
        <defaultValueExpression><![CDATA["M"]]></defaultValueExpression>
    </parameter>
    <parameter name="empresaNombre" class="java.lang.String"/>
    <parameter name="empresaRuc" class="java.lang.String"/>
    <parameter name="reporteTitulo" class="java.lang.String"/>
    <parameter name="anio" class="java.lang.Integer"/>
    <parameter name="mes" class="java.lang.Integer"/>
    <parameter name="mesNombre" class="java.lang.String"/>
    <parameter name="subtitulo" class="java.lang.String"/>
    <parameter name="usuario" class="java.lang.String"/>

    <title>
        <band height="80" splitType="Stretch">
            
            <!-- ══════════════════════════════════════════════════════════════ -->
            <!-- SECCIÓN IZQUIERDA: Logo + Datos Empresa (x=0, width=250)      -->
            <!-- ══════════════════════════════════════════════════════════════ -->
            
            <!-- Logo (subreporte reutilizable) -->
            <subreport>
                <reportElement x="0" y="0" width="150" height="45"/>
                <subreportParameter name="logoImage">
                    <subreportParameterExpression><![CDATA[$P{logoImage}]]></subreportParameterExpression>
                </subreportParameter>
                <subreportParameter name="logoSize">
                    <subreportParameterExpression><![CDATA[$P{logoSize}]]></subreportParameterExpression>
                </subreportParameter>
                <dataSourceExpression><![CDATA[new net.sf.jasperreports.engine.JREmptyDataSource()]]></dataSourceExpression>
                <subreportExpression><![CDATA[$P{logoSubreport}]]></subreportExpression>
            </subreport>
            
            <!-- Razón Social -->
            <textField isBlankWhenNull="true">
                <reportElement x="0" y="48" width="250" height="12"/>
                <textElement verticalAlignment="Middle">
                    <font size="9" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{empresaNombre}]]></textFieldExpression>
            </textField>
            
            <!-- RUC -->
            <textField isBlankWhenNull="true">
                <reportElement x="0" y="60" width="250" height="10"/>
                <textElement verticalAlignment="Middle">
                    <font size="7"/>
                </textElement>
                <textFieldExpression><![CDATA["Ruc: " + $P{empresaRuc}]]></textFieldExpression>
            </textField>
            
            <!-- ══════════════════════════════════════════════════════════════ -->
            <!-- SECCIÓN CENTRAL: Título (3 niveles) (x=300, width=500)        -->
            <!-- ══════════════════════════════════════════════════════════════ -->
            
            <!-- Nivel 1: Título Principal -->
            <textField isBlankWhenNull="true">
                <reportElement x="300" y="5" width="500" height="16"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="12" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{reporteTitulo}]]></textFieldExpression>
            </textField>
            
            <!-- Nivel 2: Año y Mes -->
            <textField isBlankWhenNull="true">
                <reportElement x="300" y="23" width="500" height="12"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="9"/>
                </textElement>
                <textFieldExpression><![CDATA["Año : " + $P{anio} + "          Mes : " + String.format("%02d", $P{mes}) + " " + $P{mesNombre}]]></textFieldExpression>
            </textField>
            
            <!-- Nivel 3: Subtítulo (puede ser multilinea) -->
            <textField isBlankWhenNull="true">
                <reportElement x="300" y="37" width="500" height="30"/>
                <textElement textAlignment="Center" verticalAlignment="Top">
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{subtitulo}]]></textFieldExpression>
            </textField>
            
            <!-- ══════════════════════════════════════════════════════════════ -->
            <!-- SECCIÓN DERECHA: Metadatos (3 niveles) (x=850, width=213)     -->
            <!-- ══════════════════════════════════════════════════════════════ -->
            
            <!-- Nivel 1: Paginación (reservado para el reporte principal) -->
            
            <!-- Nivel 2: Usuario -->
            <textField isBlankWhenNull="true">
                <reportElement x="850" y="20" width="213" height="10"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font size="7"/>
                </textElement>
                <textFieldExpression><![CDATA["Usuario: " + $P{usuario}]]></textFieldExpression>
            </textField>
            
            <!-- Nivel 3: Fecha de Generación -->
            <textField>
                <reportElement x="850" y="35" width="213" height="10"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font size="7"/>
                </textElement>
                <textFieldExpression><![CDATA["Generado: " + new java.text.SimpleDateFormat("dd/MM/yyyy HH:mm").format(new java.util.Date())]]></textFieldExpression>
            </textField>
            
            <!-- ══════════════════════════════════════════════════════════════ -->
            <!-- Línea separadora inferior                                      -->
            <!-- ══════════════════════════════════════════════════════════════ -->
            <line>
                <reportElement x="0" y="73" width="1063" height="1"/>
                <graphicElement>
                    <pen lineWidth="1.0"/>
                </graphicElement>
            </line>
            
        </band>
    </title>

</jasperReport>
