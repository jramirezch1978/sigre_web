{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "sigre-asistencia": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss"
        }
      },
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:browser",
          "options": {
            "outputPath": "dist/sigre-asistencia",
            "index": "src/index.html",
            "main": "src/main.ts",
            "polyfills": [
              "zone.js"
            ],
            "tsConfig": "tsconfig.app.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              "src/favicon.ico",
              "src/assets",
              {
                "glob": "**/*.svg",
                "input": "node_modules/ionicons/dist/ionicons/svg",
                "output": "./svg"
              }
            ],
            "styles": [
              "@angular/material/prebuilt-themes/indigo-pink.css",
              "src/assets/metoxi/css/bootstrap.min.css",
              "src/assets/metoxi/css/bootstrap-extended.css",
              "src/assets/metoxi/plugins/metismenu/metisMenu.min.css",
              "src/assets/metoxi/plugins/metismenu/mm-vertical.css",
              "src/assets/metoxi/sass/main.css",
              "src/assets/metoxi/sass/dark-theme.css",
              "src/assets/metoxi/sass/semi-dark.css",
              "src/assets/metoxi/sass/bordered-theme.css",
              "src/assets/metoxi/sass/responsive.css",
              "src/assets/metoxi/assets/plugins/perfect-scrollbar/css/perfect-scrollbar.css",
              "src/assets/metoxi/assets/plugins/simplebar/css/simplebar.css",
              "src/assets/metoxi/assets/plugins/notifications/css/lobibox.min.css",
              "src/assets/metoxi/assets/plugins/datatable/css/dataTables.bootstrap5.min.css",
              "src/assets/metoxi/assets/plugins/select2/css/select2.min.css",
              "src/assets/metoxi/assets/plugins/select2/css/select2-bootstrap4.css",
              "src/assets/metoxi/assets/plugins/bs-stepper/css/bs-stepper.css",
              "src/assets/metoxi/assets/plugins/fancy-file-uploader/fancy_fileupload.css",
              "src/app/erp/shared/styles/sigre-metoxi-global.scss",
              "src/app/auth/styles/sigre-auth-shared.scss",
              "src/styles.scss",
              "node_modules/@ionic/angular/css/core.css",
              "node_modules/@ionic/angular/css/normalize.css",
              "node_modules/@ionic/angular/css/structure.css",
              "node_modules/@ionic/angular/css/typography.css"
            ],
            "scripts": [
              "src/assets/metoxi/assets/js/jquery.min.js",
              "src/assets/metoxi/assets/js/bootstrap.bundle.min.js",
              "src/assets/metoxi/assets/plugins/perfect-scrollbar/js/perfect-scrollbar.js",
              "src/assets/metoxi/assets/plugins/simplebar/js/simplebar.min.js",
              "src/assets/metoxi/assets/plugins/metismenu/metisMenu.min.js",
              "src/assets/metoxi/assets/plugins/apexchart/apexcharts.min.js",
              "src/assets/metoxi/assets/js/main.js"
            ]
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "2mb",
                  "maximumError": "4mb"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "60kb",
                  "maximumError": "120kb"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "buildOptimizer": false,
              "optimization": false,
              "vendorChunk": true,
              "extractLicenses": false,
              "sourceMap": true,
              "namedChunks": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "configurations": {
            "production": {
              "browserTarget": "sigre-asistencia:build:production"
            },
            "development": {
              "browserTarget": "sigre-asistencia:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "extract-i18n": {
          "builder": "@angular-devkit/build-angular:extract-i18n",
          "options": {
            "browserTarget": "sigre-asistencia:build"
          }
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "polyfills": [
              "zone.js",
              "zone.js/testing"
            ],
            "tsConfig": "tsconfig.spec.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              "src/favicon.ico",
              "src/assets",
              {
                "glob": "**/*.svg",
                "input": "node_modules/ionicons/dist/ionicons/svg",
                "output": "./svg"
              }
            ],
            "styles": [
              "@angular/material/prebuilt-themes/indigo-pink.css",
              "src/styles.scss"
            ],
            "scripts": []
          }
        }
      }
    }
  },
  "cli": {
    "analytics": false
  }
}
