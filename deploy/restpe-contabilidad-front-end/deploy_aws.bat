@echo off
chcp 65001 >nul 2>&1
setlocal enabledelayedexpansion
for /f "delims=" %%t in ('powershell -NoProfile -Command "Get-Date -Format \"yyyy-MM-dd HH:mm:ss\""') do set "SCRIPT_START_HUMAN=%%t"
for /f "delims=" %%t in ('powershell -NoProfile -Command "[DateTimeOffset]::Now.ToUnixTimeSeconds()"') do set "SCRIPT_START_EPOCH=%%t"
echo [deploy-frontend] Inicio: !SCRIPT_START_HUMAN!

:: ============================================================
:: Restaurant.pe ERP ??? Frontend Deploy Script
:: ============================================================
:: Compila Angular + Docker build + Despliegue local o AWS EKS
::
:: Uso:
::   deploy.bat frontend          Build prod + push ECR + kubectl apply
::   deploy.bat frontend --force  Igual + rollout restart (nuevos pods)
::   deploy.bat full-prod         Build prod + docker local (puerto 4200)
::   deploy.bat full-dev          Build dev + docker local
::   deploy.bat docker-build      Solo construir imagen
::   deploy.bat docker-up         Levantar contenedor local
::   deploy.bat docker-down       Detener contenedor local
::   deploy.bat docker-logs       Ver logs
::   deploy.bat docker-shell      Shell en contenedor
::   deploy.bat menu              Men?? interactivo
::   deploy.bat help              Ayuda
::
:: Autenticaci??n AWS: perfil contabilidad-restpe + aws sso login
:: ============================================================

set "FRONTEND_DIR=%~dp0"
set "OUTPUT_DIR=www"
set "DOCKER_IMAGE=rpe-frontend"
set "DOCKER_TAG=latest"
set "CONTAINER_NAME=rpe-frontend"
set "CONTAINER_PORT=80"
set "HOST_PORT=4200"

:: AWS / EKS
set AWS_PROFILE=contabilidad-restpe
set AWS_REGION=us-east-1
set EKS_CLUSTER=restpe-eks-dev
set K8S_NS=dev
set "K8S_YAML=%FRONTEND_DIR%..\restpe-contabilidad-back-end\04. Terraform-aws\k8s\dev\frontend.yaml"
if exist "%FRONTEND_DIR%aws-deploy-credentials.local.bat" call "%FRONTEND_DIR%aws-deploy-credentials.local.bat"
if defined AWS_ACCESS_KEY_ID set "AWS_PROFILE="
set "AWS_CLI_PROFILE_ARG="
if not defined AWS_ACCESS_KEY_ID set "AWS_CLI_PROFILE_ARG=--profile contabilidad-restpe"

for /f %%a in ('echo prompt $E ^| cmd') do set "ESC=%%a"
set "GREEN=%ESC%[92m"
set "RED=%ESC%[91m"
set "YELLOW=%ESC%[93m"
set "CYAN=%ESC%[96m"
set "RESET=%ESC%[0m"

:: ?????? Punto de entrada ??????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????
if "%~1"=="" goto :showHelp
if /i "%~1"=="menu"         goto :showMenu
if /i "%~1"=="frontend"     goto :deployAws
if /i "%~1"=="aws"          goto :deployAws
if /i "%~1"=="full-dev"     goto :fullDev
if /i "%~1"=="full-prod"    goto :fullProd
if /i "%~1"=="docker-build" goto :dockerBuild
if /i "%~1"=="docker-up"    goto :dockerUp
if /i "%~1"=="docker-down"  goto :dockerDown
if /i "%~1"=="docker-logs"  goto :dockerLogs
if /i "%~1"=="docker-shell" goto :dockerShell
if /i "%~1"=="help"         goto :showHelp

echo %RED%Opcion desconocida: %~1%RESET%
goto :showHelp

:: ????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????
:: MENU INTERACTIVO
:: ????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????
:showMenu
echo.
echo %CYAN%============================================================%RESET%
echo %CYAN%  Restaurant.pe ERP - Frontend Deploy%RESET%
echo %CYAN%  Angular 20 ^| Docker ^| Nginx ^| AWS EKS%RESET%
echo %CYAN%============================================================%RESET%
echo.
echo   %GREEN%DESPLEGAR%RESET%
echo     1.  Deploy FRONTEND       (build prod + ECR + kubectl apply)
echo     2.  Deploy FRONTEND --force (+ rollout restart)
echo     3.  Full deploy DEV       (build dev + docker local)
echo     4.  Full deploy PROD      (build prod + docker local)
echo.
echo   %GREEN%DOCKER LOCAL%RESET%
echo     5.  Docker build
echo     6.  Docker up
echo     7.  Docker down
echo     8.  Docker logs
echo     9.  Docker shell
echo.
echo     0.  Salir
echo.
set /p "OPTION=  Seleccione una opcion: "

if "%OPTION%"=="1" goto :deployAws
if "%OPTION%"=="2" goto :deployAwsForce
if "%OPTION%"=="3" goto :fullDev
if "%OPTION%"=="4" goto :fullProd
if "%OPTION%"=="5" goto :dockerBuild
if "%OPTION%"=="6" goto :dockerUp
if "%OPTION%"=="7" goto :dockerDown
if "%OPTION%"=="8" goto :dockerLogs
if "%OPTION%"=="9" goto :dockerShell
if "%OPTION%"=="0" goto :exitScript
goto :showMenu

:: ????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????
:: DEPLOY A AWS EKS
:: ????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????
:deployAwsForce
set "DEPLOY_FORCE=1"
goto :deployAwsStart

:deployAws
set "DEPLOY_FORCE=0"
for %%A in (%*) do (
    if /i "%%A"=="--force" set "DEPLOY_FORCE=1"
    if /i "%%A"=="/force" set "DEPLOY_FORCE=1"
)

:deployAwsStart
echo.
echo %CYAN%============================================================%RESET%
echo %CYAN%  DEPLOY FRONTEND A AWS EKS%RESET%
echo %CYAN%============================================================%RESET%
echo.

call :checkDocker
if errorlevel 1 goto :endScript

where aws >nul 2>&1
if errorlevel 1 (
    echo %RED%[ERROR]%RESET% AWS CLI no encontrado.
    goto :endScript
)
where kubectl >nul 2>&1
if errorlevel 1 (
    echo %RED%[ERROR]%RESET% kubectl no encontrado.
    goto :endScript
)

if not exist "!K8S_YAML!" (
    echo %RED%[ERROR]%RESET% No se encontro frontend.yaml en: !K8S_YAML!
    goto :endScript
)

:: Log
for /f "delims=" %%t in ('powershell -NoProfile -Command "Get-Date -Format yyyyMMdd-HHmmss"') do set "DEPLOY_TS=%%t"
set "DEPLOY_LOG_DIR=%FRONTEND_DIR%deploy-logs"
if not exist "!DEPLOY_LOG_DIR!" mkdir "!DEPLOY_LOG_DIR!"
set "DEPLOY_LOG=!DEPLOY_LOG_DIR!\deploy-!DEPLOY_TS!.log"
(
echo ============================================================
echo DEPLOY Frontend Restaurant.pe
echo Inicio: %date% %time%
echo Force: !DEPLOY_FORCE!
echo ============================================================
) > "!DEPLOY_LOG!"
echo ^>^> Log: !DEPLOY_LOG!

:: Login AWS
echo ^>^> Login AWS SSO...
aws sts get-caller-identity %AWS_CLI_PROFILE_ARG% >nul 2>&1
if errorlevel 1 (
    echo ^>^> Sesion expirada, ejecutando aws sso login...
    aws sso login %AWS_CLI_PROFILE_ARG%
)
aws eks update-kubeconfig --region %AWS_REGION% --name %EKS_CLUSTER% %AWS_CLI_PROFILE_ARG% >> "!DEPLOY_LOG!" 2>&1

:: ECR login
for /f "tokens=*" %%i in ('aws sts get-caller-identity --query Account --output text %AWS_CLI_PROFILE_ARG%') do set ACCOUNT_ID=%%i
set ECR_REGISTRY=%ACCOUNT_ID%.dkr.ecr.%AWS_REGION%.amazonaws.com
set "ECR_IMAGE=%ECR_REGISTRY%/restpe/dev/frontend:latest"

echo ^>^> Login ECR...
for /f "tokens=*" %%i in ('aws ecr get-login-password --region %AWS_REGION% %AWS_CLI_PROFILE_ARG%') do (
    echo %%i| docker login --username AWS --password-stdin %ECR_REGISTRY% >nul 2>&1
)

:: Docker build
echo ^>^> [1/4] Docker build (multi-stage: npm + nginx)...
cd /d "%FRONTEND_DIR%"
docker build --no-cache --progress=plain -t !ECR_IMAGE! . >> "!DEPLOY_LOG!" 2>&1
if errorlevel 1 (
    echo %RED%[FAIL]%RESET% Docker build fallo. Ultimas lineas:
    powershell -NoProfile -Command "Get-Content -LiteralPath '!DEPLOY_LOG!' -Tail 30"
    goto :endScript
)
echo %GREEN%[OK]%RESET% Imagen: !ECR_IMAGE!

:: Push ECR
echo ^>^> [2/4] Push a ECR...
docker push !ECR_IMAGE! >> "!DEPLOY_LOG!" 2>&1
if errorlevel 1 (
    echo %RED%[FAIL]%RESET% Push fallo. Ver: !DEPLOY_LOG!
    goto :endScript
)
echo %GREEN%[OK]%RESET% Push completado.

:: kubectl apply
if "!DEPLOY_FORCE!"=="1" (
    echo ^>^> [3/4] Eliminando deployment anterior...
    kubectl -n %K8S_NS% delete deployment frontend --ignore-not-found >> "!DEPLOY_LOG!" 2>&1
    echo ^>^> [3b] Aplicando deployment nuevo con imagen fresca...
) else (
    echo ^>^> [3/4] kubectl apply...
)
powershell -NoProfile -Command "(Get-Content -LiteralPath '!K8S_YAML!' -Raw) -replace 'IMAGE_PLACEHOLDER','!ECR_IMAGE!' | Set-Content -LiteralPath '%TEMP%\frontend-deploy.yaml' -Encoding utf8"
kubectl apply -f "%TEMP%\frontend-deploy.yaml" >> "!DEPLOY_LOG!" 2>&1

:: Rollout status
echo ^>^> [4/4] Esperando rollout...
kubectl -n %K8S_NS% rollout status deployment frontend --timeout=180s >> "!DEPLOY_LOG!" 2>&1
if errorlevel 1 (
    echo %RED%[FAIL]%RESET% Rollout timeout. Ver: !DEPLOY_LOG!
    goto :endScript
)

:: Obtener URL del LoadBalancer
echo.
echo %GREEN%============================================================%RESET%
echo %GREEN%  Frontend desplegado en EKS!%RESET%
echo %GREEN%============================================================%RESET%
for /f "tokens=*" %%u in ('kubectl -n %K8S_NS% get svc frontend -o jsonpath^="{.status.loadBalancer.ingress[0].hostname}"') do (
    echo %GREEN%  URL: http://%%u%RESET%
)
echo %GREEN%  Imagen: !ECR_IMAGE!%RESET%
echo %GREEN%  Log: !DEPLOY_LOG!%RESET%
echo %GREEN%============================================================%RESET%
goto :endScript

:: ????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????
:: VALIDACIONES
:: ????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????
:checkNode
node --version >nul 2>&1
if errorlevel 1 (
    echo %RED%[ERROR]%RESET% Node.js no encontrado. Instale Node.js ^>= 18.
    exit /b 1
)
exit /b 0

:checkDocker
docker --version >nul 2>&1
if errorlevel 1 (
    echo %RED%[ERROR]%RESET% Docker no encontrado. Instale Docker Desktop.
    exit /b 1
)
echo %GREEN%[OK]%RESET% Docker disponible.
exit /b 0

:checkNodeModules
if not exist "%FRONTEND_DIR%node_modules" (
    echo %YELLOW%[WARN]%RESET% node_modules no encontrado. Instalando...
    pushd "%FRONTEND_DIR%"
    npm install
    popd
)
exit /b 0

:: ????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????
:: FULL DEPLOY LOCAL
:: ????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????
:fullDev
echo.
echo %CYAN%[INFO]%RESET% Deploy completo ??? modo DESARROLLO
echo %YELLOW%???????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????%RESET%

call :checkNode
if errorlevel 1 goto :endScript
call :checkDocker
if errorlevel 1 goto :endScript
call :checkNodeModules

echo.
echo %CYAN%[1/3]%RESET% Compilando Angular (desarrollo)...
echo %YELLOW%???????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????%RESET%
pushd "%FRONTEND_DIR%"
ng build
if errorlevel 1 (
    echo %RED%[ERROR]%RESET% Fallo la compilacion.
    popd
    goto :endScript
)
popd
echo %GREEN%[OK]%RESET% Build completado.

set "DOCKER_TAG=dev"
goto :buildAndRun

:fullProd
echo.
echo %CYAN%[INFO]%RESET% Deploy completo ??? modo PRODUCCION
echo %YELLOW%???????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????%RESET%

call :checkNode
if errorlevel 1 goto :endScript
call :checkDocker
if errorlevel 1 goto :endScript
call :checkNodeModules

echo.
echo %CYAN%[1/3]%RESET% Compilando Angular (produccion)...
echo %YELLOW%???????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????%RESET%
pushd "%FRONTEND_DIR%"
ng build --configuration production
if errorlevel 1 (
    echo %RED%[ERROR]%RESET% Fallo la compilacion de produccion.
    popd
    goto :endScript
)
popd
echo %GREEN%[OK]%RESET% Build de produccion completado.

set "DOCKER_TAG=latest"
goto :buildAndRun

:buildAndRun
echo.
echo %CYAN%[2/3]%RESET% Construyendo imagen Docker [%DOCKER_IMAGE%:%DOCKER_TAG%]...
echo %YELLOW%???????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????%RESET%
pushd "%FRONTEND_DIR%"
docker build -t %DOCKER_IMAGE%:%DOCKER_TAG% .
if errorlevel 1 (
    echo %RED%[ERROR]%RESET% Fallo el build de Docker.
    popd
    goto :endScript
)
popd
echo %GREEN%[OK]%RESET% Imagen construida: %DOCKER_IMAGE%:%DOCKER_TAG%

echo.
echo %CYAN%[3/3]%RESET% Levantando contenedor...
echo %YELLOW%???????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????%RESET%

docker stop %CONTAINER_NAME% >nul 2>&1
docker rm %CONTAINER_NAME% >nul 2>&1

docker run -d ^
    --name %CONTAINER_NAME% ^
    -p %HOST_PORT%:%CONTAINER_PORT% ^
    --restart unless-stopped ^
    %DOCKER_IMAGE%:%DOCKER_TAG%

if errorlevel 1 (
    echo %RED%[ERROR]%RESET% Fallo al levantar el contenedor.
) else (
    echo.
    echo %GREEN%???????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????%RESET%
    echo %GREEN%  Frontend desplegado correctamente!%RESET%
    echo %GREEN%  URL: http://localhost:%HOST_PORT%%RESET%
    echo %GREEN%  Contenedor: %CONTAINER_NAME%%RESET%
    echo %GREEN%  Imagen: %DOCKER_IMAGE%:%DOCKER_TAG%%RESET%
    echo %GREEN%???????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????%RESET%
)
goto :endScript

:: ????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????
:: DOCKER INDIVIDUAL
:: ????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????
:dockerBuild
call :checkDocker
if errorlevel 1 goto :endScript

if "%~2" neq "" set "DOCKER_TAG=%~2"

echo.
echo %CYAN%[INFO]%RESET% Construyendo imagen Docker [%DOCKER_IMAGE%:%DOCKER_TAG%]...
pushd "%FRONTEND_DIR%"
docker build -t %DOCKER_IMAGE%:%DOCKER_TAG% .
if errorlevel 1 (
    echo %RED%[ERROR]%RESET% Fallo el build de Docker.
) else (
    echo %GREEN%[OK]%RESET% Imagen construida: %DOCKER_IMAGE%:%DOCKER_TAG%
)
popd
goto :endScript

:dockerUp
call :checkDocker
if errorlevel 1 goto :endScript

if "%~2" neq "" set "DOCKER_TAG=%~2"

echo.
echo %CYAN%[INFO]%RESET% Levantando contenedor %CONTAINER_NAME%...
docker stop %CONTAINER_NAME% >nul 2>&1
docker rm %CONTAINER_NAME% >nul 2>&1
docker run -d --name %CONTAINER_NAME% -p %HOST_PORT%:%CONTAINER_PORT% --restart unless-stopped %DOCKER_IMAGE%:%DOCKER_TAG%
if errorlevel 1 (
    echo %RED%[ERROR]%RESET% Fallo al levantar el contenedor.
) else (
    echo %GREEN%[OK]%RESET% Contenedor activo en http://localhost:%HOST_PORT%
)
goto :endScript

:dockerDown
call :checkDocker
if errorlevel 1 goto :endScript

echo %CYAN%[INFO]%RESET% Deteniendo contenedor %CONTAINER_NAME%...
docker stop %CONTAINER_NAME% >nul 2>&1
docker rm %CONTAINER_NAME% >nul 2>&1
echo %GREEN%[OK]%RESET% Contenedor detenido y eliminado.
goto :endScript

:dockerLogs
call :checkDocker
if errorlevel 1 goto :endScript

echo %CYAN%[INFO]%RESET% Logs del contenedor %CONTAINER_NAME%:
echo %YELLOW%  Ctrl+C para salir%RESET%
echo %YELLOW%???????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????%RESET%
docker logs -f %CONTAINER_NAME%
goto :endScript

:dockerShell
call :checkDocker
if errorlevel 1 goto :endScript

echo %CYAN%[INFO]%RESET% Abriendo shell en %CONTAINER_NAME%...
docker exec -it %CONTAINER_NAME% sh
goto :endScript

:: ????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????
:: AYUDA
:: ????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????
:showHelp
echo.
echo %CYAN%Uso:%RESET% deploy.bat ^<comando^> [argumentos]
echo.
echo %GREEN%Deploy FRONTEND (ECR + kubectl):%RESET%
echo   frontend                  Build prod + push ECR + kubectl apply
echo   frontend --force          Igual + rollout restart (nuevos pods)
echo   aws                       Alias legado de compatibilidad
echo   aws --force               Alias legado con rollout restart
echo.
echo %GREEN%Deploy local (Docker):%RESET%
echo   full-dev                  Build dev + docker build + docker up
echo   full-prod                 Build prod + docker build + docker up
echo.
echo %GREEN%Comandos Docker:%RESET%
echo   docker-build [tag]        Construir imagen (default: latest)
echo   docker-up [tag]           Levantar contenedor
echo   docker-down               Detener y eliminar contenedor
echo   docker-logs               Ver logs en tiempo real
echo   docker-shell              Abrir shell en el contenedor
echo.
echo %GREEN%Otros:%RESET%
echo   menu                      Menu interactivo
echo   help                      Esta ayuda
echo.
echo %CYAN%Ejemplos:%RESET%
echo   deploy.bat frontend
echo   deploy.bat frontend --force
echo   deploy.bat full-prod
echo   deploy.bat full-dev
echo   deploy.bat menu
echo.
goto :endScript

:exitScript
echo.
echo %GREEN%Hasta luego!%RESET%
:endScript
for /f "delims=" %%t in ('powershell -NoProfile -Command "Get-Date -Format \"yyyy-MM-dd HH:mm:ss\""') do set "SCRIPT_END_HUMAN=%%t"
for /f "delims=" %%t in ('powershell -NoProfile -Command "[DateTimeOffset]::Now.ToUnixTimeSeconds()"') do set "SCRIPT_END_EPOCH=%%t"
set /a SCRIPT_ELAPSED_SEC=!SCRIPT_END_EPOCH!-!SCRIPT_START_EPOCH!
if !SCRIPT_ELAPSED_SEC! lss 0 set "SCRIPT_ELAPSED_SEC=0"
for /f "delims=" %%t in ('powershell -NoProfile -Command "$s=[int]$env:SCRIPT_ELAPSED_SEC; [TimeSpan]::FromSeconds($s).ToString(\"hh\:mm\:ss\")"') do set "SCRIPT_ELAPSED_FMT=%%t"
echo [deploy-frontend] Fin: !SCRIPT_END_HUMAN!
echo [deploy-frontend] Duracion total: !SCRIPT_ELAPSED_FMT! ^(!SCRIPT_ELAPSED_SEC! s^)
if defined DEPLOY_LOG if exist "!DEPLOY_LOG!" (
    >> "!DEPLOY_LOG!" echo.
    >> "!DEPLOY_LOG!" echo ============================================================
    >> "!DEPLOY_LOG!" echo Fin: !SCRIPT_END_HUMAN!
    >> "!DEPLOY_LOG!" echo Duracion total: !SCRIPT_ELAPSED_FMT! ^(!SCRIPT_ELAPSED_SEC! s^)
    >> "!DEPLOY_LOG!" echo ============================================================
)
endlocal
