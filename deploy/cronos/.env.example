# SIGRE ERP — Variables de entorno (copiar a .env en cronos)
# cp .env.example .env && nano .env

POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES
ERP_APP_PASSWORD=CHANGE_ME_ERP_APP
SONAR_DB_PASSWORD=CHANGE_ME_SONARQUBE

IMAGE_REGISTRY=ghcr.io/jramirezch1978/sigre
IMAGE_TAG=latest

PUBLIC_HOST=crisaor.serveftp.com
API_GATEWAY_URL=http://crisaor.serveftp.com:9080
FRONTEND_URL=http://crisaor.serveftp.com:8080

TZ=America/Lima

# JDBC interno (red Docker stack_default — hostname: postgres)
# jdbc:postgresql://postgres:5432/sigre_security
# jdbc:postgresql://postgres:5432/sigre_template
# jdbc:postgresql://postgres:5432/sigre_emp_cantabria
