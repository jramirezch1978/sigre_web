<?xml version="1.0" encoding="UTF-8"?>
<!--
  Subreporte reutilizable: Contenedor de logo para JasperReports.
  Aspect ratio fijo 3:1 (ancho:alto). Tamaños: S (90×30), M (120×40), L (150×50).
  La imagen se centra sin estirarse (scaleImage="RetainShape").

  PARÁMETROS del subreporte:
    logoImage  - java.io.InputStream con la imagen del logo (puede ser null)
    logoSize   - String: "S" | "M" | "L" (default: "L")

  USO en el reporte padre:
    1. Compilar subreporte:
       InputStream jrxml = getClass().getResourceAsStream("/reports/logo_container.jrxml");
       JasperReport logoSub = JasperCompileManager.compileReport(jrxml);

    2. Pasar como parámetros:
       params.put("logoSubreport", logoSub);
       params.put("logoImage", inputStream);
       params.put("logoSize", "L");

    3. En el JRXML padre:
       <subreport>
         <reportElement x="0" y="0" width="150" height="50"/>
         <subreportParameter name="logoImage"><subreportParameterExpression>$P{logoImage}</subreportParameterExpression></subreportParameter>
         <subreportParameter name="logoSize"><subreportParameterExpression>$P{logoSize}</subreportParameterExpression></subreportParameter>
         <dataSourceExpression>new net.sf.jasperreports.engine.JREmptyDataSource()</dataSourceExpression>
         <subreportExpression>$P{logoSubreport}</subreportExpression>
       </subreport>
-->
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
                                  http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="logo_container" pageWidth="150" pageHeight="50"
              columnWidth="150" leftMargin="0" rightMargin="0"
              topMargin="0" bottomMargin="0"
              uuid="a5c00000-0000-4000-8000-000000000001">

    <parameter name="logoImage" class="java.io.InputStream"/>
    <parameter name="logoSize"  class="java.lang.String">
        <defaultValueExpression><![CDATA["L"]]></defaultValueExpression>
    </parameter>

    <title>
        <band height="50">

            <!-- ── SIZE S: 90 × 30 ── -->
            <image scaleImage="RetainShape" hAlign="Center" vAlign="Middle"
                   onErrorType="Blank" isUsingCache="true">
                <reportElement x="0" y="0" width="90" height="30"
                               uuid="a5c00001-0000-4000-8000-000000000002">
                    <printWhenExpression><![CDATA["S".equalsIgnoreCase($P{logoSize}) && $P{logoImage} != null]]></printWhenExpression>
                </reportElement>
                <box><pen lineWidth="0.25" lineColor="#CCCCCC"/></box>
                <imageExpression><![CDATA[$P{logoImage}]]></imageExpression>
            </image>

            <!-- ── SIZE M: 120 × 40 ── -->
            <image scaleImage="RetainShape" hAlign="Center" vAlign="Middle"
                   onErrorType="Blank" isUsingCache="true">
                <reportElement x="0" y="0" width="120" height="40"
                               uuid="a5c00002-0000-4000-8000-000000000003">
                    <printWhenExpression><![CDATA["M".equalsIgnoreCase($P{logoSize}) && $P{logoImage} != null]]></printWhenExpression>
                </reportElement>
                <box><pen lineWidth="0.25" lineColor="#CCCCCC"/></box>
                <imageExpression><![CDATA[$P{logoImage}]]></imageExpression>
            </image>

            <!-- ── SIZE L: 150 × 50 (default) ── -->
            <image scaleImage="RetainShape" hAlign="Center" vAlign="Middle"
                   onErrorType="Blank" isUsingCache="true">
                <reportElement x="0" y="0" width="150" height="50"
                               uuid="a5c00003-0000-4000-8000-000000000004">
                    <printWhenExpression><![CDATA[("L".equalsIgnoreCase($P{logoSize}) || $P{logoSize} == null) && $P{logoImage} != null]]></printWhenExpression>
                </reportElement>
                <box><pen lineWidth="0.25" lineColor="#CCCCCC"/></box>
                <imageExpression><![CDATA[$P{logoImage}]]></imageExpression>
            </image>

        </band>
    </title>

</jasperReport>
