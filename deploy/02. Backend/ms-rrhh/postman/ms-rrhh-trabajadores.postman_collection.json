              "raw": "{{baseUrl}}/api/rrhh/trabajadores/{{trabajadorId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "rrhh", "trabajadores", "{{trabajadorId}}"]
            }
          }
        },
