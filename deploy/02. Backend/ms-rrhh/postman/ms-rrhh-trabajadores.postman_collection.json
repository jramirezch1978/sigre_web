{
  "info": {
    "name": "ms-rrhh — Trabajadores API",
    "description": "Colección Postman (v2.1) para los 17 endpoints de Trabajadores, Contratos Laborales y Horarios.\n\n- **baseUrl:** http://localhost:9007\n- **accessToken:** JWT Bearer del gateway/login.\n- Variables {{...Id}} son ejemplos; ajustar a datos reales.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token2}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:9007" },
    { "key": "token2", "value": "" },
    { "key": "trabajadorId", "value": "1" },
    { "key": "contratoId", "value": "1" },
    { "key": "horarioId", "value": "1" }
  ],
  "item": [
    {
      "name": "Trabajador",
      "item": [
        {
          "name": "Listar trabajadores (paginado + filtros)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/rrhh/trabajadores?page=0&size=10&flagEstado=1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "rrhh", "trabajadores"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "10" },
                { "key": "flagEstado", "value": "1" },
                { "key": "codigoTrabajador", "value": "", "disabled": true },
                { "key": "nombres", "value": "", "disabled": true },
                { "key": "apellidoPaterno", "value": "", "disabled": true },
                { "key": "numeroDocumento", "value": "", "disabled": true },
                { "key": "areaId", "value": "", "disabled": true },
                { "key": "cargoId", "value": "", "disabled": true },
                { "key": "sucursalId", "value": "", "disabled": true }
              ]
            }
          }
        },
        {
