          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"trabajadorId\": 1,\n  \"fecMovim\": \"2026-05-15\",\n  \"conceptoId\": 5,\n  \"nroDoc\": \"MOV-2026-001-UPD\",\n  \"impVar\": 400.00,\n  \"nroDias\": 2.50,\n  \"nroHoras\": 20.00,\n  \"tipoPlanilla\": \"NORMAL\"\n}"
            },
