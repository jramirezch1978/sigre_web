            "description": "Esperado: 422, errorCode RH-GV-001"
          }
        },
        {
          "name": "ERROR: Concepto inexistente",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"trabajadorId\": 1,\n  \"fecMovim\": \"2026-05-15\",\n  \"conceptoId\": 9999,\n  \"impVar\": 100.00\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/rrhh/ganancias-descuentos-variables",
              "host": ["{{baseUrl}}"],
              "path": ["api", "rrhh", "ganancias-descuentos-variables"]
            },
            "description": "Esperado: 422, errorCode RH-GV-002"
          }
        },
        {
