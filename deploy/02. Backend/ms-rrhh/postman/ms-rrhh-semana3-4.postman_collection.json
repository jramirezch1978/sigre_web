    {
      "name": "03. Calculo Planilla",
      "item": [
        {
          "name": "Listar cálculos de planilla",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/rrhh/calculos?page=0&size=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "rrhh", "calculos"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "10" },
                { "key": "anio", "value": "2026", "disabled": true },
                { "key": "mes", "value": "5", "disabled": true },
                { "key": "tipo", "value": "NORMAL", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Obtener detalle de cálculo",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/rrhh/calculos/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "rrhh", "calculos", "1"]
            },
            "description": "Retorna cabecera + lista de detalles con nombres de trabajador y concepto"
          }
        },
        {
          "name": "Procesar planilla (NORMAL)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"anio\": 2026,\n  \"mes\": 5,\n  \"tipo\": \"NORMAL\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/rrhh/calculos/procesar",
              "host": ["{{baseUrl}}"],
              "path": ["api", "rrhh", "calculos", "procesar"]
            },
            "description": "Esperado: 201. Calcula planilla para todos los trabajadores activos con contrato activo. Genera líneas de ingreso (remuneración) y descuento (AFP)"
          }
        },
        {
          "name": "Procesar planilla (GRATIFICACION)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"anio\": 2026,\n  \"mes\": 7,\n  \"tipo\": \"GRATIFICACION\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/rrhh/calculos/procesar",
              "host": ["{{baseUrl}}"],
              "path": ["api", "rrhh", "calculos", "procesar"]
            }
          }
        },
        {
          "name": "ERROR: Sin año/mes",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tipo\": \"NORMAL\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/rrhh/calculos/procesar",
              "host": ["{{baseUrl}}"],
              "path": ["api", "rrhh", "calculos", "procesar"]
            },
            "description": "Esperado: 400, VALIDATION_ERROR"
          }
        },
        {
          "name": "ERROR: Sin tipo planilla",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"anio\": 2026,\n  \"mes\": 5\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/rrhh/calculos/procesar",
              "host": ["{{baseUrl}}"],
              "path": ["api", "rrhh", "calculos", "procesar"]
            },
            "description": "Esperado: 400, VALIDATION_ERROR"
          }
        },
        {
          "name": "Re-procesar (sobrescribe cálculo previo)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"anio\": 2026,\n  \"mes\": 5,\n  \"tipo\": \"NORMAL\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/rrhh/calculos/procesar",
              "host": ["{{baseUrl}}"],
              "path": ["api", "rrhh", "calculos", "procesar"]
            },
            "description": "Esperado: 201. Si ya existe cálculo para mayo/NORMAL, lo elimina y recalcula"
          }
        },
        {
          "name": "Eliminar cálculo",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/rrhh/calculos/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "rrhh", "calculos", "1"]
            },
            "description": "Esperado: 200. Elimina cabecera + todos los detalles"
          }
        }
      ]
    }
  ]
}
