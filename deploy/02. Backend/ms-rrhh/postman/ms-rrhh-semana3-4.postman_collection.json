{
  "info": {
    "name": "ms-rrhh — Semana 3-4 (Asistencia, GanDescVariable, Cálculo)",
    "_postman_id": "c3d4e5f6-7890-4abc-def0-123456789abc",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:9007" },
    { "key": "token2", "value": "" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token2}}", "type": "string" }]
