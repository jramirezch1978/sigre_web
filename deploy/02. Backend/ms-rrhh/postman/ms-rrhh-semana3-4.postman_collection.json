  "item": [
    {
      "name": "00. Prerequisitos",
      "item": [
        {
          "name": "Insertar concepto_planilla (ejecutar en BD)",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/", "host": ["{{baseUrl}}"], "path": [""] },
            "description": "NOTA: Ejecutar directamente en la BD del tenant:\n\nINSERT INTO rrhh.concepto_planilla (id, codigo, nombre, tipo, afecto_quinta, afecto_essalud, aplica_todos, created_by, fec_creacion)\nVALUES\n(1, 'REM-BAS', 'Remuneración Básica', 'INGRESO', true, true, true, 1, NOW()),\n(2, 'AFP-COM', 'Comisión AFP', 'DESCUENTO', false, false, true, 1, NOW()),\n(3, 'AFP-PRI', 'Prima Seguro AFP', 'DESCUENTO', false, false, true, 1, NOW()),\n(4, 'AFP-APO', 'Aporte Obligatorio AFP', 'DESCUENTO', false, false, true, 1, NOW()),\n(5, 'HRS-EXT', 'Horas Extra', 'INGRESO', true, true, true, 1, NOW())\nON CONFLICT (id) DO NOTHING;\nSELECT setval(pg_get_serial_sequence('rrhh.concepto_planilla', 'id'), (SELECT COALESCE(MAX(id), 1) FROM rrhh.concepto_planilla));"
          }
        }
      ]
    },
    {
      "name": "01. Asistencia",
      "item": [
        {
          "name": "Listar asistencias",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/rrhh/asistencias?page=0&size=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "rrhh", "asistencias"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "10" },
                { "key": "trabajadorId", "value": "1", "disabled": true },
                { "key": "fechaDesde", "value": "2026-05-01", "disabled": true },
                { "key": "fechaHasta", "value": "2026-05-31", "disabled": true },
                { "key": "tipoMarca", "value": "NORMAL", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Obtener asistencia por ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/rrhh/asistencias/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "rrhh", "asistencias", "1"]
            }
          }
        },
        {
          "name": "Crear asistencia (jornada completa)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"trabajadorId\": 1,\n  \"fecha\": \"2026-05-28\",\n  \"horaEntrada\": \"08:00:00\",\n  \"horaSalida\": \"17:30:00\",\n  \"tipoMarca\": \"NORMAL\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/rrhh/asistencias",
              "host": ["{{baseUrl}}"],
              "path": ["api", "rrhh", "asistencias"]
            },
            "description": "Esperado: 201. horasTrabajadas=9.50, horasExtra=1.50"
          }
        },
        {
          "name": "Crear asistencia (solo entrada)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"trabajadorId\": 1,\n  \"fecha\": \"2026-05-27\",\n  \"horaEntrada\": \"08:00:00\",\n  \"tipoMarca\": \"ENTRADA\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/rrhh/asistencias",
              "host": ["{{baseUrl}}"],
              "path": ["api", "rrhh", "asistencias"]
            },
            "description": "Esperado: 201. horasTrabajadas=null (sin hora salida)"
          }
        },
        {
          "name": "ERROR: Duplicado mismo trabajador+fecha",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"trabajadorId\": 1,\n  \"fecha\": \"2026-05-28\",\n  \"horaEntrada\": \"09:00:00\",\n  \"tipoMarca\": \"NORMAL\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/rrhh/asistencias",
              "host": ["{{baseUrl}}"],
              "path": ["api", "rrhh", "asistencias"]
            },
            "description": "Esperado: 422, errorCode RH-AS-002"
          }
        },
        {
          "name": "ERROR: Hora salida antes de entrada",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"trabajadorId\": 1,\n  \"fecha\": \"2026-05-26\",\n  \"horaEntrada\": \"17:00:00\",\n  \"horaSalida\": \"08:00:00\",\n  \"tipoMarca\": \"NORMAL\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/rrhh/asistencias",
              "host": ["{{baseUrl}}"],
              "path": ["api", "rrhh", "asistencias"]
            },
            "description": "Esperado: 422, errorCode RH-AS-003"
          }
        },
        {
          "name": "ERROR: Trabajador inexistente",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"trabajadorId\": 9999,\n  \"fecha\": \"2026-05-26\",\n  \"horaEntrada\": \"08:00:00\",\n  \"tipoMarca\": \"NORMAL\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/rrhh/asistencias",
              "host": ["{{baseUrl}}"],
              "path": ["api", "rrhh", "asistencias"]
            },
            "description": "Esperado: 422, errorCode RH-AS-001"
          }
        },
        {
          "name": "Actualizar asistencia",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"trabajadorId\": 1,\n  \"fecha\": \"2026-05-28\",\n  \"horaEntrada\": \"07:30:00\",\n  \"horaSalida\": \"17:00:00\",\n  \"tipoMarca\": \"NORMAL\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/rrhh/asistencias/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "rrhh", "asistencias", "1"]
            },
            "description": "Esperado: 200. Recalcula horasTrabajadas y horasExtra"
          }
        },
        {
          "name": "Anular asistencia",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/rrhh/asistencias/1/anular",
              "host": ["{{baseUrl}}"],
              "path": ["api", "rrhh", "asistencias", "1", "anular"]
            },
            "description": "Esperado: 200. flagEstado cambia a '0'"
          }
        },
        {
          "name": "ERROR: Modificar registro anulado",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"trabajadorId\": 1,\n  \"fecha\": \"2026-05-28\",\n  \"horaEntrada\": \"08:00:00\",\n  \"tipoMarca\": \"NORMAL\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/rrhh/asistencias/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "rrhh", "asistencias", "1"]
            },
            "description": "Esperado: 409, errorCode RH-AS-004 (registro ya anulado)"
          }
        }
      ]
    },
    {
      "name": "02. Ganancia-Descuento Variable",
      "item": [
        {
          "name": "Listar ganancias/descuentos variables",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/rrhh/ganancias-descuentos-variables?page=0&size=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "rrhh", "ganancias-descuentos-variables"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "10" },
                { "key": "trabajadorId", "value": "1", "disabled": true },
                { "key": "conceptoId", "value": "5", "disabled": true },
                { "key": "anio", "value": "2026", "disabled": true },
                { "key": "mes", "value": "5", "disabled": true },
                { "key": "tipoPlanilla", "value": "NORMAL", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Obtener ganancia/descuento variable por ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/rrhh/ganancias-descuentos-variables/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "rrhh", "ganancias-descuentos-variables", "1"]
            }
          }
        },
        {
          "name": "Crear ganancia/descuento variable",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"trabajadorId\": 1,\n  \"fecMovim\": \"2026-05-15\",\n  \"conceptoId\": 5,\n  \"nroDoc\": \"MOV-2026-001\",\n  \"impVar\": 350.00,\n  \"nroDias\": 2.00,\n  \"nroHoras\": 16.00,\n  \"tipoPlanilla\": \"NORMAL\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/rrhh/ganancias-descuentos-variables",
              "host": ["{{baseUrl}}"],
              "path": ["api", "rrhh", "ganancias-descuentos-variables"]
            },
            "description": "Esperado: 201. Incluye trabajadorNombres y conceptoNombre"
          }
        },
