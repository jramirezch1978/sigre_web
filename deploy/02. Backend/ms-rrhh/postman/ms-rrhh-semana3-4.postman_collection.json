            "body": {
              "mode": "raw",
              "raw": "{\n  \"trabajadorId\": 9999,\n  \"fecMovim\": \"2026-05-15\",\n  \"conceptoId\": 5,\n  \"impVar\": 100.00\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/rrhh/ganancias-descuentos-variables",
