          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"trabajadorId\": 2,\n  \"fecMovim\": \"2026-05-20\",\n  \"conceptoId\": 5,\n  \"nroDoc\": \"MOV-2026-002\",\n  \"impVar\": 600.00,\n  \"centrosCostoId\": 1,\n  \"cantLabor\": 10.00,\n  \"nroDias\": 5.00,\n  \"nroHoras\": 40.00,\n  \"nroCuotas\": 3,\n  \"tipoPlanilla\": \"NORMAL\"\n}"
