  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token2}}", "type": "string" }]
  },
  "item": [
    {
      "name": "01. Quinta Categoria",
      "item": [
        {
          "name": "Procesar quinta categoría (NORMAL)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"anio\": 2026,\n  \"mes\": 6\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/rrhh/quinta-categoria/procesar",
              "host": ["{{baseUrl}}"],
              "path": ["api", "rrhh", "quinta-categoria", "procesar"]
            },
            "description": "Esperado: 201. Calcula retención de 5ta para todos los trabajadores activos con contrato. Devuelve lista de registros generados."
          }
        },
        {
          "name": "Re-procesar (sobrescribe período)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"anio\": 2026,\n  \"mes\": 6\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/rrhh/quinta-categoria/procesar",
              "host": ["{{baseUrl}}"],
              "path": ["api", "rrhh", "quinta-categoria", "procesar"]
            },
            "description": "Esperado: 201. Elimina los registros previos del período y recalcula (idempotente)."
          }
        },
        {
          "name": "ERROR: Mes inválido",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"anio\": 2026,\n  \"mes\": 13\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/rrhh/quinta-categoria/procesar",
              "host": ["{{baseUrl}}"],
              "path": ["api", "rrhh", "quinta-categoria", "procesar"]
            },
            "description": "Esperado: 400, VALIDATION_ERROR / RH-QC-002"
          }
        },
        {
          "name": "ERROR: Sin año",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mes\": 6\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/rrhh/quinta-categoria/procesar",
              "host": ["{{baseUrl}}"],
              "path": ["api", "rrhh", "quinta-categoria", "procesar"]
            },
            "description": "Esperado: 400, VALIDATION_ERROR / RH-QC-001"
          }
        },
        {
          "name": "Listar quinta categoría",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/rrhh/quinta-categoria?page=0&size=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "rrhh", "quinta-categoria"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "20" },
                { "key": "trabajadorId", "value": "1", "disabled": true },
                { "key": "anio", "value": "2026", "disabled": true },
                { "key": "mes", "value": "6", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Obtener quinta categoría por ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/rrhh/quinta-categoria/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "rrhh", "quinta-categoria", "1"]
            }
          }
        }
      ]
    },
    {
      "name": "02. Liquidacion",
      "item": [
        {
          "name": "Calcular liquidación",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"trabajadorId\": 3,\n  \"fechaCese\": \"2025-12-31\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/rrhh/liquidaciones/calcular",
              "host": ["{{baseUrl}}"],
              "path": ["api", "rrhh", "liquidaciones", "calcular"]
            },
            "description": "Esperado: 201. Requiere trabajador con fecha de cese registrada. Calcula CTS, gratificación trunca, vacaciones truncas, descuentos y neto. Estado inicial '1' (Pendiente)."
          }
        },
        {
          "name": "ERROR: Trabajador sin fecha de cese",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"trabajadorId\": 1\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/rrhh/liquidaciones/calcular",
              "host": ["{{baseUrl}}"],
              "path": ["api", "rrhh", "liquidaciones", "calcular"]
            },
            "description": "Esperado: 400, errorCode RH-LQ-002 (trabajador activo sin cese)"
          }
        },
        {
          "name": "ERROR: Liquidación duplicada",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"trabajadorId\": 3,\n  \"fechaCese\": \"2025-12-31\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/rrhh/liquidaciones/calcular",
              "host": ["{{baseUrl}}"],
              "path": ["api", "rrhh", "liquidaciones", "calcular"]
            },
            "description": "Esperado: 409, errorCode RH-LQ-003 (ya existe liquidación activa). Ejecutar después de calcular la primera."
          }
        },
        {
          "name": "Listar liquidaciones",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/rrhh/liquidaciones?page=0&size=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "rrhh", "liquidaciones"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "20" },
                { "key": "trabajadorId", "value": "3", "disabled": true },
                { "key": "flagEstado", "value": "1", "disabled": true },
                { "key": "fechaDesde", "value": "2025-01-01", "disabled": true },
                { "key": "fechaHasta", "value": "2025-12-31", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Obtener liquidación por ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/rrhh/liquidaciones/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "rrhh", "liquidaciones", "1"]
            }
          }
        },
        {
          "name": "Aprobar liquidación",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/rrhh/liquidaciones/1/aprobar",
              "host": ["{{baseUrl}}"],
              "path": ["api", "rrhh", "liquidaciones", "1", "aprobar"]
            },
            "description": "Esperado: 200. flagEstado '1' → '2'. Solo permitido si está Pendiente."
          }
        },
        {
          "name": "ERROR: Aprobar liquidación no pendiente",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/rrhh/liquidaciones/1/aprobar",
              "host": ["{{baseUrl}}"],
              "path": ["api", "rrhh", "liquidaciones", "1", "aprobar"]
            },
            "description": "Esperado: 400, errorCode RH-LQ-005 (ya aprobada). Ejecutar después de aprobar."
          }
        },
        {
          "name": "Anular liquidación",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/rrhh/liquidaciones/2/anular",
              "host": ["{{baseUrl}}"],
              "path": ["api", "rrhh", "liquidaciones", "2", "anular"]
            },
            "description": "Esperado: 200. flagEstado '1' → '0'. Solo permitido si está Pendiente."
          }
        }
      ]
    }
  ]
